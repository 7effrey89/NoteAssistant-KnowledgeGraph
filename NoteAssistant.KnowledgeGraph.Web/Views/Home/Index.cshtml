@{
    ViewData["Title"] = "Knowledge Graph Workbench";
    var backendBaseUrl = (string?)ViewData["BackendBaseUrl"] ?? "https://localhost:7228";
}

<div class="container py-3">
    <h1 class="mb-4">Knowledge Graph Workbench</h1>

    <div class="alert alert-info">
        <div class="d-flex flex-wrap align-items-center gap-2">
            <span>Backend endpoint: <code id="backendBaseUrl">@backendBaseUrl</code></span>
            <span class="d-flex align-items-center gap-1">
                <span id="backendLamp" class="status-lamp"></span>
                <small id="backendStatusText" class="text-muted">Checking backend...</small>
            </span>
        </div>
    </div>
    <div id="ageStatus" class="alert alert-warning d-none"></div>

    <div class="card mb-4">
        <div class="card-header">0) Optional: Reset PostgreSQL (dev only)</div>
        <div class="card-body">
            <p class="text-muted small mb-2">Drops the AGE graph, the graph schema, the kg_data schema (documents, chunks, entities, chunk_entities), the public fallback tables (documents, chunks, entities, chunk_entities), the AGE extension (ag_catalog), and clears the cache for document-to-entity breakdown.</p>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-outline-danger" id="resetDbBtn">Reset database</button>
                <button class="btn btn-outline-secondary" id="initScriptBtn">Run init script</button>
            </div>
            <div class="mt-2"><small id="resetDbMessage" class="text-muted">Use with caution.</small></div>
            <div class="mt-3">
                <div class="small text-muted">Init script output</div>
                <pre id="initScriptOutput" class="mt-2 p-2 bg-light border rounded" style="max-height: 240px; overflow:auto;"></pre>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">1) Upload markdown document</div>
        <div class="card-body">
            <div class="input-group">
                <input class="form-control" type="file" id="markdownFile" accept=".md" />
                <button class="btn btn-primary" id="uploadBtn">Upload & Analyze</button>
            </div>
            <div class="mt-2"><small id="uploadMessage" class="text-muted"></small></div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>2) Decomposition & ingestion status</span>
            <span id="cachedBadge" class="badge bg-warning text-dark" style="display:none;">cached</span>
        </div>
        <div class="card-body">
            <button class="btn btn-outline-secondary mb-3" id="refreshStatusBtn">Refresh Status</button>
            <div id="statusOutput" class="mb-3"></div>

            <ul class="nav nav-tabs" id="decompositionTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="tab-original-btn" data-bs-toggle="tab" data-bs-target="#tab-original" type="button" role="tab">Original Document</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-decomp-btn" data-bs-toggle="tab" data-bs-target="#tab-decomp" type="button" role="tab">Chunks · Entities · Links</button>
                </li>
            </ul>
            <div class="tab-content border border-top-0 p-3">
                <div class="tab-pane fade show active" id="tab-original" role="tabpanel">
                    <pre id="originalContent" style="max-height: 480px; overflow:auto; white-space: pre-wrap;" class="mb-0">Upload a document to see its raw markdown here.</pre>
                </div>
                <div class="tab-pane fade" id="tab-decomp" role="tabpanel">
                    <details class="mb-3 decomposition-prompt-details">
                        <summary>System prompt</summary>
                        <pre id="decompositionSystemPrompt" class="decomposition-prompt mb-0">Upload a document to see the prompt used for entity extraction.</pre>
                    </details>
                    <h5>Chunks</h5>
                    <ul id="chunksOutput"></ul>
                    <h5>Entities</h5>
                    <ul id="entitiesOutput"></ul>
                    <h5>Chunk → Entity links</h5>
                    <ul id="mentionsOutput"></ul>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">2.5) Metadata</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="metadataDocumentType">Document type</label>
                    <select class="form-select" id="metadataDocumentType">
                        <option value="">(select)</option>
                        <option value="transcription">Transcription</option>
                        <option value="meeting_summary">Meeting summary</option>
                        <option value="product_notes">Product notes</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="metadataDocumentDate">Document date</label>
                    <input class="form-control" type="date" id="metadataDocumentDate" />
                </div>
                <div class="col-md-12">
                    <label class="form-label" for="metadataTags">Tags (comma-separated)</label>
                    <input class="form-control" id="metadataTags" placeholder="e.g. power bi, external sharing" />
                </div>
            </div>
            <div class="mt-2 text-muted small">Metadata is stored with the document to support queries like "latest meeting".</div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">3) Ingest into PostgreSQL (relational)</div>
        <div class="card-body">
            <p class="text-muted small mb-2">Stores documents, chunks, entities, and embeddings in PostgreSQL. Requires <code>ConnectionStrings:AgeDatabase</code>.</p>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary" id="ingestBtn" disabled>Ingest to PostgreSQL</button>
                <button class="btn btn-outline-secondary" id="ingestSqlBtn" disabled>Show SQL</button>
                <button class="btn btn-outline-secondary" id="ingestLogBtn" disabled>Refresh log</button>
            </div>
            <div class="mt-2"><small id="ingestMessage" class="text-muted">Upload a document first.</small></div>
            <details class="mt-3">
                <summary>Ingest SQL</summary>
                <pre id="ingestSqlOutput" class="mt-2 p-2 bg-light border rounded" style="max-height: 240px; overflow:auto;"></pre>
            </details>
            <details class="mt-2">
                <summary>Ingest execution log</summary>
                <pre id="ingestLogOutput" class="mt-2 p-2 bg-light border rounded" style="max-height: 240px; overflow:auto;"></pre>
            </details>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">4) Build Apache AGE graph</div>
        <div class="card-body">
            <p class="text-muted small mb-2">Creates (if needed) and populates the AGE graph with the current document.</p>
            <button class="btn btn-outline-primary" id="initGraphBtn" disabled>Build graph</button>
            <div class="mt-2"><small id="initGraphMessage" class="text-muted">Upload a document first.</small></div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">5) Query editor + graph explorer</div>
        <div class="card-body">
            <div class="row g-3 query-workbench-layout">
                <div class="col-lg-3 query-workbench-sidebar">
                    <div class="mb-2">
                        <label class="form-label" for="assistantPrompt">Assistant prompt</label>
                        <div class="assistant-prompt-group">
                            <textarea class="form-control" id="assistantPrompt" rows="3" placeholder="e.g. show all chunks and mentioned entities"></textarea>
                            <button class="btn btn-outline-primary" id="assistBtn">Suggest query</button>
                        </div>
                        <div class="mt-2 d-flex flex-column gap-2">
                            <span class="text-muted small">Quick prompts:</span>
                            <button class="btn btn-sm btn-outline-secondary text-start" type="button" id="quickPrompt1">Show all chunks with entities</button>
                            <button class="btn btn-sm btn-outline-secondary text-start" type="button" id="quickPrompt2">Find entities related to Power BI</button>
                            <button class="btn btn-sm btn-outline-secondary text-start" type="button" id="quickPrompt3">List documents and chunk counts</button>
                        </div>
                        <small class="text-muted" id="assistExplanation"></small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="queryInput">Cypher query</label>
                        <textarea id="queryInput" class="form-control" rows="12"></textarea>
                    </div>
                    <button class="btn btn-success w-100" id="runQueryBtn">Run query</button>
                </div>
                <div class="col-lg-9 query-workbench-main">
                    <div id="queryError" class="text-danger mb-2"></div>
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <div id="graphCheckStatus" class="text-muted small flex-grow-1">Graph counts not loaded.</div>
                        <button class="btn btn-sm btn-outline-secondary" id="graphCheckBtn">Refresh counts</button>
                    </div>
                    <details class="query-workbench-details mb-2">
                        <summary>Cypher results</summary>
                        <div class="table-responsive query-results-panel mt-2">
                            <table class="table table-sm table-bordered mb-0" id="resultsTable"></table>
                        </div>
                    </details>
                    <details class="query-workbench-details mb-2" open>
                        <summary>Graph</summary>
                        <div id="graphView" class="mt-2 query-graph-view"></div>
                    </details>
                </div>
            </div>
            <details id="graphSelectionDetails" class="graph-selection-details mt-3">
                <summary id="graphSelectionSummary">Selected graph item details</summary>
                <div id="graphSelectionContent" class="graph-selection-content text-muted small">Click a node or edge in the graph to inspect it.</div>
            </details>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">6) Hybrid GraphRAG (Graph → Vector → LLM context)</div>
        <div class="card-body">
            <div class="mb-2">
                <label class="form-label" for="hybridQuestion">Question</label>
                <div class="input-group">
                    <input class="form-control" id="hybridQuestion" value="What did Microsoft do with OpenAI?" />
                    <button class="btn btn-primary" id="runHybridBtn">Run Hybrid Retrieval</button>
                </div>
                <div class="mt-2 d-flex flex-wrap gap-2">
                    <span class="text-muted small">Quick questions:</span>
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="hybridQuick1">Can F8 support them?</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="hybridQuick2">What is the meeting about?</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="hybridQuick3">What were the key takeaways?</button>
                </div>
                <div class="mt-2"><small id="hybridStatus" class="text-muted"></small></div>
                <div class="mt-2">
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="hybridTraceToggle" checked />
                        <label class="form-check-label" for="hybridTraceToggle">Show retrieval trace</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="hybridAnswerToggle" checked />
                        <label class="form-check-label" for="hybridAnswerToggle">Ask LLM for answer</label>
                    </div>
                </div>
            </div>
            <div id="hybridError" class="text-danger mb-2"></div>
            <h6>Process map</h6>
            <div id="hybridProcessMap" class="process-map"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
    <script>
        const backendBaseUrl = document.getElementById('backendBaseUrl').innerText.trim().replace(/\/$/, '');
        const backendLamp = document.getElementById('backendLamp');
        const backendStatusText = document.getElementById('backendStatusText');
        let currentDocumentId = null;
        let currentGraphName = 'knowledge_graph';
        let graphReady = false;
        let hybridClarificationAttempts = 0;

        const uploadBtn = document.getElementById('uploadBtn');
        const refreshStatusBtn = document.getElementById('refreshStatusBtn');
        const ingestBtn = document.getElementById('ingestBtn');
        const ingestSqlBtn = document.getElementById('ingestSqlBtn');
        const ingestLogBtn = document.getElementById('ingestLogBtn');
        const initGraphBtn = document.getElementById('initGraphBtn');
        const assistBtn = document.getElementById('assistBtn');
        const runQueryBtn = document.getElementById('runQueryBtn');
        const runHybridBtn = document.getElementById('runHybridBtn');
        const graphCheckBtn = document.getElementById('graphCheckBtn');
        const resetDbBtn = document.getElementById('resetDbBtn');
        const initScriptBtn = document.getElementById('initScriptBtn');
        const initScriptOutput = document.getElementById('initScriptOutput');
        const quickPrompt1 = document.getElementById('quickPrompt1');
        const quickPrompt2 = document.getElementById('quickPrompt2');
        const quickPrompt3 = document.getElementById('quickPrompt3');
        const hybridQuick1 = document.getElementById('hybridQuick1');
        const hybridQuick2 = document.getElementById('hybridQuick2');
        const hybridQuick3 = document.getElementById('hybridQuick3');

        uploadBtn.addEventListener('click', uploadFile);
        refreshStatusBtn.addEventListener('click', refreshStatus);
        ingestBtn.addEventListener('click', ingestToDatabase);
        ingestSqlBtn.addEventListener('click', loadIngestSql);
        ingestLogBtn.addEventListener('click', refreshIngestLog);
        initGraphBtn.addEventListener('click', initGraph);
        assistBtn.addEventListener('click', assistQuery);
        runQueryBtn.addEventListener('click', runQuery);
        runHybridBtn.addEventListener('click', runHybridRetrieval);
        graphCheckBtn.addEventListener('click', refreshGraphCheck);
        resetDbBtn.addEventListener('click', resetDatabase);
        initScriptBtn.addEventListener('click', runInitScript);
        quickPrompt1.addEventListener('click', () => setQuickPrompt('Show all chunks with entities'));
        quickPrompt2.addEventListener('click', () => setQuickPrompt('Find entities related to Power BI'));
        quickPrompt3.addEventListener('click', () => setQuickPrompt('List documents and chunk counts'));
        hybridQuick1.addEventListener('click', () => setHybridQuickQuestion('Can F8 support them?'));
        hybridQuick2.addEventListener('click', () => setHybridQuickQuestion('What is the meeting about?'));
        hybridQuick3.addEventListener('click', () => setHybridQuickQuestion('What were the key takeaways?'));

        document.getElementById('queryInput').value = `MATCH p=(n)-[r]->(m)\nRETURN n, r, m\nLIMIT 50`;
        window.addEventListener('load', () => {
            checkBackendStatus();
            setInterval(checkBackendStatus, 15000);
            loadGraphOnStartup();
        });

        function setQuickPrompt(text) {
            document.getElementById('assistantPrompt').value = text;
        }

        function setHybridQuickQuestion(text) {
            document.getElementById('hybridQuestion').value = text;
        }

        function getMetadataPayload() {
            return {
                documentType: document.getElementById('metadataDocumentType').value.trim(),
                documentDate: document.getElementById('metadataDocumentDate').value.trim(),
                tags: document.getElementById('metadataTags').value.trim()
            };
        }

        function setBackendStatus(state, text) {
            backendLamp.className = `status-lamp status-lamp-${state}`;
            backendStatusText.innerText = text;
        }

        async function checkBackendStatus() {
            setBackendStatus('warning', 'Checking backend...');
            try {
                const response = await fetch(`${backendBaseUrl}/api/health`);
                if (response.ok) {
                    setBackendStatus('online', 'Backend online');
                    return;
                }

                const payload = await response.json().catch(() => null);
                const detail = payload?.detail || payload?.error;
                setBackendStatus('warning', detail ? `Backend online: ${detail}` : `Backend online (status ${response.status}).`);
            } catch (err) {
                setBackendStatus('offline', `Backend offline: ${err.message}`);
            }
        }

        async function uploadFile() {
            const fileInput = document.getElementById('markdownFile');
            const file = fileInput.files[0];
            if (!file) {
                setMessage('uploadMessage', 'Please select a .md file first.', 'text-danger');
                return;
            }

            const formData = new FormData();
            formData.append('file', file);
            const metadata = getMetadataPayload();
            formData.append('documentType', metadata.documentType || '');
            formData.append('documentDate', metadata.documentDate || '');
            formData.append('tags', metadata.tags || '');

            setMessage('uploadMessage', `Uploading ${file.name}…`, 'text-muted');

            let response;
            try {
                response = await fetch(`${backendBaseUrl}/api/documents/upload`, {
                    method: 'POST',
                    body: formData
                });
            } catch (err) {
                console.error('Upload network error', err);
                setMessage('uploadMessage', `Network error calling ${backendBaseUrl}: ${err.message}. Check the backend is running and CORS allows ${window.location.origin}.`, 'text-danger');
                return;
            }

            let payload;
            try {
                payload = await response.json();
            } catch (err) {
                console.error('Upload parse error', err, response.status);
                setMessage('uploadMessage', `Backend returned non-JSON (status ${response.status}).`, 'text-danger');
                return;
            }

            if (!response.ok) {
                setMessage('uploadMessage', payload.error || `Upload failed with status ${response.status}.`, 'text-danger');
                return;
            }

            currentDocumentId = payload.documentId;
            if (payload.graphName) {
                currentGraphName = payload.graphName;
            }
            const cachedSuffix = payload.cached ? ' [from cache]' : '';
            setMessage('uploadMessage', `Document ${payload.documentId} analyzed (${payload.status.state})${cachedSuffix}.`, payload.cached ? 'text-warning' : 'text-success');
            document.getElementById('cachedBadge').style.display = payload.cached ? 'inline-block' : 'none';
            ingestBtn.disabled = false;
            ingestSqlBtn.disabled = false;
            ingestLogBtn.disabled = false;
            initGraphBtn.disabled = false;
            setMessage('ingestMessage', `Ready to ingest document ${payload.documentId} (${payload.chunks.length} chunks, ${payload.entities.length} entities).`, 'text-muted');
            setMessage('initGraphMessage', 'Ready to build graph for this document.', 'text-muted');
            renderDecomposition(payload);
            renderStatus(payload.status);
        }

        async function ingestToDatabase() {
            if (!currentDocumentId) {
                setMessage('ingestMessage', 'Upload a document first.', 'text-danger');
                return;
            }
            ingestBtn.disabled = true;
            setMessage('ingestMessage', `Ingesting document ${currentDocumentId} into PostgreSQL/AGE…`, 'text-muted');
            let response;
            try {
                response = await fetch(`${backendBaseUrl}/api/documents/${currentDocumentId}/ingest`, { method: 'POST' });
            } catch (err) {
                setMessage('ingestMessage', `Network error: ${err.message}`, 'text-danger');
                ingestBtn.disabled = false;
                return;
            }
            let payload;
            try { payload = await response.json(); } catch { payload = null; }
            if (!response.ok) {
                setMessage('ingestMessage', (payload && (payload.error || payload.detail)) || `Ingest failed (status ${response.status}).`, 'text-danger');
                ingestBtn.disabled = false;
                return;
            }
            if (payload?.graphName) {
                currentGraphName = payload.graphName;
            }
            const state = payload.status.state;
            const cls = state === 'Completed' ? 'text-success' : state === 'Ready' ? 'text-warning' : 'text-info';
            setMessage('ingestMessage', `${state}: ${payload.status.message}`, cls);
            renderStatus(payload.status);
            ingestBtn.disabled = false;
            await refreshIngestLog();
        }

        async function loadIngestSql() {
            if (!currentDocumentId) {
                return;
            }

            const output = document.getElementById('ingestSqlOutput');
            output.innerText = 'Loading SQL…';
            try {
                const response = await fetch(`${backendBaseUrl}/api/documents/${currentDocumentId}/ingest/preview`);
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    output.innerText = (payload && (payload.error || payload.detail)) || `Failed to load SQL (status ${response.status}).`;
                    return;
                }

                const relational = payload.relationalStatements || [];
                const graph = payload.graphStatements || [];
                const lines = [];
                lines.push('-- Relational statements');
                relational.forEach((stmt, idx) => lines.push(`-- ${idx + 1}\n${stmt}`));
                lines.push('');
                lines.push('-- Graph statements');
                graph.forEach((stmt, idx) => lines.push(`-- ${idx + 1}\n${stmt}`));
                output.innerText = lines.join('\n');
            } catch (err) {
                output.innerText = `Failed to load SQL: ${err.message}`;
            }
        }

        async function refreshIngestLog() {
            if (!currentDocumentId) {
                return;
            }

            const output = document.getElementById('ingestLogOutput');
            output.innerText = 'Loading log…';
            try {
                const response = await fetch(`${backendBaseUrl}/api/documents/${currentDocumentId}/ingest/log`);
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    output.innerText = (payload && (payload.error || payload.detail)) || `Failed to load log (status ${response.status}).`;
                    return;
                }

                const lines = [];
                lines.push(`Started: ${payload.startedAt}`);
                lines.push(`Completed: ${payload.completedAt || 'n/a'}`);
                lines.push(`Statements: ${payload.succeededStatements}/${payload.totalStatements} succeeded, ${payload.failedStatements} failed`);
                (payload.steps || []).forEach((step) => {
                    const status = step.success ? 'ok' : 'fail';
                    lines.push(`[${status}] #${step.index} ${step.statementType} (${step.durationMs}ms)`);
                    if (step.error) {
                        lines.push(`  error: ${step.error}`);
                    }
                    lines.push(`  ${step.statement}`);
                });
                output.innerText = lines.join('\n');
            } catch (err) {
                output.innerText = `Failed to load log: ${err.message}`;
            }
        }

        async function refreshStatus() {
            if (!currentDocumentId) {
                return;
            }

            const response = await fetch(`${backendBaseUrl}/api/documents/${currentDocumentId}/status`);
            const payload = await response.json();
            if (response.ok) {
                renderStatus(payload);
            }
        }

        async function assistQuery() {
            const prompt = document.getElementById('assistantPrompt').value.trim();
            if (!prompt) {
                document.getElementById('assistExplanation').innerText = 'Enter a prompt to get a suggested query.';
                return;
            }

            let response;
            try {
                response = await fetch(`${backendBaseUrl}/api/query/assist`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt })
                });
            } catch (err) {
                document.getElementById('assistExplanation').innerText = `Assistant request failed: ${err.message}`;
                return;
            }

            let payload = null;
            try { payload = await response.json(); } catch { payload = null; }
            if (!response.ok) {
                document.getElementById('assistExplanation').innerText = (payload && payload.error) || 'Assistant failed.';
                return;
            }

            document.getElementById('queryInput').value = payload.suggestedCypher;
            document.getElementById('assistExplanation').innerText = payload.explanation;
        }

        async function runQuery() {
            const query = document.getElementById('queryInput').value.trim();
            if (!query) {
                document.getElementById('queryError').innerText = 'Cypher query is required.';
                renderResults([]);
                renderGraph([], []);
                return;
            }
            const response = await fetch(`${backendBaseUrl}/api/query`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cypher: query, graphName: currentGraphName })
            });

            const payload = await response.json();
            if (!response.ok) {
                document.getElementById('queryError').innerText = payload.error || 'Query failed.';
                renderResults([]);
                renderGraph([], []);
                return;
            }

            document.getElementById('queryError').innerText = '';
            renderResults(payload.rows || []);
            renderGraph(payload.nodes || [], payload.edges || []);
        }

        async function loadGraphOnStartup() {
            document.getElementById('queryError').innerText = 'Loading graph…';
            try {
                const health = await fetch(`${backendBaseUrl}/api/health/age`);
                if (!health.ok) {
                    const payload = await health.json().catch(() => null);
                    graphReady = false;
                    showAgeStatus(payload?.detail || 'Graph not available until AGE is ready.');
                    document.getElementById('queryError').innerText = 'Graph not available until AGE is ready.';
                    setMessage('initGraphMessage', payload?.detail || 'Initialize the graph in step 4.', 'text-warning');
                    return;
                }
                graphReady = true;
                showAgeStatus('');
                setMessage('initGraphMessage', 'Graph is ready.', 'text-success');
                try {
                    const info = await fetch(`${backendBaseUrl}/api/graph/info`);
                    if (info.ok) {
                        const payload = await info.json();
                        if (payload?.graphName) {
                            currentGraphName = payload.graphName;
                        }
                    }
                } catch {
                    // ignore graph info lookup failures
                }
            } catch (err) {
                graphReady = false;
                showAgeStatus(`Backend not reachable: ${err.message}`);
                document.getElementById('queryError').innerText = `Backend not reachable: ${err.message}`;
                setMessage('initGraphMessage', 'Backend not reachable.', 'text-danger');
                return;
            }

            await refreshGraphCheck();
            await runQuery();
        }

        async function initGraph() {
            if (!currentDocumentId) {
                setMessage('initGraphMessage', 'Upload a document first.', 'text-danger');
                return;
            }

            initGraphBtn.disabled = true;
            setMessage('initGraphMessage', 'Building graph…', 'text-muted');

            let response;
            try {
                response = await fetch(`${backendBaseUrl}/api/documents/${currentDocumentId}/graph`, { method: 'POST' });
            } catch (err) {
                setMessage('initGraphMessage', `Graph build failed: ${err.message}`, 'text-danger');
                initGraphBtn.disabled = false;
                return;
            }

            let payload = null;
            try { payload = await response.json(); } catch { payload = null; }
            if (!response.ok) {
                setMessage('initGraphMessage', (payload && (payload.detail || payload.error)) || `Graph build failed (status ${response.status}).`, 'text-danger');
                initGraphBtn.disabled = false;
                return;
            }

            graphReady = true;
            showAgeStatus('');
            if (payload?.graphName) {
                currentGraphName = payload.graphName;
            }
            setMessage('initGraphMessage', `Graph ${currentGraphName} built for document ${currentDocumentId}.`, 'text-success');
            await refreshGraphCheck();
            await runQuery();
        }

        async function refreshGraphCheck() {
            const statusEl = document.getElementById('graphCheckStatus');
            statusEl.innerText = 'Loading counts…';
            try {
                const response = await fetch(`${backendBaseUrl}/api/graph/check`);
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    statusEl.innerText = (payload && (payload.detail || payload.error)) || `Counts unavailable (status ${response.status}).`;
                    return;
                }

                const exists = payload.graphExists ? 'yes' : 'no';
                statusEl.innerText = `Graph: ${payload.graphName} (exists: ${exists}) | documents: ${payload.documents} | chunks: ${payload.chunks} | entities: ${payload.entities} | mentions: ${payload.mentions}`;
            } catch (err) {
                statusEl.innerText = `Counts unavailable: ${err.message}`;
            }
        }

