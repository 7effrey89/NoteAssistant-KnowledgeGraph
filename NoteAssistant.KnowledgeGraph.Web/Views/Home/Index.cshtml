        const graphSettingsToggleBtn = document.getElementById('graphSettingsToggleBtn');
        const querySidebarToggleBtn = document.getElementById('querySidebarToggleBtn');

        if (hybridModeInfoBtn && window.bootstrap?.Popover) {
            const modeGuideHtml = [
                '<div class="small">',
                '<div class="fw-semibold mb-1">Which mode should I choose?</div>',
                '<div><strong>Auto</strong>: Router chooses for you based on intent.</div>',
                '<div class="text-muted mb-1">Use when unsure.</div>',
                '<div><strong>Local / Entity-first</strong>: Focused retrieval around matched entities.</div>',
                '<div class="text-muted mb-1">Ideal: direct fact lookup about specific customers, products, or people.</div>',
                '<div><strong>Light / Parallel-friendly</strong>: Entity branch + global branch in parallel, then merge/rerank.</div>',
                '<div class="text-muted mb-1">Ideal: broad summaries, status snapshots, and mixed-signal questions.</div>',
                '<div><strong>Path / Multi-hop</strong>: Prioritizes relationship chains and path evidence grounding.</div>',
                '<div class="text-muted mb-1">Ideal: "how/why" questions involving indirect influence or dependency chains.</div>',
                '<div><strong>Global / Temporal</strong>: Community summaries first, timeline second, answer third.</div>',
                '<div class="text-muted mb-1">This is not entity-first lookup. It starts from community summaries, then uses the timeline as supporting context.</div>',
