        const communityTuningSystemPrompt = document.getElementById('communityTuningSystemPrompt');
        const communityTuningUserPrompt = document.getElementById('communityTuningUserPrompt');
        const communityProfileList = document.getElementById('communityProfileList');
        const communityLoadProfilesBtn = document.getElementById('communityLoadProfilesBtn');
        const communityProfileMeta = document.getElementById('communityProfileMeta');
        const communityContinueBtn = document.getElementById('communityContinueBtn');
        const communityPostTuneBtn = document.getElementById('communityPostTuneBtn');
        const communityPostTuneBtnWrapper = document.getElementById('communityPostTuneBtnWrapper');
        const communityRevertProfileBtn = document.getElementById('communityRevertProfileBtn');
        const communityPreBuildGate = document.getElementById('communityPreBuildGate');
        const communityPreBuildMessage = document.getElementById('communityPreBuildMessage');
        const communityPreBuildAssessment = document.getElementById('communityPreBuildAssessment');
        const communityProceedBuildBtn = document.getElementById('communityProceedBuildBtn');
        const communityTuneBeforeBuildBtn = document.getElementById('communityTuneBeforeBuildBtn');
        const communityCancelBuildBtn = document.getElementById('communityCancelBuildBtn');
        const communityPostBuildActions = document.getElementById('communityPostBuildActions');
        const communityPostBuildMessage = document.getElementById('communityPostBuildMessage');
        const communityQuickAssessment = document.getElementById('communityQuickAssessment');
        const communityFinalProfileDetails = document.getElementById('communityFinalProfileDetails');
