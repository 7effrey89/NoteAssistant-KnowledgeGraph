        }

        const backendBaseUrl = document.getElementById('backendBaseUrl').innerText.trim().replace(/\/$/, '');
        const backendLamp = document.getElementById('backendLamp');
        const backendStatusText = document.getElementById('backendStatusText');
        let currentDocumentId = null;
        let currentGraphName = 'knowledge_graph';
        let communitySummaryTabsState = null;
        let communityProfilesState = {
            activeProfileId: null,
            selectedProfileId: null,
            previousProfileId: null,
            profiles: [],
            defaults: null,
            previousConfigSnapshot: null
        };
        let communityFurtherTuningDisabledReason = '';
        let communityBuildGatePending = false;
        let graphReady = false;
        const uploadedDocuments = new Map();
        const selectedDocumentIds = new Set();
        const metadataDrafts = new Map();
        let decompositionStepCompleted = false;
        let hybridClarificationAttempts = 0;
        let graphCy = null;
        let graphNetwork = null;
        let backgroundCytoscapeLayout = null;
        let querySidebarCollapsed = false;
        let graphSettingsCollapsed = false;
        let currentVisNodeDataSet = null;
        let currentVisEdgeDataSet = null;
        let currentVisNodeItems = [];
        let currentVisEdgeItems = [];
        let currentGraphNodes = [];
        let currentGraphEdges = [];
        let currentGraphNodeMap = new Map();
        let currentGraphEdgeMap = new Map();
        let currentGraphLabelColorMap = new Map();
        const legacyVisNetworkPalette = Object.freeze([
            { background: '#97C2FC', border: '#2B7CE9' },
            { background: '#FFFF00', border: '#FFA500' },
            { background: '#FB7E81', border: '#FA0A10' },
            { background: '#7BE141', border: '#41A906' },
            { background: '#6E6EFD', border: '#0000FF' },
            { background: '#C2FABC', border: '#4AD63A' },
            { background: '#FFA807', border: '#FFA500' },
