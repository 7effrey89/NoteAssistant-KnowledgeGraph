        }

        async function runHybridRetrieval(isClarification = false) {
            const question = document.getElementById('hybridQuestion').value.trim();
            if (!question) {
                document.getElementById('hybridError').innerText = 'Question is required.';
                return;
            }

            const hybridStatus = document.getElementById('hybridStatus');
            const includeTrace = document.getElementById('hybridTraceToggle').checked;
            const includeAnswer = document.getElementById('hybridAnswerToggle').checked;

            if (!isClarification) {
                hybridClarificationAttempts = 0;
                renderProcessMap([], false);
            }

            runHybridBtn.disabled = true;
            hybridStatus.innerText = 'Processing retrieval...';

            const response = await fetch(`${backendBaseUrl}/api/retrieval/hybrid`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    query: question,
                    graphName: currentGraphName,
                    maxHops: 2,
                    limit: 10,
                    includeTrace,
                    includeAnswer,
                    clarificationAttempts: hybridClarificationAttempts,
                    clarificationResponse: isClarification ? (window.lastClarificationResponse || '') : ''
                })
            });

            const payload = await response.json();
            if (!response.ok) {
                document.getElementById('hybridError').innerText = payload.error || 'Hybrid retrieval failed.';
                appendProcessMap([{ title: 'Retrieval failed', body: payload.error || 'Hybrid retrieval failed.' }]);
                hybridStatus.innerText = 'Retrieval failed.';
                runHybridBtn.disabled = false;
                return;
            }

            document.getElementById('hybridError').innerText = '';

            const trace = payload.trace;
            const mapItems = [];

            // Helpers ------------------------------------------------------
            const analysisSystemPrompt = payload.analysisSystemPrompt || '(not available)';
            const answerSystemPrompt = payload.systemPrompt || '(not available)';
            const entityLlmStep = getTraceStep(trace, 'entity-llm');
            const answerStep = getTraceStep(trace, 'llm-answer');
            const matchStep = getTraceStep(trace, 'entity-match');
            const expansionStep = getTraceStep(trace, 'graph-expansion');
            const embeddingStep = getTraceStep(trace, 'embedding');
            const vectorStep = getTraceStep(trace, 'vector-search');
            const fallbackStep = getTraceStep(trace, 'entity-fallback');

            function buildAgentBubble(title, role, systemPrompt, step) {
                return {
                    title,
                    variant: 'agent',
                    role,
                    systemPrompt,
                    tokenUsage: step && step.tokenUsage ? step.tokenUsage : null
                };
            }

            function buildSqlBubble(title, detail, indent = true) {
                const sql = parseSqlSections(detail);
                if (sql) {
                    return {
                        title,
                        indent,
                        bodyHtml: buildSqlToggleHtml(sql.parameterized, sql.executable)
                    };
                }
                return {
                    title,
                    indent,
                    bodyHtml: `<pre class="sql-toggle-view">${escapeHtml(detail || '(trace disabled)')}</pre>`
                };
            }

            // Phase 0: User question (only on initial call, not on clarification resubmits)
            if (!isClarification) {
                mapItems.push({ title: 'User question received', body: question });
            }

            // Phase 1: Clarification required path -------------------------
            if (payload.clarificationQuestion) {
                mapItems.push(buildAgentBubble(
                    'Clarification Agent',
                    'Detect ambiguity in the user question and ask a clarifying question when needed.',
                    analysisSystemPrompt,
                    entityLlmStep));
                mapItems.push({
                    title: 'Clarification needed',
                    indent: true,
                    body: `${payload.clarificationQuestion} (attempt ${hybridClarificationAttempts + 1} of 3)`,
                    clarification: true,
                    baseQuestion: payload.rewrittenQuestion || question
                });
                appendProcessMap(mapItems);
                hybridStatus.innerText = 'Clarification required.';
                runHybridBtn.disabled = false;
                return;
            }

            // Phase 2: Clarification received + question rewrite ----------
            if (isClarification && window.lastClarificationResponse) {
                mapItems.push(buildAgentBubble(
                    'Clarification Agent',
                    'Detect ambiguity in the user question and ask a clarifying question when needed.',
                    analysisSystemPrompt,
                    entityLlmStep));
                mapItems.push({
                    title: 'Clarification received',
                    indent: true,
                    body: window.lastClarificationResponse
                });
                if (payload.rewrittenQuestion) {
                    mapItems.push({
                        title: 'Question rewrite',
                        indent: true,
                        body: payload.rewrittenQuestion
                    });
                }
            }

            const effectiveQuestion = payload.rewrittenQuestion || question;

            // Phase 3: Entity detection -----------------------------------
            mapItems.push(buildAgentBubble(
                'Entity detection Agent',
                'Extract entities from the user question. Falls back to a heuristic detector if the agent fails.',
                analysisSystemPrompt,
                entityLlmStep));

            const detectedList = fallbackStep ? [] : (payload.detectedEntities || []);
            mapItems.push({
                title: 'Entity detected',
                indent: true,
                body: detectedList.length ? detectedList.join(', ') : '(none)'
            });

            if (matchStep || (payload.matchedEntities && payload.matchedEntities.length)) {
                const matchDetail = includeTrace && matchStep?.detail ? matchStep.detail : '(trace disabled)';
                mapItems.push(buildSqlBubble('Graph Entity matching', matchDetail, true));
                mapItems.push({
                    title: 'Entity match output',
                    indent: true,
                    body: (payload.matchedEntities || []).join(', ') || '(none)'
                });
            }

            if (fallbackStep) {
                const fallbackDetail = includeTrace && fallbackStep.detail ? fallbackStep.detail : '(trace disabled)';
                mapItems.push({
                    title: 'Entity fallback output',
                    indent: true,
                    body: truncateText(fallbackDetail, 500)
                });
            }

            // Phase 4: Graph-expanded entities ----------------------------
            mapItems.push({
                title: 'Graph-expanded entities',
                variant: 'purpose',
                purpose: 'Traverse the knowledge graph from matched entities to discover related entities to broaden retrieval.'
            });
            const expansionDetail = includeTrace && expansionStep?.detail ? expansionStep.detail : '(trace disabled)';
            mapItems.push({
                title: 'Graph expansion query',
                indent: true,
                scroll: true,
                body: truncateText(expansionDetail, 1200)
            });
            mapItems.push({
                title: 'Graph-expanded entities',
                indent: true,
                body: (payload.graphEntities || []).join(', ') || '(none)'
            });

            // Phase 5: Question Embedding ---------------------------------
            mapItems.push({
                title: 'Question Embedding',
                variant: 'purpose',
                purpose: 'Vectorize the question for similarity search.',
                inputText: effectiveQuestion
            });
            const embeddingDetail = includeTrace && embeddingStep?.detail ? embeddingStep.detail : '';
            const embeddingOutputText = (() => {
                if (!embeddingDetail) {
                    return '(trace disabled)';
                }
                const outputIdx = embeddingDetail.indexOf('Output:');
                const tail = outputIdx >= 0 ? embeddingDetail.slice(outputIdx + 'Output:'.length).trim() : embeddingDetail;
                return truncateText(tail, 600);
            })();
            mapItems.push({
                title: 'Question Embedding Output',
                indent: true,
                scroll: true,
                body: embeddingOutputText
            });

            // Phase 6: Vector Search --------------------------------------
            const vectorDetail = includeTrace && vectorStep?.detail ? vectorStep.detail : '(trace disabled)';
            const vectorSql = parseSqlSections(vectorDetail);
            const vectorBubble = {
                title: 'Vector Search',
                variant: 'purpose',
                purpose: 'Find relevant chunks filtered by relevant entities to answer the user question.'
            };
            if (vectorSql) {
                vectorBubble.bodyHtml = buildSqlToggleHtml(vectorSql.parameterized, vectorSql.executable);
            } else {
                vectorBubble.bodyHtml = `<pre class="sql-toggle-view">${escapeHtml(vectorDetail)}</pre>`;
            }
            mapItems.push(vectorBubble);

            const chunkLines = (payload.chunks || []).map(c => `[doc:${c.documentId} chunk:${c.chunkIndex}] ${c.content} (distance: ${c.distance ?? 'n/a'})`);
            mapItems.push({
                title: 'Vector Search Output',
                indent: true,
                scroll: true,
                body: chunkLines.length === 0 ? '(none)' : chunkLines.join('\n')
            });

            // Phase 7: Answer Agent ---------------------------------------
            if (includeAnswer) {
                mapItems.push(buildAgentBubble(
                    'Answer Agent',
                    'Synthesize an answer for the user question using the retrieved chunks. Falls back to a heuristic response if the agent fails.',
                    answerSystemPrompt,
                    answerStep));
                mapItems.push({
                    title: 'Agent Answer',
                    indent: true,
                    scroll: true,
                    body: payload.answer || '(no answer returned)'
                });
            }

            appendProcessMap(mapItems);

            hybridStatus.innerText = 'Retrieval complete.';
            hybridClarificationAttempts = 0;
            window.lastClarificationResponse = '';
            runHybridBtn.disabled = false;
        }

        function renderDecomposition(payload) {
            document.getElementById('originalContent').textContent = payload.originalContent || '(no original content returned)';
            document.getElementById('decompositionSystemPrompt').textContent = payload.decompositionSystemPrompt || '(no system prompt returned)';
            renderList('chunksOutput', payload.chunks.map(c => `#${c.id}: ${c.text}`));
            renderList('entitiesOutput', payload.entities.map(e => `${e.label}: ${e.name}`));
            renderList('mentionsOutput', payload.mentions.map(m => `Chunk ${m.chunkId} -> ${m.entityLabel}(${m.entityName})`));
        }

        function renderStatus(status) {
            document.getElementById('statusOutput').innerText =
                `Document ${status.documentId}: ${status.state} | ${status.message} | Updated: ${status.updatedAt}`;
        }

        function renderList(elementId, items) {
            const list = document.getElementById(elementId);
            list.innerHTML = '';
            for (const item of items) {
                const li = document.createElement('li');
                li.innerText = item;
                list.appendChild(li);
            }
        }

        function renderProcessMap(items, append = false) {
            const container = document.getElementById('hybridProcessMap');
            if (!append) {
                container.innerHTML = '';
            }

            if (!items || items.length === 0) {
                if (!append) {
                    container.innerText = '(no process steps to display)';
                }
                return;
            }

            if (append && container.children.length > 0) {
                const connector = document.createElement('div');
                connector.className = 'process-connector';
                if (items[0].indent) {
                    connector.classList.add('process-connector-indent');
                }
                container.appendChild(connector);
            }

            items.forEach((item, index) => {
                const bubble = createProcessBubble(item);
                container.appendChild(bubble);

                if (index < items.length - 1) {
                    const connector = document.createElement('div');
                    connector.className = 'process-connector';
                    if (item.indent) {
                        connector.classList.add('process-connector-indent');
                    }
                    container.appendChild(connector);
                }
            });
        }

        function appendProcessMap(items) {
            renderProcessMap(items, true);
        }

        function createProcessBubble(item) {
            const bubble = document.createElement('div');
            bubble.className = 'process-bubble';
            if (item.indent) {
                bubble.classList.add('process-bubble-indent');
            }
            if (item.scroll) {
                bubble.classList.add('process-bubble-scroll');
            }
            if (item.variant === 'agent') {
                bubble.classList.add('process-bubble-agent');
            } else if (item.variant === 'purpose') {
                bubble.classList.add('process-bubble-purpose');
            }

            const title = document.createElement('div');
            title.className = 'process-bubble-title';
            title.innerText = item.title || 'Step';
            bubble.appendChild(title);

            if (item.role) {
                const section = document.createElement('div');
                section.className = 'process-bubble-section';
                section.innerHTML = `<span class="label">Role:</span> ${escapeHtml(item.role)}`;
                bubble.appendChild(section);
            }

            if (item.purpose) {
                const section = document.createElement('div');
                section.className = 'process-bubble-section';
                section.innerHTML = `<span class="label">Purpose:</span> ${escapeHtml(item.purpose)}`;
                bubble.appendChild(section);
            }

            if (item.inputText) {
                const section = document.createElement('div');
                section.className = 'process-bubble-section';
                section.innerHTML = `<span class="label">Input:</span> ${escapeHtml(item.inputText)}`;
                bubble.appendChild(section);
            }

            if (item.body || item.bodyHtml) {
                const body = document.createElement('div');
                body.className = 'process-bubble-body';
                if (item.bodyHtml) {
                    body.innerHTML = item.bodyHtml;
                } else {
                    body.innerText = item.body;
                }
                bubble.appendChild(body);
            }

            if (item.systemPrompt) {
                const details = document.createElement('details');
                details.className = 'process-bubble-systemprompt';
                const summary = document.createElement('summary');
                summary.innerText = 'System Prompt';
                details.appendChild(summary);
                const pre = document.createElement('pre');
                pre.innerText = item.systemPrompt;
                details.appendChild(pre);
                bubble.appendChild(details);
            }

            if (item.tokenUsage) {
                const tokens = document.createElement('div');
                tokens.className = 'process-bubble-tokens';
                const p = item.tokenUsage.promptTokens;
                const c = item.tokenUsage.completionTokens;
                const promptText = (p === null || p === undefined) ? 'n/a' : p;
                const completionText = (c === null || c === undefined) ? 'n/a' : c;
                tokens.innerText = `Token usage: prompt: ${promptText} | completion: ${completionText}`;
                bubble.appendChild(tokens);
            }

            if (item.clarification) {
                const inputGroup = document.createElement('div');
                inputGroup.className = 'input-group mt-2';

                const input = document.createElement('input');
                input.className = 'form-control';
                input.type = 'text';
                input.placeholder = 'Your clarification...';

                const button = document.createElement('button');
                button.className = 'btn btn-outline-primary';
                button.type = 'button';
                button.innerText = 'Submit clarification';
                if (hybridClarificationAttempts >= 3) {
                    input.disabled = true;
                    button.disabled = true;
                }
                button.addEventListener('click', () => {
                    const value = input.value.trim();
                    if (!value) {
                        return;
                    }

                        const base = item.baseQuestion || document.getElementById('hybridQuestion').value.trim();
                        document.getElementById('hybridQuestion').value = base;
                        window.lastClarificationResponse = value;
                    hybridClarificationAttempts += 1;
                    runHybridRetrieval(true);
                });

                inputGroup.appendChild(input);
                inputGroup.appendChild(button);
                bubble.appendChild(inputGroup);
            }

            return bubble;
        }

        function getTraceStep(trace, name) {
            if (!trace || !Array.isArray(trace.steps)) {
                return null;
            }

            return trace.steps.find(step => step.name === name) || null;
        }

        function truncateText(value, maxLength) {
            if (!value) {
                return '';
            }

            return value.length > maxLength ? `${value.slice(0, maxLength)}...` : value;
        }

        function escapeHtml(value) {
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function parseSqlSections(value) {
            if (!value) {
                return null;
            }

            const parameterizedHeader = 'Parameterized SQL:';
            const executableHeader = 'Executable SQL:';
            const parameterizedIndex = value.indexOf(parameterizedHeader);
            const executableIndex = value.indexOf(executableHeader);
            if (parameterizedIndex === -1 || executableIndex === -1) {
                return null;
            }

            const parameterized = value
                .slice(parameterizedIndex + parameterizedHeader.length, executableIndex)
                .trim();
            const executable = value
                .slice(executableIndex + executableHeader.length)
                .trim();
            return { parameterized, executable };
        }

        function buildSqlToggleHtml(parameterizedSql, executableSql) {
            const parameterized = escapeHtml(parameterizedSql);
            const executable = escapeHtml(executableSql);
            return `
                <div class="sql-toggle" data-view="parameterized">
                    <div class="btn-group btn-group-sm sql-toggle-buttons" role="group">
                        <button type="button" class="btn btn-outline-secondary sql-toggle-btn active" data-view="parameterized">Parameterized</button>
                        <button type="button" class="btn btn-outline-secondary sql-toggle-btn" data-view="executable">Executable</button>
                    </div>
                    <pre class="sql-toggle-view sql-toggle-view-parameterized">${parameterized}</pre>
                    <pre class="sql-toggle-view sql-toggle-view-executable d-none">${executable}</pre>
                </div>`;
        }

        document.addEventListener('click', (event) => {
            const button = event.target.closest('.sql-toggle-btn');
            if (!button) {
                return;
            }

            const container = button.closest('.sql-toggle');
            if (!container) {
                return;
            }

            const view = button.dataset.view;
            container.querySelectorAll('.sql-toggle-view').forEach((element) => {
                element.classList.toggle('d-none', !element.classList.contains(`sql-toggle-view-${view}`));
            });
            container.querySelectorAll('.sql-toggle-btn').forEach((btn) => {
                btn.classList.toggle('active', btn === button);
            });
        });

        function renderResults(rows) {
            const table = document.getElementById('resultsTable');
            table.innerHTML = '';
            if (!rows.length) {
                return;
            }

            const keys = Object.keys(rows[0]);
            const thead = document.createElement('thead');
            const headRow = document.createElement('tr');
            keys.forEach(k => {
                const th = document.createElement('th');
                th.innerText = k;
                headRow.appendChild(th);
            });
            thead.appendChild(headRow);
            table.appendChild(thead);

            const tbody = document.createElement('tbody');
            rows.forEach(row => {
                const tr = document.createElement('tr');
                keys.forEach(key => {
                    const td = document.createElement('td');
                    td.innerText = row[key] ?? '';
                    tr.appendChild(td);
                });
                tbody.appendChild(tr);
            });
            table.appendChild(tbody);
        }

        function renderGraph(nodes, edges) {
            const container = document.getElementById('graphView');
            container.innerHTML = '';
            resetGraphSelectionDetails();

            if (!nodes.length) {
                container.innerText = 'No graph primitives returned. Use a query that returns vertices/edges.';
                return;
            }

            if (!window.vis || !window.vis.Network) {
                container.innerText = 'vis-network failed to load. Check internet access or bundle the library locally.';
                return;
            }

            const nodesById = new Map(nodes.map(node => [String(node.id), node]));
            const edgesById = new Map();
            const visNodes = new vis.DataSet(nodes.map(node => ({ id: node.id, label: node.title, group: node.label })));
            const visEdges = new vis.DataSet(edges.map((edge, index) => {
                const id = `edge-${index}`;
                edgesById.set(id, edge);
                return { id, from: edge.source, to: edge.target, label: edge.label, arrows: 'to' };
            }));

            const network = new vis.Network(container, { nodes: visNodes, edges: visEdges }, {
                interaction: { hover: true, navigationButtons: true },
                physics: { stabilization: false }
            });

            network.on('click', (params) => {
                const nodeId = params.nodes && params.nodes.length > 0 ? params.nodes[0] : null;
                if (nodeId !== null) {
                    const node = nodesById.get(String(nodeId));
                    if (node) {
                        showGraphNodeDetails(node);
                        return;
                    }
                }

                const edgeId = params.edges && params.edges.length > 0 ? params.edges[0] : null;
                if (edgeId !== null) {
                    const edge = edgesById.get(String(edgeId));
                    if (edge) {
                        showGraphEdgeDetails(edge, nodesById);
                        return;
                    }
                }

                resetGraphSelectionDetails();
            });
        }

        function resetGraphSelectionDetails() {
            const details = document.getElementById('graphSelectionDetails');
            const summary = document.getElementById('graphSelectionSummary');
            const content = document.getElementById('graphSelectionContent');
            details.open = false;
            summary.innerText = 'Selected graph item details';
            content.className = 'graph-selection-content text-muted small';
            content.innerText = 'Click a node or edge in the graph to inspect it.';
        }

        async function showGraphNodeDetails(node) {
            showGraphSelectionDetails(`Node: ${node.title || node.id}`, [
                ['Type', 'Node', 'vis-network selection'],
                ['AGE ID', node.id, 'AGE vertex.id'],
                ['Label', node.label, 'AGE vertex.label'],
                ['Title', node.title, 'display value'],
                ...objectEntriesToRows(node.properties || {}, (key) => `AGE vertex.properties.${key}`)
            ], true);

            try {
                const response = await fetch(`${backendBaseUrl}/api/graph/node/details`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id: String(node.id),
                        label: node.label || '',
                        title: node.title || '',
                        properties: node.properties || {}
                    })
                });
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    setGraphRelationalDetails(payload?.error || `Could not load kg_data details (status ${response.status}).`, true);
                    return;
                }

                setGraphRelationalDetails(payload?.attributes || {}, payload?.attributeSources || {}, false, node, payload?.attributeSourceSqls || {});
            } catch (err) {
                setGraphRelationalDetails(`Could not load kg_data details: ${err.message}`, true);
            }
        }

        function showGraphEdgeDetails(edge, nodesById) {
            const source = nodesById.get(String(edge.source));
            const target = nodesById.get(String(edge.target));
            showGraphSelectionDetails(`Edge: ${edge.label || 'relationship'}`, [
                ['Type', 'Edge', 'vis-network selection'],
                ['Label', edge.label, 'AGE edge.label'],
                ['Source ID', edge.source, 'AGE edge.start_id'],
                ['Source title', source?.title || '', 'display value'],
                ['Target ID', edge.target, 'AGE edge.end_id'],
                ['Target title', target?.title || '', 'display value']
            ]);
        }

        function showGraphSelectionDetails(summaryText, rows, includeRelationalDetails = false) {
            const details = document.getElementById('graphSelectionDetails');
            const summary = document.getElementById('graphSelectionSummary');
            const content = document.getElementById('graphSelectionContent');

            summary.innerText = summaryText;
            content.className = 'graph-selection-content';
            content.innerHTML = '';

            const grid = document.createElement('div');
            grid.className = includeRelationalDetails ? 'graph-selection-grid' : '';

            const graphPanel = document.createElement('div');
            const graphTitle = document.createElement('div');
            graphTitle.className = 'graph-selection-panel-title';
            graphTitle.innerText = 'Graph item';
            graphPanel.appendChild(graphTitle);
            graphPanel.appendChild(createGraphAttributeTable(rows));
            grid.appendChild(graphPanel);

            if (includeRelationalDetails) {
                const relationalPanel = document.createElement('div');
                const relationalTitle = document.createElement('div');
                relationalTitle.className = 'graph-selection-panel-title';
                relationalTitle.innerText = 'kg_data attributes';
                relationalPanel.appendChild(relationalTitle);

                const relationalContent = document.createElement('div');
                relationalContent.id = 'graphRelationalDetails';
                relationalContent.className = 'text-muted small';
                relationalContent.innerText = 'Loading relational details...';
                relationalPanel.appendChild(relationalContent);
                grid.appendChild(relationalPanel);
            }

            content.appendChild(grid);
            details.open = true;
        }

        function createGraphAttributeTable(rows) {
            const table = document.createElement('table');
            table.className = 'table table-sm table-bordered mb-0 graph-selection-table';
            const thead = document.createElement('thead');
            const headerRow = document.createElement('tr');
            const columnDescriptions = {
                Attribute: 'The displayed field name for the selected graph item or relational row.',
                Value: 'The value returned for that field. Long values are shortened until expanded.',
                Source: 'Where the value came from. For derived values, this can be executable SQL.'
            };
            ['Attribute', 'Value', 'Source'].forEach((label) => {
                const th = document.createElement('th');
                th.scope = 'col';
                th.innerText = label;
                th.title = columnDescriptions[label];
                headerRow.appendChild(th);
            });
            thead.appendChild(headerRow);
            table.appendChild(thead);

            const tbody = document.createElement('tbody');
            rows.forEach(([label, value, source, sourceSql]) => {
                const tr = document.createElement('tr');
                const th = document.createElement('th');
                th.scope = 'row';
                th.innerText = label;
                const td = document.createElement('td');
                appendExpandableCellContent(td, value ?? '');
                const sourceTd = document.createElement('td');
                sourceTd.className = 'graph-selection-source';
                appendSourceCellContent(sourceTd, source || '', sourceSql || '');
                tr.appendChild(th);
                tr.appendChild(td);
                tr.appendChild(sourceTd);
                tbody.appendChild(tr);
            });
            table.appendChild(tbody);
            return table;
        }

        function appendExpandableCellContent(cell, value) {
            const text = String(value ?? '');
            const maxLength = 140;
            if (text.length <= maxLength) {
                cell.innerText = text;
                return;
            }

            const textSpan = document.createElement('span');
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn btn-sm btn-outline-secondary graph-cell-toggle';
            button.title = 'Expand or collapse full cell text';

            let expanded = false;
            const render = () => {
                textSpan.innerText = expanded ? text : `${text.slice(0, maxLength)}...`;
                button.innerText = expanded ? 'Collapse' : 'Expand';
            };
            button.addEventListener('click', () => {
                expanded = !expanded;
                render();
            });

            render();
            cell.appendChild(textSpan);
            cell.appendChild(document.createTextNode(' '));
            cell.appendChild(button);
        }

        function appendSourceCellContent(cell, source, sourceSql) {
            if (!sourceSql) {
                appendExpandableCellContent(cell, source);
                return;
            }

            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn btn-link graph-source-link';
            button.title = 'Show executable SQL for this source';
            button.innerText = source;
            button.addEventListener('click', () => showSourceSqlDialog(source, sourceSql));
            cell.appendChild(button);
        }

        function setGraphRelationalDetails(value, sourcesOrIsError = {}, isError = false, selectedNode = null, sourceSqls = {}) {
            if (typeof sourcesOrIsError === 'boolean') {
                isError = sourcesOrIsError;
                sourcesOrIsError = {};
            }

            const container = document.getElementById('graphRelationalDetails');
            if (!container) {
                return;
            }

            container.className = isError ? 'text-danger small' : '';
            container.innerHTML = '';
            if (typeof value === 'string') {
                container.innerText = value;
                return;
            }

            const rows = objectEntriesToRows(
                value,
                (key) => sourcesOrIsError[key] || 'kg_data',
                (key) => sourceSqls[key] || '');
            if (rows.length === 0) {
                container.className = 'text-muted small';
                container.innerText = 'No relational details found.';
                return;
            }

            appendEntityFocusAction(container, selectedNode);
            container.appendChild(createGraphAttributeTable(rows));
        }

        function appendEntityFocusAction(container, selectedNode) {
            const entityName = selectedNode?.properties?.name;
            if (!entityName || selectedNode.label === 'Document' || selectedNode.label === 'Chunk') {
                return;
            }

            const note = document.createElement('div');
            note.className = 'graph-selection-hint mb-2';
            note.innerText = 'The canvas only shows relationships returned by the active Cypher query. Focus this entity to show all MENTIONS edges returned for it.';

            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn btn-sm btn-outline-primary mb-2';
            button.innerText = 'Show linked chunks in graph';
            button.addEventListener('click', async () => {
                document.getElementById('queryInput').value = `MATCH (c:Chunk)-[r:MENTIONS]->(e)\nWHERE e.name = "${escapeCypherString(entityName)}"\nRETURN c, r, e\nLIMIT 200`;
                await runQuery();
            });

            container.appendChild(note);
            container.appendChild(button);
        }

        function escapeCypherString(value) {
            return String(value)
                .replace(/\\/g, '\\\\')
                .replace(/"/g, '\\"');
        }

        function objectEntriesToRows(value, sourceFactory = () => '', sourceSqlFactory = () => '') {
            return Object.entries(value || {}).map(([key, val]) => [formatAttributeLabel(key), val, sourceFactory(key), sourceSqlFactory(key)]);
        }

        function showSourceSqlDialog(source, sql) {
            const existing = document.getElementById('sourceSqlDialog');
            if (existing) {
                existing.remove();
            }

            const overlay = document.createElement('div');
            overlay.id = 'sourceSqlDialog';
            overlay.className = 'source-sql-overlay';

            const dialog = document.createElement('div');
            dialog.className = 'source-sql-dialog';
            dialog.setAttribute('role', 'dialog');
            dialog.setAttribute('aria-modal', 'true');
            dialog.setAttribute('aria-label', 'Executable source SQL');

            const header = document.createElement('div');
            header.className = 'source-sql-header';
            const title = document.createElement('div');
            title.className = 'source-sql-title';
            title.innerText = source;
            const closeButton = document.createElement('button');
            closeButton.type = 'button';
            closeButton.className = 'btn btn-sm btn-outline-secondary';
            closeButton.innerText = 'Close';
            closeButton.addEventListener('click', () => overlay.remove());
            header.appendChild(title);
            header.appendChild(closeButton);

            const pre = document.createElement('pre');
            pre.className = 'source-sql-code';
            pre.innerText = sql;

            dialog.appendChild(header);
            dialog.appendChild(pre);
            overlay.appendChild(dialog);
            overlay.addEventListener('click', (event) => {
                if (event.target === overlay) {
                    overlay.remove();
                }
            });
            document.body.appendChild(overlay);
            closeButton.focus();
        }

        function formatAttributeLabel(value) {
            return String(value)
                .replace(/_/g, ' ')
                .replace(/\b\w/g, (match) => match.toUpperCase());
        }

        function setMessage(id, text, cssClass) {
            const el = document.getElementById(id);
            el.className = cssClass;
            el.innerText = text;
        }
    </script>
}
