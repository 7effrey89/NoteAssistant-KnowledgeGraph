        async function checkBackendStatus() {
            setBackendStatus('warning', 'Checking backend...');
            try {
                const response = await fetch(`${backendBaseUrl}/api/health`);
                if (!response.ok) {
                    const payload = await response.json().catch(() => null);
                    const detail = payload?.detail || payload?.error;
                    setBackendStatus('warning', detail ? `Backend warning: ${detail}` : `Backend warning (status ${response.status}).`);
                    return;
                }

                const age = await fetch(`${backendBaseUrl}/api/health/age`);
                if (age.ok) {
                    setBackendStatus('online', 'Backend + PostgreSQL/AGE online');
                    return;
                }

                const agePayload = await age.json().catch(() => null);
                const ageDetail = agePayload?.detail || agePayload?.error || `status ${age.status}`;
                setBackendStatus('warning', `Backend online; PostgreSQL/AGE unavailable: ${ageDetail}`);
            } catch (err) {
                setBackendStatus('offline', `Backend offline: ${err.message}`);
            }
        }

        async function uploadFile(cacheMode) {
            const fileInput = document.getElementById(cacheMode ? 'cacheFile' : 'markdownFile');
            const activeUploadButton = cacheMode ? uploadCacheBtn : uploadBtn;
            const files = Array.from(fileInput.files || []);
            const resultsList = document.getElementById('uploadBatchResults');
            resultsList.innerHTML = '';

            if (files.length === 0) {
                setMessage('uploadMessage', `Please select at least one ${cacheMode ? 'cache analysis .json' : '.md'} file first.`, 'text-danger');
                return;
            }

            const expectedExtension = cacheMode ? '.json' : '.md';
            const invalidFiles = files.filter(file => !file.name.toLowerCase().endsWith(expectedExtension));
            if (invalidFiles.length > 0) {
                setMessage('uploadMessage', `Only ${expectedExtension} files are supported in this mode. Remove: ${invalidFiles.map(file => file.name).join(', ')}.`, 'text-danger');
                return;
            }

            activeUploadButton.disabled = true;
            resetUploadedDocumentsForNewBatch();
            const parallelism = getLlmParallelism();
            setMessage('uploadMessage', cacheMode
                ? `Uploading ${files.length} cache file${files.length === 1 ? '' : 's'} without LLM processing...`
                : `Uploading ${files.length} file${files.length === 1 ? '' : 's'} with parallelism ${parallelism}...`, 'text-muted');

            let succeeded = 0;
            let failed = 0;
            const jobs = files.map((file, index) => ({
                file,
                index,
                resultItem: appendUploadBatchResult(file.name, 'Queued...', 'text-muted')
            }));
            let nextJobIndex = 0;

            async function runUploadWorker() {
                while (nextJobIndex < jobs.length) {
                    const job = jobs[nextJobIndex++];
                    updateUploadBatchResult(job.resultItem, `${cacheMode ? 'Loading cache' : 'Uploading'} ${job.index + 1}/${files.length}...`, 'text-muted');
                    setMessage('uploadMessage', `${cacheMode ? 'Loading cache' : 'Uploading'} ${job.index + 1}/${files.length}: ${job.file.name}`, 'text-muted');

                    const result = await uploadSingleFile(job.file, cacheMode);
                    if (result.ok) {
                        succeeded++;
                        handleUploadSuccess(result.payload);
                        const statusMessage = result.payload.cached
                            ? `Document ${result.payload.documentId} loaded from cache (${result.payload.status.state}). Analysis step skipped by duplicate/content-hash handling.`
                            : `Document ${result.payload.documentId} uploaded (${result.payload.status.state}).`;
                        updateUploadBatchResult(job.resultItem, statusMessage, result.payload.cached ? 'text-warning' : 'text-success');
                    } else {
                        failed++;
                        updateUploadBatchResult(job.resultItem, result.error, 'text-danger');
                    }
                }
            }

            const workerCount = cacheMode ? Math.min(files.length, parallelism) : Math.min(files.length, parallelism);
            await Promise.all(Array.from({ length: workerCount }, () => runUploadWorker()));

            activeUploadButton.disabled = false;
            const summaryClass = failed > 0 ? (succeeded > 0 ? 'text-warning' : 'text-danger') : 'text-success';
            setMessage('uploadMessage', `Batch complete: ${succeeded} succeeded, ${failed} failed. See detailed file results above.`, summaryClass);
        }

        function getLlmParallelism() {
            const value = Number.parseInt(llmParallelismInput?.value || '2', 10);
            return Math.max(1, Math.min(Number.isFinite(value) ? value : 2, 8));
        }

        function getNumberInputValue(input, fallback, min, max) {
            const value = Number.parseFloat(input?.value || '');
            if (!Number.isFinite(value)) {
                return fallback;
            }
            return Math.max(min, Math.min(value, max));
        }

        function getIntegerInputValue(input, fallback, min, max) {
            const value = Number.parseInt(input?.value || '', 10);
            if (!Number.isFinite(value)) {
                return fallback;
            }
            return Math.max(min, Math.min(value, max));
        }

        function getCommunityBuildRequest() {
            return {
                parallelism: getLlmParallelism(),
                communityDetection: {
                    algorithm: 'LeidenCpm',
                    directed: Boolean(communityDirectedInput?.checked),
                    seed: getIntegerInputValue(communitySeedInput, 42, 0, Number.MAX_SAFE_INTEGER),
                    cpmResolution: getNumberInputValue(communityResolutionInput, 0.25, 0.001, 2),
                    typedRelationshipWeight: getNumberInputValue(communityTypedWeightInput, 2.0, 0.01, 20),
                    coMentionWeight: getNumberInputValue(communityCoMentionWeightInput, 1.0, 0.01, 20),
                    minCommunitySizeToSummarize: getIntegerInputValue(communityMinSizeInput, 2, 1, 1000),
                    maxCommunitiesToSummarize: getIntegerInputValue(communityMaxSummariesInput, 50, 1, 500)
                }
            };
        }

        function updateCommunityConfigOutput() {
            if (!communityConfigOutput) {
                return;
            }
            communityConfigOutput.value = JSON.stringify(getCommunityBuildRequest(), null, 2);
            resizeCommunityConfigOutput();
            updateCommunityTuningPrompts();
        }

        function resizeCommunityConfigOutput() {
            if (!communityConfigOutput) {
                return;
            }

            communityConfigOutput.style.height = 'auto';
            communityConfigOutput.style.height = `${communityConfigOutput.scrollHeight}px`;
        }

        function applyCommunityBuildRequestToInputs(request) {
            if (!request || !request.communityDetection) {
                return;
            }

            const detection = request.communityDetection;
            if (llmParallelismInput) llmParallelismInput.value = String(request.parallelism ?? 1);
            if (communityResolutionInput) communityResolutionInput.value = String(detection.cpmResolution ?? 0.25);
            if (communityTypedWeightInput) communityTypedWeightInput.value = String(detection.typedRelationshipWeight ?? 2.0);
            if (communityCoMentionWeightInput) communityCoMentionWeightInput.value = String(detection.coMentionWeight ?? 1.0);
            if (communitySeedInput) communitySeedInput.value = String(detection.seed ?? 42);
            if (communityMinSizeInput) communityMinSizeInput.value = String(detection.minCommunitySizeToSummarize ?? 2);
            if (communityMaxSummariesInput) communityMaxSummariesInput.value = String(detection.maxCommunitiesToSummarize ?? 50);
            if (communityDirectedInput) communityDirectedInput.checked = Boolean(detection.directed);
            updateCommunityConfigOutput();
        }

        function getDefaultCommunityBuildRequest() {
            return {
                parallelism: 1,
                communityDetection: {
                    algorithm: 'LeidenCpm',
                    directed: false,
                    seed: 42,
                    cpmResolution: 0.25,
                    typedRelationshipWeight: 2.0,
                    coMentionWeight: 1.0,
                    minCommunitySizeToSummarize: 2,
                    maxCommunitiesToSummarize: 50
                }
            };
        }

        function normalizePercentValue(value) {
            if (value === null || value === undefined || value === '') {
                return null;
            }

            const numeric = Number(value);
            if (!Number.isFinite(numeric)) {
                return null;
            }

            return Math.max(0, Math.min(100, numeric));
        }

        function describeCommunityProfile(profile) {
            const createdAt = profile?.createdAt ? new Date(profile.createdAt).toLocaleString() : 'n/a';
            const score = normalizePercentValue(profile?.scorePercent);
            const confidence = normalizePercentValue(profile?.confidencePercent);
            const scoreText = score === null ? 'score: n/a' : `score: ${score.toFixed(1)}%`;
            const confidenceText = confidence === null ? 'confidence: n/a' : `confidence: ${confidence.toFixed(1)}%`;
            const source = profile?.source || 'manual';
            return `${createdAt} | ${scoreText} | ${confidenceText} | source: ${source}`;
        }

        function getCommunityProfileDisplayParts(profile) {
            const score = normalizePercentValue(profile?.scorePercent);
            const confidence = normalizePercentValue(profile?.confidencePercent);
            const scoreLabel = score === null ? 'score n/a' : `score ${score.toFixed(1)}%`;
            const confidenceLabel = confidence === null ? 'conf n/a' : `conf ${confidence.toFixed(1)}%`;
            const createdAt = profile?.createdAt ? new Date(profile.createdAt).toLocaleString() : 'n/a';
            const detection = profile?.config?.communityDetection || {};
            const parallelism = Number.isFinite(Number(profile?.config?.parallelism)) ? Number(profile.config.parallelism) : 'n/a';
            const cpm = Number.isFinite(Number(detection.cpmResolution)) ? Number(detection.cpmResolution).toFixed(2) : 'n/a';
            const minSize = Number.isFinite(Number(detection.minCommunitySizeToSummarize)) ? Number(detection.minCommunitySizeToSummarize) : 'n/a';
            const maxSummaries = Number.isFinite(Number(detection.maxCommunitiesToSummarize)) ? Number(detection.maxCommunitiesToSummarize) : 'n/a';
            return {
                createdAt,
                details: `${scoreLabel} | ${confidenceLabel} | p ${parallelism} | cpm ${cpm} | min ${minSize} | max ${maxSummaries}`
            };
        }

        async function loadCommunityProfiles(selectActive) {
            if (!communityProfileList) {
                return;
            }

            try {
                const response = await fetch(`${backendBaseUrl}/api/communities/profiles`);
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    throw new Error((payload && (payload.error || payload.detail)) || `Failed to load profiles (status ${response.status}).`);
                }

                const profiles = Array.isArray(payload?.profiles) ? payload.profiles : [];
                communityProfilesState.profiles = profiles;
                communityProfilesState.activeProfileId = payload?.activeProfileId || null;
                communityProfilesState.defaults = payload?.defaultConfig || getDefaultCommunityBuildRequest();

                renderCommunityProfileOptions(selectActive);
            } catch (err) {
                communityProfileList.innerHTML = '';
                communityProfilesState.profiles = [];
                communityProfilesState.activeProfileId = null;
                communityProfilesState.selectedProfileId = '__defaults';
                communityProfilesState.defaults = getDefaultCommunityBuildRequest();
                communityProfileMeta.innerText = `Unable to load profiles: ${err.message}. Using defaults.`;
                applyCommunityBuildRequestToInputs(communityProfilesState.defaults);
            }
        }

        function renderCommunityProfileOptions(selectActive) {
            const previousSelected = communityProfilesState.selectedProfileId;
            if (selectActive && communityProfilesState.activeProfileId) {
                communityProfilesState.selectedProfileId = communityProfilesState.activeProfileId;
            } else if (previousSelected && (previousSelected === '__defaults' || communityProfilesState.profiles.some(profile => profile.id === previousSelected))) {
                communityProfilesState.selectedProfileId = previousSelected;
            } else {
                communityProfilesState.selectedProfileId = '__defaults';
            }

            renderCommunityProfileList();

            updateCommunityProfileMeta();

            const selectedProfile = getSelectedCommunityProfile();
            if (selectedProfile) {
                applyCommunityBuildRequestToInputs(selectedProfile.config);
            } else if (selectActive) {
                applyCommunityBuildRequestToInputs(communityProfilesState.defaults || getDefaultCommunityBuildRequest());
            }
        }

        function getSelectedCommunityProfile() {
            const selectedId = communityProfilesState.selectedProfileId;
            if (!selectedId || selectedId === '__defaults') {
                return null;
            }

            return communityProfilesState.profiles.find(profile => profile.id === selectedId) || null;
        }

        function updateCommunityProfileMeta() {
            const selectedProfile = getSelectedCommunityProfile();
            if (!selectedProfile) {
                communityProfileMeta.innerText = 'No persisted profile selected. Current build uses defaults or your unsaved edits.';
                return;
            }

            const isActive = selectedProfile.id === communityProfilesState.activeProfileId;
            const activeText = isActive ? 'ACTIVE' : 'not active';
            const improvement = selectedProfile.improvement ? ` | ${truncateText(selectedProfile.improvement, 180)}` : '';
            communityProfileMeta.innerText = `${activeText}: ${describeCommunityProfile(selectedProfile)}${improvement}`;
        }

        function onCommunityProfileSelectionChanged(profileId) {
            communityProfilesState.selectedProfileId = profileId || '__defaults';
            renderCommunityProfileList();
            updateCommunityProfileMeta();

            const selectedProfile = getSelectedCommunityProfile();
            if (selectedProfile?.config) {
                applyCommunityBuildRequestToInputs(selectedProfile.config);
                return;
            }

            if (communityProfilesState.defaults) {
                applyCommunityBuildRequestToInputs(communityProfilesState.defaults);
            }
        }

        function getCommunityProfileTuneButton(profileId) {
            if (!communityProfileList) {
                return null;
            }

            const targetProfileId = profileId || '__defaults';
            const rows = communityProfileList.querySelectorAll('.community-profile-row');
            for (const row of rows) {
                if ((row.getAttribute('data-profile-id') || '') === targetProfileId) {
                    return row.querySelector('[data-role="tune"]');
                }
            }

            return null;
        }

        function renderCommunityProfileList() {
            if (!communityProfileList) {
                return;
            }

            const selectedId = communityProfilesState.selectedProfileId || '__defaults';
            const activeId = communityProfilesState.activeProfileId;
            communityProfileList.innerHTML = '';

            const defaultsRow = document.createElement('div');
            defaultsRow.className = `community-profile-row${selectedId === '__defaults' ? ' selected' : ''}`;
            defaultsRow.setAttribute('role', 'option');
            defaultsRow.setAttribute('aria-selected', selectedId === '__defaults' ? 'true' : 'false');
            defaultsRow.setAttribute('data-profile-id', '__defaults');
            defaultsRow.innerHTML = `
                <div class="community-profile-row-main">
                    <div class="community-profile-row-title">Defaults (unsaved)</div>
                </div>
                <div class="community-profile-row-actions">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-role="tune" title="Use this profile as baseline for a new optimized profile.">Tune</button>
                    <button type="button" class="btn btn-sm btn-outline-primary">Use</button>
                </div>`;
            defaultsRow.addEventListener('click', () => onCommunityProfileSelectionChanged('__defaults'));
            defaultsRow.querySelector('[data-role="tune"]')?.addEventListener('click', async (event) => {
                event.stopPropagation();
                onCommunityProfileSelectionChanged('__defaults');
                applyCommunityBuildRequestToInputs(communityProfilesState.defaults || getDefaultCommunityBuildRequest());
                const visibleTuneButton = getCommunityProfileTuneButton('__defaults');
                await tuneCommunityProfile('manual', visibleTuneButton || event.currentTarget);
            });
            defaultsRow.querySelector('.btn-outline-primary')?.addEventListener('click', (event) => {
                event.stopPropagation();
                onCommunityProfileSelectionChanged('__defaults');
                applyCommunityBuildRequestToInputs(communityProfilesState.defaults || getDefaultCommunityBuildRequest());
                hideCommunityPostBuildActions();
            });
            communityProfileList.appendChild(defaultsRow);

            communityProfilesState.profiles.forEach((profile) => {
                const isSelected = selectedId === profile.id;
                const isActive = activeId === profile.id;
                const row = document.createElement('div');
                row.className = `community-profile-row${isSelected ? ' selected' : ''}${isActive ? ' active' : ''}`;
                row.setAttribute('role', 'option');
                row.setAttribute('aria-selected', isSelected ? 'true' : 'false');
                row.setAttribute('data-profile-id', profile.id);

                const displayParts = getCommunityProfileDisplayParts(profile);
                row.innerHTML = `
                    <div class="community-profile-row-main">
                        <div class="community-profile-row-title">${escapeHtml(displayParts.createdAt)}${isActive ? ' (active)' : ''}</div>
                        <div class="community-profile-row-meta">${escapeHtml(displayParts.details)}</div>
                    </div>
                    <div class="community-profile-row-actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-role="tune" title="Use this profile as baseline for a new optimized profile.">Tune</button>
                        <button type="button" class="btn btn-sm btn-outline-primary" data-role="use">Use</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" data-role="delete">Delete</button>
                    </div>`;

                row.addEventListener('click', () => onCommunityProfileSelectionChanged(profile.id));
                row.querySelector('[data-role="tune"]')?.addEventListener('click', async (event) => {
                    event.stopPropagation();
                    onCommunityProfileSelectionChanged(profile.id);
                    applyCommunityBuildRequestToInputs(profile.config);
                    const visibleTuneButton = getCommunityProfileTuneButton(profile.id);
                    await tuneCommunityProfile('manual', visibleTuneButton || event.currentTarget);
                });
                row.querySelector('[data-role="use"]')?.addEventListener('click', async (event) => {
                    event.stopPropagation();
                    onCommunityProfileSelectionChanged(profile.id);
                    await applySelectedCommunityProfile();
                });
                row.querySelector('[data-role="delete"]')?.addEventListener('click', async (event) => {
                    event.stopPropagation();
                    await deleteCommunityProfile(profile.id);
                });

                communityProfileList.appendChild(row);
            });
        }

        async function applySelectedCommunityProfile() {
            const selectedProfile = getSelectedCommunityProfile();
            if (!selectedProfile) {
                applyCommunityBuildRequestToInputs(communityProfilesState.defaults || getDefaultCommunityBuildRequest());
                hideCommunityPostBuildActions();
                return;
            }

            try {
                const response = await fetch(`${backendBaseUrl}/api/communities/profiles/active`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ profileId: selectedProfile.id })
                });
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    throw new Error((payload && (payload.error || payload.detail)) || `Unable to activate profile (status ${response.status}).`);
                }

                communityProfilesState.previousProfileId = communityProfilesState.activeProfileId;
                communityProfilesState.activeProfileId = payload?.activeProfileId || selectedProfile.id;
                applyCommunityBuildRequestToInputs(selectedProfile.config);
                setInlineStatus(document.getElementById('communityStatus'), 'Selected community profile loaded.', 'text-success');
                updateCommunityProfileMeta();
                renderCommunityProfileList();
            } catch (err) {
                document.getElementById('communityError').innerText = err.message;
            }
        }

        async function deleteCommunityProfile(profileId) {
            if (!profileId) {
                return;
            }

            if (!window.confirm('Delete this persisted profile?')) {
                return;
            }

            document.getElementById('communityError').innerText = '';
            try {
                const response = await fetch(`${backendBaseUrl}/api/communities/profiles/${encodeURIComponent(profileId)}`, {
                    method: 'DELETE'
                });
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    throw new Error((payload && (payload.error || payload.detail)) || `Unable to delete profile (status ${response.status}).`);
                }

                communityProfilesState.profiles = Array.isArray(payload?.profiles) ? payload.profiles : [];
                communityProfilesState.activeProfileId = payload?.activeProfileId || null;
                if (communityProfilesState.selectedProfileId === profileId) {
                    communityProfilesState.selectedProfileId = communityProfilesState.activeProfileId || '__defaults';
                }

                renderCommunityProfileOptions(false);
                setInlineStatus(document.getElementById('communityStatus'), 'Profile deleted.', 'text-success');
            } catch (err) {
                document.getElementById('communityError').innerText = err.message;
            }
        }

        function showCommunityPostBuildActions(message) {
            if (!communityPostBuildActions) {
                return;
            }

            communityPostBuildActions.classList.remove('d-none');
            if (communityPostBuildMessage) {
                communityPostBuildMessage.innerText = message || 'Build the community with the current profile, continue tuning, or cancel.';
            }
        }

        function setCommunityFurtherTuningAvailability(disabled, reason) {
            communityFurtherTuningDisabledReason = disabled ? (reason || 'Further tuning is not available right now.') : '';

            if (communityPostTuneBtn) {
                communityPostTuneBtn.disabled = disabled;
                if (disabled) {
                    communityPostTuneBtn.setAttribute('title', communityFurtherTuningDisabledReason);
                    communityPostTuneBtn.setAttribute('aria-disabled', 'true');
                } else {
                    communityPostTuneBtn.setAttribute('title', 'Run another tuning pass for this profile.');
                    communityPostTuneBtn.removeAttribute('aria-disabled');
                }
            }

            if (communityPostTuneBtnWrapper) {
                communityPostTuneBtnWrapper.setAttribute('title', disabled ? communityFurtherTuningDisabledReason : '');
            }
        }

        function cancelCommunityPostBuildActions() {
            hideCommunityPostBuildActions();
            setInlineStatus(document.getElementById('communityStatus'), 'Community build canceled. Current profile remains selected.', 'text-muted');
        }

        async function onCommunityContinueClicked() {
            const communityError = document.getElementById('communityError');
            if (communityError) {
                communityError.className = 'text-danger mb-2';
                communityError.innerText = '';
            }

            setButtonLoading(communityContinueBtn, true, 'Continuing...');
            try {
                const selectedProfile = getSelectedCommunityProfile();
                if (selectedProfile) {
                    await applySelectedCommunityProfile();
                } else {
                    applyCommunityBuildRequestToInputs(communityProfilesState.defaults || getDefaultCommunityBuildRequest());
                }

                if (communityError && communityError.innerText) {
                    return;
                }

                await runCommunityBuildExecution();
            } finally {
                setButtonLoading(communityContinueBtn, false);
            }
        }

        function hideCommunityPostBuildActions() {
            if (!communityPostBuildActions) {
                return;
            }

            communityPostBuildActions.classList.add('d-none');
            if (communityQuickAssessment) {
                communityQuickAssessment.innerHTML = '';
            }
            setCommunityFinalProfileOutput(null);
        }

        function setCommunityFinalProfileOutput(config) {
            if (!communityFinalProfileDetails || !communityFinalProfileJson) {
                return;
            }

            if (!config || typeof config !== 'object') {
                communityFinalProfileJson.textContent = '';
                communityFinalProfileDetails.classList.add('d-none');
                communityFinalProfileDetails.open = false;
                return;
            }

            communityFinalProfileJson.textContent = JSON.stringify(config, null, 2);
            communityFinalProfileDetails.classList.remove('d-none');
        }

        function parseCommunityClusteringMetrics(detail) {
            const text = String(detail || '');
            const readInt = (pattern) => {
                const match = text.match(pattern);
                return match ? Number.parseInt(match[1], 10) : null;
            };

            return {
                totalCommunities: readInt(/Total communities:\s*(\d+)/i),
                singletonCommunities: readInt(/Singleton communities:\s*(\d+)/i),
                multiEntityCommunities: readInt(/Multi-entity communities:\s*(\d+)/i)
            };
        }

        function assessCommunityTuningPotential(configOverride) {
            const state = ensureCommunitySummaryTabsState();
            const config = configOverride || getCommunityBuildRequest();
            const metrics = parseCommunityClusteringMetrics(state.clusteringDetail);
            const completedSummaryCount = state.completedBlocks.filter(Boolean).length;
            const hasRunMetrics = Boolean(metrics.totalCommunities || metrics.multiEntityCommunities || metrics.singletonCommunities || state.clusteringDetail);

            if (!hasRunMetrics) {
                const reasons = [];
                if (config.communityDetection.cpmResolution < 0.08 || config.communityDetection.cpmResolution > 0.8) {
                    reasons.push('resolution is in an extreme range');
                }
                if (config.communityDetection.minCommunitySizeToSummarize >= 4) {
                    reasons.push('minimum summary size may filter aggressively');
                }
                if (config.communityDetection.maxCommunitiesToSummarize < 25) {
                    reasons.push('summary cap is relatively low');
                }

                return {
                    potential: null,
                    confidence: reasons.length ? 35 : 25,
                    band: 'Unknown',
                    total: null,
                    singleton: null,
                    multiEntity: null,
                    summaryCount: 0,
                    reasons,
                    recommendation: reasons.length
                        ? 'only config-level risks are visible before detection; proceed with build to measure real community quality, or tune conservatively first'
                        : 'no detected communities/entities are available yet; proceed with build to collect real metrics before judging tuning upside',
                    source: 'config-only'
                };
            }

            const multiEntity = metrics.multiEntityCommunities ?? completedSummaryCount;
            const singleton = metrics.singletonCommunities ?? 0;
            const total = metrics.totalCommunities ?? (multiEntity + singleton);
            const singletonRatio = total > 0 ? singleton / total : 0;
            const candidateSummaryCount = completedSummaryCount > 0
                ? completedSummaryCount
                : Math.min(multiEntity, config.communityDetection.maxCommunitiesToSummarize);
            const summarizedCoverage = multiEntity > 0 ? candidateSummaryCount / multiEntity : 0;

            let potential = 5;
            const reasons = [];

            if (singletonRatio >= 0.35) {
                potential += 22;
                reasons.push(`high singleton ratio (${(singletonRatio * 100).toFixed(1)}%) suggests fragmentation`);
            } else if (singletonRatio >= 0.22) {
                potential += 10;
                reasons.push(`moderate singleton ratio (${(singletonRatio * 100).toFixed(1)}%)`);
            }

            if (multiEntity > config.communityDetection.maxCommunitiesToSummarize) {
                potential += 20;
                reasons.push(`summary cap hit (${config.communityDetection.maxCommunitiesToSummarize}/${multiEntity})`);
            }

            if (summarizedCoverage > 0 && summarizedCoverage < 0.7) {
                potential += 10;
                reasons.push(`low summarized coverage (${(summarizedCoverage * 100).toFixed(1)}%)`);
            }

            if (config.communityDetection.cpmResolution < 0.08 || config.communityDetection.cpmResolution > 0.8) {
                potential += 8;
                reasons.push('resolution is in an extreme range');
            }

            if (config.communityDetection.minCommunitySizeToSummarize >= 4) {
                potential += 6;
                reasons.push('minimum summary size may filter too aggressively');
            }

            potential = Math.max(0, Math.min(95, Math.round(potential)));

            const confidence = Math.max(45, Math.min(90,
                45
                + (metrics.totalCommunities ? 15 : 0)
                + (metrics.multiEntityCommunities ? 10 : 0)
                + (completedSummaryCount > 0 ? 10 : 0)
            ));

            let band = 'Low';
            if (potential >= 60) {
                band = 'High';
            } else if (potential >= 30) {
                band = 'Medium';
            }

            const recommendation = [];
            if (singletonRatio >= 0.3) {
                recommendation.push('try slightly lower CPM resolution or slightly higher co-mention weight');
            }
            if (multiEntity > config.communityDetection.maxCommunitiesToSummarize) {
                recommendation.push('raise max summaries or tighten resolution to focus high-value communities');
            }
            if (recommendation.length === 0) {
                recommendation.push('current profile looks stable; tune only if retrieval quality is weak');
            }

            return {
                potential,
                confidence,
                band,
                total,
                singleton,
                multiEntity,
                summaryCount: candidateSummaryCount,
                reasons,
                recommendation: recommendation.join('; '),
                source: 'run-metrics'
            };
        }

        function formatAssessmentPotential(assessment) {
            return assessment.potential === null || assessment.potential === undefined
                ? `${assessment.band} (needs detected community metrics)`
                : `${assessment.band} (${assessment.potential}%)`;
        }

        function buildCommunityReviewRubricPrompt() {
            return [
                'This review is generated by a deterministic rule-based rubric (no LLM call).',
                '',
                'Scoring logic summary:',
                '- Start potential at 5%.',
                '- Add +22 when singleton ratio >= 35%, or +10 when >= 22%.',
                '- Add +20 when multi-entity communities exceed max summaries.',
                '- Add +10 when summarized coverage is between 0% and 70%.',
                '- Add +8 when CPM resolution is in extreme range (<0.08 or >0.8).',
                '- Add +6 when minimum summary size >= 4.',
                '- Clamp potential to 0-95%.',
                '- Confidence is derived from detected run metrics and completed summaries (45-90%).',
                '',
                'Output fields:',
                '- Improvement potential band and percentage',
                '- Confidence',
                '- Candidate coverage',
                '- Recommendation text'
            ].join('\n');
        }

        function buildCommunityReviewInputPayload(assessment) {
            const state = ensureCommunitySummaryTabsState();
            const metrics = parseCommunityClusteringMetrics(state.clusteringDetail);
            const completedSummaryCount = state.completedBlocks.filter(Boolean).length;

            return [
                'Source: local deterministic assessment (no LLM system prompt/user prompt sent).',
                '',
                'Current config:',
                JSON.stringify(getCommunityBuildRequest(), null, 2),
                '',
                'Detected clustering output:',
                truncateText(state.clusteringDetail || '(not available)', 12000),
                '',
                'Derived metrics:',
                JSON.stringify({
                    totalCommunities: metrics.totalCommunities,
                    singletonCommunities: metrics.singletonCommunities,
                    multiEntityCommunities: metrics.multiEntityCommunities,
                    completedSummaryCount,
                    assessmentPotential: assessment?.potential ?? null,
                    assessmentBand: assessment?.band ?? null,
                    assessmentConfidence: assessment?.confidence ?? null
                }, null, 2)
            ].join('\n');
        }

        function renderCommunityQuickAssessment(assessment) {
            if (!communityQuickAssessment) {
                return;
            }

            const reasonText = assessment.reasons.length
                ? `Signals: ${assessment.reasons.join(' | ')}`
                : 'Signals: no major risk indicators detected from this run.';
            communityQuickAssessment.innerHTML = `
                <div><strong>Quick assessment before tuning:</strong> ${formatAssessmentPotential(assessment)} | confidence ${assessment.confidence}%.</div>
                <div>Coverage: summarized ${assessment.summaryCount} multi-entity communities out of ${assessment.multiEntity} (${assessment.total} total communities, ${assessment.singleton} singleton).</div>
                <div>${escapeHtml(reasonText)}</div>
                <div><strong>Recommendation:</strong> ${escapeHtml(assessment.recommendation)}</div>`;
        }

        function renderCommunityPreBuildAssessment(assessment) {
            if (!communityPreBuildAssessment) {
                return;
            }

            const scopeText = assessment.source === 'run-metrics'
                ? 'Based on the detected communities from this Leiden run.'
                : 'Config-only preflight: no detected communities/entities exist yet for this build.';
            const coverageText = assessment.source === 'run-metrics'
                ? `<div>Candidate coverage: ${assessment.summaryCount} of ${assessment.multiEntity} multi-entity communities would be summarized (${assessment.total} total, ${assessment.singleton} singleton).</div>`
                : '<div>Community/entity counts are not known until the backend detection step runs.</div>';
            communityPreBuildAssessment.innerHTML = `
                <div><strong>Estimated improvement potential:</strong> ${formatAssessmentPotential(assessment)} | confidence ${assessment.confidence}%.</div>
                <div>${escapeHtml(scopeText)}</div>
                ${coverageText}
                <div><strong>Recommendation:</strong> ${escapeHtml(assessment.recommendation)}</div>
                <div class="text-muted">No reset or LLM summary call has started yet. Proceed to continue with \"Existing community index cleared\".</div>`;
        }

        function showCommunityPreBuildGate(assessment) {
            if (!communityPreBuildGate) {
                return;
            }

            communityPreBuildGate.classList.remove('d-none');
            if (communityPreBuildMessage) {
                communityPreBuildMessage.innerText = 'Build is paused before execution. Choose proceed or tune first.';
            }
            renderCommunityPreBuildAssessment(assessment);
        }

        function formatCommunityConfigValue(value) {
            if (typeof value === 'number' && Number.isFinite(value)) {
                return Number.isInteger(value) ? String(value) : value.toFixed(3).replace(/\.0+$/, '').replace(/(\.\d*?)0+$/, '$1');
            }
            if (typeof value === 'boolean') {
                return value ? 'true' : 'false';
            }
            return String(value ?? 'n/a');
        }

        function summarizeCommunityConfigChanges(beforeConfig, afterConfig) {
            const changes = [];
            const beforeDetection = beforeConfig?.communityDetection || {};
            const afterDetection = afterConfig?.communityDetection || {};

            const addChange = (label, beforeValue, afterValue) => {
                if (beforeValue === afterValue) {
                    return;
                }
                changes.push(`${label}: ${formatCommunityConfigValue(beforeValue)} -> ${formatCommunityConfigValue(afterValue)}`);
            };

            addChange('LLM parallelism', beforeConfig?.parallelism, afterConfig?.parallelism);
            addChange('CPM resolution', beforeDetection.cpmResolution, afterDetection.cpmResolution);
            addChange('Typed relationship weight', beforeDetection.typedRelationshipWeight, afterDetection.typedRelationshipWeight);
            addChange('Co-mention weight', beforeDetection.coMentionWeight, afterDetection.coMentionWeight);
            addChange('Min summary size', beforeDetection.minCommunitySizeToSummarize, afterDetection.minCommunitySizeToSummarize);
            addChange('Max summaries', beforeDetection.maxCommunitiesToSummarize, afterDetection.maxCommunitiesToSummarize);
            addChange('Directed graph', beforeDetection.directed, afterDetection.directed);
            addChange('Seed', beforeDetection.seed, afterDetection.seed);

            return changes;
        }

        function estimateCommunityTuningGain(beforeAssessment, scorePercent) {
            const score = normalizePercentValue(scorePercent);
            if (score === null || beforeAssessment?.potential === null || beforeAssessment?.potential === undefined) {
                return null;
            }

            const baselineQuality = Math.max(0, Math.min(100, 100 - beforeAssessment.potential));
            const delta = Number((score - baselineQuality).toFixed(1));
            return {
                baselineQuality,
                projectedQuality: score,
                delta
            };
        }

        function appendCommunityTuningAgentReview(reason, payload, previousConfig, nextConfig, beforeAssessment) {
            const configChanges = summarizeCommunityConfigChanges(previousConfig, nextConfig);
            const expectedGain = estimateCommunityTuningGain(beforeAssessment, payload?.scorePercent);
            const score = normalizePercentValue(payload?.scorePercent);
            const confidence = normalizePercentValue(payload?.confidencePercent);
            const scoreBreakdown = payload?.scoreBreakdown || null;
            const scoreText = score === null ? 'n/a' : `${score.toFixed(1)}%`;
            const confidenceText = confidence === null ? 'n/a' : `${confidence.toFixed(1)}%`;
            const expectedGainText = expectedGain
                ? `Projected quality after applying profile: ${expectedGain.projectedQuality.toFixed(1)}% (baseline ${expectedGain.baselineQuality.toFixed(1)}%, expected gain ${expectedGain.delta >= 0 ? '+' : ''}${expectedGain.delta.toFixed(1)}%).`
                : 'Projected gain unavailable: score and run metrics are required.';

            const scoreComponentText = Array.isArray(scoreBreakdown?.scoreComponents) && scoreBreakdown.scoreComponents.length
                ? scoreBreakdown.scoreComponents
                    .map(component => `${component.name}: ${component.value} (${component.detail || ''})`)
                    .join('\n')
                : '(no score components returned)';
            const confidenceComponentText = Array.isArray(scoreBreakdown?.confidenceComponents) && scoreBreakdown.confidenceComponents.length
                ? scoreBreakdown.confidenceComponents
                    .map(component => `${component.name}: ${component.value} (${component.detail || ''})`)
                    .join('\n')
                : '(no confidence components returned)';
            const scoringMethodLine = scoreBreakdown?.method
                ? `Scoring method: ${scoreBreakdown.method} (deterministic backend)`
                : 'Scoring method: not provided';

            const reviewLines = [
                `Trigger: ${reason || 'manual'}`,
                `Agent score: ${scoreText} | confidence: ${confidenceText}`,
                scoringMethodLine,
                `Estimated improvement potential before tuning: ${formatAssessmentPotential(beforeAssessment)} | confidence ${beforeAssessment?.confidence ?? 'n/a'}%`,
                expectedGainText,
                `Recommendation: ${payload?.improvement || 'No recommendation text returned.'}`,
                configChanges.length
                    ? `Suggested config changes: ${configChanges.join(' | ')}`
                    : 'Suggested config changes: none (agent kept current profile).'
            ];

            appendCommunityProcessMap([
                {
                    title: 'Community Tuning Agent review',
                    variant: 'agent',
                    role: 'GraphRag Community Tuning Agent',
                    purpose: 'Evaluate Leiden run quality and recommend a reversible profile optimization.',
                    body: reviewLines.join('\n'),
                    systemPrompt: communityTuningSystemPrompt?.value || '(system prompt unavailable)',
                    systemPromptTitle: 'Community Tuning Agent system prompt',
                    inputPayload: communityTuningUserPrompt?.value || '(agent input unavailable)',
                    inputPayloadTitle: 'Community Tuning Agent input (config + detected entities/relationships + summary samples)',
                    configPayload: JSON.stringify(nextConfig || payload?.config || {}, null, 2),
                    configPayloadTitle: 'Suggested community profile JSON',
                    outputPayload: [
                        `scorePercent: ${scoreText}`,
                        `confidencePercent: ${confidenceText}`,
                        scoringMethodLine,
                        '',
                        'Score components:',
                        scoreComponentText,
                        '',
                        'Confidence components:',
                        confidenceComponentText
                    ].join('\n'),
                    outputPayloadTitle: 'Deterministic score breakdown',
                    tokenUsage: payload?.tokenUsage || null
                }
            ]);
        }

        function hideCommunityPreBuildGate() {
            if (!communityPreBuildGate) {
                return;
            }

            communityPreBuildGate.classList.add('d-none');
            if (communityPreBuildAssessment) {
                communityPreBuildAssessment.innerHTML = '';
            }
        }

        function cancelCommunityBuildGate() {
            communityBuildGatePending = false;
            hideCommunityPreBuildGate();
            setInlineStatus(document.getElementById('communityStatus'), 'Community build paused. Click Build Communities when ready.', 'text-muted');
        }

        async function proceedCommunityBuild(triggerButton = null) {
            communityBuildGatePending = false;
            if (triggerButton) {
                setButtonLoading(triggerButton, true, 'Proceeding...');
            }

            try {
                return await runCommunityBuildExecution();
            } finally {
                if (triggerButton) {
                    setButtonLoading(triggerButton, false);
                }
            }
        }

        async function tuneCommunityProfile(reason, triggerButton = null) {
            const communityStatus = document.getElementById('communityStatus');
            document.getElementById('communityError').innerText = '';
            updateCommunityTuningPrompts();
            const previousConfig = getCommunityBuildRequest();
            const existingProfileIds = new Set((communityProfilesState.profiles || []).map(profile => profile.id));
            const beforeAssessment = assessCommunityTuningPotential(previousConfig);
            setInlineStatus(communityStatus, 'Running GraphRag Community Tuning Agent...', 'text-muted');

            const tuningButtons = new Set();
            if (triggerButton) {
                tuningButtons.add(triggerButton);
            }
            if (reason === 'post-build' && communityPostTuneBtn) {
                tuningButtons.add(communityPostTuneBtn);
            }
            if (reason === 'pre-build' && communityTuneBeforeBuildBtn) {
                tuningButtons.add(communityTuneBeforeBuildBtn);
            }
            tuningButtons.forEach((button) => setButtonLoading(button, true, 'Tuning...'));

            try {
                communityProfilesState.previousConfigSnapshot = getCommunityBuildRequest();
                communityProfilesState.previousProfileId = communityProfilesState.activeProfileId;

                const response = await fetch(`${backendBaseUrl}/api/communities/tune-profile`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        systemPrompt: communityTuningSystemPrompt?.value || '',
                        userPrompt: communityTuningUserPrompt?.value || '',
                        currentConfig: getCommunityBuildRequest(),
                        persistProfile: true,
                        assessmentContext: {
                            totalCommunities: beforeAssessment?.total ?? null,
                            singletonCommunities: beforeAssessment?.singleton ?? null,
                            multiEntityCommunities: beforeAssessment?.multiEntity ?? null,
                            candidateSummaryCount: beforeAssessment?.summaryCount ?? null,
                            source: beforeAssessment?.source || null
                        }
                    })
                });
                const payload = await response.json().catch(() => null);
                if (!response.ok || !payload?.success) {
                    throw new Error((payload && (payload.error || payload.detail)) || 'Tuning request failed.');
                }

                if (payload.config) {
                    applyCommunityBuildRequestToInputs(payload.config);
                }

                const appliedConfig = payload.config || getCommunityBuildRequest();
                setCommunityFinalProfileOutput(appliedConfig);
                const configChanges = summarizeCommunityConfigChanges(previousConfig, appliedConfig);

                await loadCommunityProfiles(true);
                if (payload?.savedProfile?.id) {
                    communityProfilesState.selectedProfileId = payload.savedProfile.id;
                    renderCommunityProfileList();
                    updateCommunityProfileMeta();
                }

                appendCommunityTuningAgentReview(reason, payload, previousConfig, appliedConfig, beforeAssessment);

                const score = normalizePercentValue(payload.scorePercent);
                const confidence = normalizePercentValue(payload.confidencePercent);
                const scoreText = score === null ? 'n/a' : `${score.toFixed(1)}%`;
                const confidenceText = confidence === null ? 'n/a' : `${confidence.toFixed(1)}%`;
                const improvement = payload.improvement ? ` ${payload.improvement}` : '';
                const reusedExistingProfile = !!(payload?.savedProfile?.id && existingProfileIds.has(payload.savedProfile.id));
                const reuseNote = reusedExistingProfile ? ' Reused existing matching profile (no new profile created).' : '';
                setInlineStatus(communityStatus, `Tuning complete (score ${scoreText}, confidence ${confidenceText}).${reuseNote}`, 'text-success');
                if (configChanges.length === 0) {
                    setCommunityFurtherTuningAvailability(
                        true,
                        'Further tuning disabled: no additional optimization was suggested because the agent kept the current profile (Suggested config changes: none).'
                    );
                } else {
                    setCommunityFurtherTuningAvailability(false);
                }
                showCommunityPostBuildActions(`Tuning complete (${reason || 'manual'}). Review the Community Tuning Agent step, then build the community, continue with further tuning, or cancel.${improvement}`);
            } catch (err) {
                document.getElementById('communityError').innerText = err.message;
                setInlineStatus(communityStatus, 'Community profile tuning failed.', 'text-danger');
            } finally {
                tuningButtons.forEach((button) => setButtonLoading(button, false));
            }
        }

        async function revertToPreviousCommunityProfile() {
            if (communityProfilesState.previousProfileId) {
                communityProfilesState.selectedProfileId = communityProfilesState.previousProfileId;
                renderCommunityProfileList();
                await applySelectedCommunityProfile();
                showCommunityPostBuildActions('Previous persisted profile restored.');
                return;
            }

            if (communityProfilesState.previousConfigSnapshot) {
                applyCommunityBuildRequestToInputs(communityProfilesState.previousConfigSnapshot);
                showCommunityPostBuildActions('Previous unsaved config restored.');
                return;
            }

            setInlineStatus(document.getElementById('communityStatus'), 'No previous profile/config available to restore.', 'text-warning');
        }

        function copyElementValue(elementId) {
            const element = document.getElementById(elementId || '');
            if (!element) {
                return;
            }
            element.select();
            element.setSelectionRange(0, element.value.length);
            navigator.clipboard?.writeText(element.value).catch(() => document.execCommand('copy'));
        }

        async function uploadSingleFile(file, cacheMode) {
            const formData = new FormData();
            formData.append('file', file);
            const metadata = getMetadataPayload();
            formData.append('documentType', metadata.documentType || '');
            formData.append('documentDate', metadata.documentDate || '');
            formData.append('tags', metadata.tags || '');

            let response;
            try {
                response = await fetch(`${backendBaseUrl}${cacheMode ? '/api/documents/upload-cache' : '/api/documents/upload'}`, {
                    method: 'POST',
                    body: formData
                });
            } catch (err) {
                console.error('Upload network error', err);
                return { ok: false, error: `Network error calling ${backendBaseUrl}: ${err.message}. Check the backend is running and CORS allows ${window.location.origin}.` };
            }

            let payload;
            try {
                payload = await response.json();
            } catch (err) {
                console.error('Upload parse error', err, response.status);
                return { ok: false, error: `Backend returned non-JSON (status ${response.status}).` };
            }

            if (!response.ok) {
                return { ok: false, error: payload.error || `Upload failed with status ${response.status}.` };
            }

            return { ok: true, payload };
        }

        function handleUploadSuccess(payload) {
            uploadedDocuments.set(payload.documentId, payload);
            selectedDocumentIds.add(payload.documentId);
            syncDecompositionStateFromUploadedPlans();
            showDocumentPlan(payload.documentId);
        }

        function appendUploadBatchResult(fileName, message, cssClass) {
            return appendBatchResult(document.getElementById('uploadBatchResults'), fileName, message, cssClass);
        }

        function appendBatchResult(list, fileName, message, cssClass) {
            const item = document.createElement('li');
            const name = document.createElement('strong');
            const status = document.createElement('span');
            name.innerText = fileName;
            status.className = cssClass;
            status.innerText = message;
            item.appendChild(name);
            item.appendChild(document.createTextNode(': '));
            item.appendChild(status);
            list.appendChild(item);
            return item;
        }

        function updateUploadBatchResult(item, message, cssClass) {
            const status = item.querySelector('span');
            status.className = cssClass;
            status.innerText = message;
        }

        async function applyMetadataToSelectedDocuments() {
            saveCurrentMetadataDraft();
            const documentIds = Array.from(selectedDocumentIds);
            if (documentIds.length === 0) {
                setMessage('metadataMessage', 'Select one or more uploaded documents first.', 'text-danger');
                return;
            }

            const metadata = getMetadataPayload();
            if (!hasMetadataPayload(metadata)) {
                setMessage('metadataMessage', 'Define at least one metadata field before applying.', 'text-danger');
                return;
            }

            applyMetadataBtn.disabled = true;
            setMessage('metadataMessage', `Applying metadata to ${documentIds.length} document${documentIds.length === 1 ? '' : 's'}...`, 'text-muted');
            let response;
            try {
                response = await fetch(`${backendBaseUrl}/api/documents/metadata`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ documentIds, ...metadata })
                });
            } catch (err) {
                setMessage('metadataMessage', `Metadata update failed: ${err.message}`, 'text-danger');
                applyMetadataBtn.disabled = false;
                renderUploadedDocuments();
                return;
            }

            const payload = await response.json().catch(() => null);
            if (!response.ok) {
                setMessage('metadataMessage', (payload && (payload.error || payload.detail)) || `Metadata update failed (status ${response.status}).`, 'text-danger');
                applyMetadataBtn.disabled = false;
                renderUploadedDocuments();
                return;
            }

            (payload.updated || []).forEach((plan) => {
                uploadedDocuments.set(plan.documentId, plan);
                metadataDrafts.set(plan.documentId, normalizeMetadataDraft(plan.metadata));
            });
            if (currentDocumentId && uploadedDocuments.has(currentDocumentId)) {
                showDocumentPlan(currentDocumentId, { loadMetadata: false });
            } else {
                renderUploadedDocuments();
            }

            const missing = payload.missing || [];
            const suffix = missing.length ? ` (${missing.length} missing: ${missing.join(', ')})` : '';
            setMessage('metadataMessage', `Metadata applied to ${(payload.updated || []).length} document${(payload.updated || []).length === 1 ? '' : 's'}.${suffix}`, missing.length ? 'text-warning' : 'text-success');
            applyMetadataBtn.disabled = selectedDocumentIds.size === 0;
        }

        async function ingestToDatabase() {
            const plans = Array.from(uploadedDocuments.values());
            if (plans.length === 0) {
                setMessage('ingestMessage', 'Upload one or more documents first.', 'text-danger');
                return;
            }

            ingestBatchResults.innerHTML = '';
            ingestBtn.disabled = true;
            let succeeded = 0;
            let failed = 0;
            let skipped = 0;

            for (let index = 0; index < plans.length; index++) {
                const plan = plans[index];
                const label = plan.status.fileName || plan.title || `Document ${plan.documentId}`;
                setMessage('ingestMessage', `Ingesting ${index + 1} of ${plans.length}: ${label}`, 'text-muted');
                const resultItem = appendBatchResult(ingestBatchResults, label, 'Ingesting...', 'text-muted');
                let response;
                try {
                    response = await fetch(`${backendBaseUrl}/api/documents/${plan.documentId}/ingest`, { method: 'POST' });
                } catch (err) {
                    failed++;
                    updateUploadBatchResult(resultItem, `Failed: ${err.message}`, 'text-danger');
                    continue;
                }

                let payload;
                try { payload = await response.json(); } catch { payload = null; }
                if (!response.ok) {
                    failed++;
                    updateUploadBatchResult(resultItem, `Failed: ${(payload && (payload.error || payload.detail)) || `status ${response.status}`}`, 'text-danger');
                    continue;
                }

                if (payload?.graphName) {
                    currentGraphName = payload.graphName;
                }
                if (payload?.documentId) {
                    uploadedDocuments.set(payload.documentId, payload);
                    if (payload.documentId === currentDocumentId) {
                        renderStatus(payload.status);
                    }
                }

                if ((payload?.status?.state || '').toLowerCase() === 'skipped') {
                    skipped += 1;
                    updateUploadBatchResult(resultItem, `Skipped: ${payload?.status?.message || 'No changes were applied.'}`, 'text-warning');
                } else {
                    succeeded += 1;
                    updateUploadBatchResult(resultItem, `Succeeded: ${payload?.status?.message || 'Ingest completed.'}`, 'text-success');
                }
            }

            renderUploadedDocuments();
            if (currentDocumentId && uploadedDocuments.has(currentDocumentId)) {
                showDocumentPlan(currentDocumentId, { loadMetadata: false });
            }

            const hasIssues = failed > 0;
            const messageClass = hasIssues ? ((succeeded + skipped) > 0 ? 'text-warning' : 'text-danger') : 'text-success';
            setMessage('ingestMessage', `Ingest batch complete: ${succeeded} succeeded, ${skipped} skipped, ${failed} failed.`, messageClass);
            ingestBtn.disabled = false;
            await refreshIngestLog();
        }

        async function loadIngestSql() {
            if (!currentDocumentId) {
                return;
            }

            const output = document.getElementById('ingestSqlOutput');
            output.innerText = 'Loading SQL…';
            try {
                const response = await fetch(`${backendBaseUrl}/api/documents/${currentDocumentId}/ingest/preview`);
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    output.innerText = (payload && (payload.error || payload.detail)) || `Failed to load SQL (status ${response.status}).`;
                    return;
                }

                const relational = payload.relationalStatements || [];
                const graph = payload.graphStatements || [];
                const lines = [];
                lines.push('-- Relational statements');
                relational.forEach((stmt, idx) => lines.push(`-- ${idx + 1}\n${stmt}`));
                lines.push('');
                lines.push('-- Graph statements');
                graph.forEach((stmt, idx) => lines.push(`-- ${idx + 1}\n${stmt}`));
                output.innerText = lines.join('\n');
            } catch (err) {
                output.innerText = `Failed to load SQL: ${err.message}`;
            }
        }

        async function refreshIngestLog() {
            if (!currentDocumentId) {
                return;
            }

            const output = document.getElementById('ingestLogOutput');
            output.innerText = 'Loading log…';
            try {
                const response = await fetch(`${backendBaseUrl}/api/documents/${currentDocumentId}/ingest/log`);
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    output.innerText = (payload && (payload.error || payload.detail)) || `Failed to load log (status ${response.status}).`;
                    return;
                }

                const lines = [];
                lines.push(`Started: ${payload.startedAt}`);
                lines.push(`Completed: ${payload.completedAt || 'n/a'}`);
                lines.push(`Statements: ${payload.succeededStatements}/${payload.totalStatements} succeeded, ${payload.failedStatements} failed`);
                (payload.steps || []).forEach((step) => {
                    const status = step.success ? 'ok' : 'fail';
                    lines.push(`[${status}] #${step.index} ${step.statementType} (${step.durationMs}ms)`);
                    if (step.error) {
                        lines.push(`  error: ${step.error}`);
                    }
                    lines.push(`  ${step.statement}`);
                });
                output.innerText = lines.join('\n');
            } catch (err) {
                output.innerText = `Failed to load log: ${err.message}`;
            }
        }

        async function assistQuery() {
            const prompt = document.getElementById('assistantPrompt').value.trim();
            if (!prompt) {
                document.getElementById('assistExplanation').innerText = 'Enter a prompt to get a suggested query.';
                return;
            }

            let response;
            try {
                response = await fetch(`${backendBaseUrl}/api/query/assist`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt })
                });
            } catch (err) {
                document.getElementById('assistExplanation').innerText = `Assistant request failed: ${err.message}`;
                return;
            }

            let payload = null;
            try { payload = await response.json(); } catch { payload = null; }
            if (!response.ok) {
                document.getElementById('assistExplanation').innerText = (payload && payload.error) || 'Assistant failed.';
                return;
            }

            document.getElementById('queryInput').value = payload.suggestedCypher;
            document.getElementById('assistExplanation').innerText = payload.explanation;
        }

        async function runQuery() {
            const query = document.getElementById('queryInput').value.trim();
            if (!query) {
                document.getElementById('queryError').innerText = 'Cypher query is required.';
                renderResults([]);
                renderGraph([], []);
                return;
            }
            const response = await fetch(`${backendBaseUrl}/api/query`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ cypher: query, graphName: currentGraphName })
            });

            const payload = await response.json();
            if (!response.ok) {
                document.getElementById('queryError').innerText = payload.error || 'Query failed.';
                renderResults([]);
                renderGraph([], []);
                return;
            }

            document.getElementById('queryError').innerText = '';
            renderResults(payload.rows || []);
            renderGraph(payload.nodes || [], payload.edges || []);
        }

        async function loadGraphOnStartup() {
            document.getElementById('queryError').innerText = 'Loading graph…';
            try {
                const health = await fetch(`${backendBaseUrl}/api/health/age`);
                if (!health.ok) {
                    const payload = await health.json().catch(() => null);
                    graphReady = false;
                    showAgeStatus(payload?.detail || 'Graph not available until AGE is ready.');
                    document.getElementById('queryError').innerText = 'Graph not available until AGE is ready.';
                    setMessage('initGraphMessage', payload?.detail || 'Initialize the graph in step 4.', 'text-warning');
                    return;
                }
                graphReady = true;
                showAgeStatus('');
                setMessage('initGraphMessage', 'Graph is ready.', 'text-success');
                try {
                    const info = await fetch(`${backendBaseUrl}/api/graph/info`);
                    if (info.ok) {
                        const payload = await info.json();
                        if (payload?.graphName) {
                            currentGraphName = payload.graphName;
                        }
                    }
                } catch {
                    // ignore graph info lookup failures
                }
            } catch (err) {
                graphReady = false;
                showAgeStatus(`Backend not reachable: ${err.message}`);
                document.getElementById('queryError').innerText = `Backend not reachable: ${err.message}`;
                setMessage('initGraphMessage', 'Backend not reachable.', 'text-danger');
                return;
            }

            await refreshGraphCheck();
            await runQuery();
        }

