        async function runHybridRetrieval(isClarification = false) {
            const question = document.getElementById('hybridQuestion').value.trim();
            if (!question) {
                document.getElementById('hybridError').innerText = 'Question is required.';
                return;
            }

            const selectedMode = hybridModeSelect.value;
            if (!isClarification && (selectedMode === 'global' || (selectedMode === 'auto' && shouldUseGlobalMode(question)))) {
                await runGlobalGraphRag(question);
                return;
            }

            const hybridStatus = document.getElementById('hybridStatus');
            const includeTrace = document.getElementById('hybridTraceToggle').checked;
            const includeAnswer = document.getElementById('hybridAnswerToggle').checked;

            if (!isClarification) {
                hybridClarificationAttempts = 0;
                renderProcessMap([], false);
            }

            runHybridBtn.disabled = true;
            hybridStatus.innerText = 'Processing retrieval...';

            const response = await fetch(`${backendBaseUrl}/api/retrieval/hybrid`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    query: question,
                    graphName: currentGraphName,
                    maxHops: 2,
                    limit: 10,
                    includeTrace,
                    includeAnswer,
                    clarificationAttempts: hybridClarificationAttempts,
                    clarificationResponse: isClarification ? (window.lastClarificationResponse || '') : ''
                })
            });

            const payload = await response.json();
            if (!response.ok) {
                document.getElementById('hybridError').innerText = payload.error || 'Hybrid retrieval failed.';
                appendProcessMap([{ title: 'Retrieval failed', body: payload.error || 'Hybrid retrieval failed.' }]);
                hybridStatus.innerText = 'Retrieval failed.';
                runHybridBtn.disabled = false;
                return;
            }

            document.getElementById('hybridError').innerText = '';

            const trace = payload.trace;
            const mapItems = [];

            // Helpers ------------------------------------------------------
            const analysisSystemPrompt = payload.analysisSystemPrompt || '(not available)';
            const answerSystemPrompt = payload.systemPrompt || '(not available)';
            const entityLlmStep = getTraceStep(trace, 'entity-llm');
            const answerStep = getTraceStep(trace, 'llm-answer');
            const matchStep = getTraceStep(trace, 'entity-match');
            const expansionStep = getTraceStep(trace, 'graph-expansion');
            const relationshipsStep = getTraceStep(trace, 'graph-relationships');
            const embeddingStep = getTraceStep(trace, 'embedding');
            const vectorStep = getTraceStep(trace, 'vector-search');
            const fallbackStep = getTraceStep(trace, 'entity-fallback');

            function buildAgentBubble(title, role, systemPrompt, step) {
                return {
                    title,
                    variant: 'agent',
                    role,
                    systemPrompt,
                    systemPromptTitle: `${title} (System Prompt)`,
                    tokenUsage: step && step.tokenUsage ? step.tokenUsage : null
                };
            }

            function buildSqlBubble(title, detail, indent = true) {
                const sql = parseSqlSections(detail);
                if (sql) {
                    return {
                        title,
                        indent,
                        bodyHtml: buildSqlToggleHtml(sql.parameterized, sql.executable)
                    };
                }
                return {
                    title,
                    indent,
                    bodyHtml: `<pre class="sql-toggle-view">${escapeHtml(detail || '(trace disabled)')}</pre>`
                };
            }

            // Phase 0: User question (only on initial call, not on clarification resubmits)
            if (!isClarification) {
                mapItems.push({ title: 'User question received', body: question });
            }

            // Phase 1: Clarification required path -------------------------
            if (payload.clarificationQuestion) {
                mapItems.push(buildAgentBubble(
                    'Clarification Agent',
                    'Detect ambiguity in the user question and ask a clarifying question when needed.',
                    analysisSystemPrompt,
                    entityLlmStep));
                mapItems.push({
                    title: 'Clarification needed',
                    indent: true,
                    body: `${payload.clarificationQuestion} (attempt ${hybridClarificationAttempts + 1} of 3)`,
                    clarification: true,
                    baseQuestion: payload.rewrittenQuestion || question
                });
                appendProcessMap(mapItems);
                hybridStatus.innerText = 'Clarification required.';
                runHybridBtn.disabled = false;
                return;
            }

            // Phase 2: Clarification received + question rewrite ----------
            if (isClarification && window.lastClarificationResponse) {
                mapItems.push(buildAgentBubble(
                    'Clarification Agent',
                    'Detect ambiguity in the user question and ask a clarifying question when needed.',
                    analysisSystemPrompt,
                    entityLlmStep));
                mapItems.push({
                    title: 'Clarification received',
                    indent: true,
                    body: window.lastClarificationResponse
                });
                if (payload.rewrittenQuestion) {
                    mapItems.push({
                        title: 'Question rewrite',
                        indent: true,
                        body: payload.rewrittenQuestion
                    });
                }
            }

            const effectiveQuestion = payload.rewrittenQuestion || question;

            // Phase 3: Entity detection -----------------------------------
            mapItems.push(buildAgentBubble(
                'Entity detection Agent',
                'Extract entities from the user question. Falls back to a heuristic detector if the agent fails.',
                analysisSystemPrompt,
                entityLlmStep));

            const detectedList = fallbackStep ? [] : (payload.detectedEntities || []);
            mapItems.push({
                title: 'Entity detected',
                indent: true,
                body: detectedList.length ? detectedList.join(', ') : '(none)'
            });

            if (matchStep || (payload.matchedEntities && payload.matchedEntities.length)) {
                const matchDetail = includeTrace && matchStep?.detail ? matchStep.detail : '(trace disabled)';
                mapItems.push(buildSqlBubble('Graph Entity matching', matchDetail, true));
                mapItems.push({
                    title: 'Entity match output',
                    indent: true,
                    body: (payload.matchedEntities || []).join(', ') || '(none)'
                });
            }

            if (fallbackStep) {
                const fallbackDetail = includeTrace && fallbackStep.detail ? fallbackStep.detail : '(trace disabled)';
                mapItems.push({
                    title: 'Entity fallback output',
                    indent: true,
                    body: truncateText(fallbackDetail, 500)
                });
            }

            // Phase 4: Graph-expanded entities ----------------------------
            mapItems.push({
                title: 'Graph-expanded entities',
                variant: 'purpose',
                purpose: 'Traverse the knowledge graph from matched entities to discover related entities to broaden retrieval.'
            });
            const expansionDetail = includeTrace && expansionStep?.detail ? expansionStep.detail : '(trace disabled)';
            mapItems.push({
                title: 'Graph expansion query',
                indent: true,
                scroll: true,
                body: truncateText(expansionDetail, 1200)
            });
            mapItems.push({
                title: 'Graph-expanded entities',
                indent: true,
                body: (payload.graphEntities || []).join(', ') || '(none)'
            });

            const relationshipDetail = includeTrace && relationshipsStep?.detail ? relationshipsStep.detail : '(trace disabled)';
            mapItems.push({
                title: 'Graph relationship context',
                variant: 'purpose',
                purpose: 'Load entity → relationship → entity triples with source chunk evidence so the answer agent can reason over graph structure, not just use the graph as a filter.'
            });
            mapItems.push({
                title: 'Graph relationship query',
                indent: true,
                scroll: true,
                body: truncateText(relationshipDetail, 1600)
            });
            const relationshipLines = (payload.graphRelationships || []).map(r => {
                const doc = r.documentId ?? 'n/a';
                const chunk = r.chunkIndex ?? 'n/a';
                const text = r.sourceText ? `\n  evidence: ${truncateText(r.sourceText, 220)}` : '';
                return `${r.source} -[${r.relationship}]-> ${r.target} (doc:${doc} chunk:${chunk})${text}`;
            });
            mapItems.push({
                title: 'Graph relationship output',
                indent: true,
                scroll: true,
                body: relationshipLines.length === 0 ? '(none)' : relationshipLines.join('\n')
            });

            // Phase 5: Question Embedding ---------------------------------
            mapItems.push({
                title: 'Question Embedding',
                variant: 'purpose',
                purpose: 'Vectorize the question for similarity search.',
                inputText: effectiveQuestion
            });
            const embeddingDetail = includeTrace && embeddingStep?.detail ? embeddingStep.detail : '';
            const embeddingOutputText = (() => {
                if (!embeddingDetail) {
                    return '(trace disabled)';
                }
                const outputIdx = embeddingDetail.indexOf('Output:');
                const tail = outputIdx >= 0 ? embeddingDetail.slice(outputIdx + 'Output:'.length).trim() : embeddingDetail;
                return truncateText(tail, 600);
            })();
            mapItems.push({
                title: 'Question Embedding Output',
                indent: true,
                scroll: true,
                body: embeddingOutputText
            });

            // Phase 6: Hybrid Chunk Retrieval -----------------------------
            const vectorDetail = includeTrace && vectorStep?.detail ? vectorStep.detail : '(trace disabled)';
            const vectorSql = parseSqlSections(vectorDetail);
            const vectorBubble = {
                title: 'Hybrid Chunk Retrieval',
                variant: 'purpose',
                purpose: 'Rank graph-relevant chunks with vector similarity and keyword search, then combine both rankings with reciprocal rank fusion.'
            };
            if (vectorSql) {
                vectorBubble.bodyHtml = buildSqlToggleHtml(vectorSql.parameterized, vectorSql.executable);
            } else {
                vectorBubble.bodyHtml = `<pre class="sql-toggle-view">${escapeHtml(vectorDetail)}</pre>`;
            }
            mapItems.push(vectorBubble);

            const chunkLines = (payload.chunks || []).map(c => `[doc:${c.documentId} chunk:${c.chunkIndex}] ${c.content} (distance: ${c.distance ?? 'n/a'}, vectorRank: ${c.vectorRank ?? 'n/a'}, keywordRank: ${c.keywordRank ?? 'n/a'}, score: ${c.score ?? 'n/a'})`);
            mapItems.push({
                title: 'Hybrid Retrieval Output',
                indent: true,
                scroll: true,
                body: chunkLines.length === 0 ? '(none)' : chunkLines.join('\n')
            });

            // Phase 7: Answer Agent ---------------------------------------
            if (includeAnswer) {
                mapItems.push(buildAgentBubble(
                    'Answer Agent',
                    'Synthesize an answer for the user question using the retrieved chunks. Falls back to a heuristic response if the agent fails.',
                    answerSystemPrompt,
                    answerStep));
                mapItems.push({
                    title: 'Agent Answer',
                    indent: true,
                    scroll: true,
                    body: payload.answer || '(no answer returned)'
                });
            }

            appendProcessMap(mapItems);

            hybridStatus.innerText = 'Retrieval complete.';
            hybridClarificationAttempts = 0;
            window.lastClarificationResponse = '';
            runHybridBtn.disabled = false;
        }

        function shouldUseGlobalMode(question) {
            return /\b(theme|themes|pattern|patterns|trend|trends|across|overall|summary|summarize|top\s+\d+|changed|timeline|over time|before|after|recent|chronolog)/i.test(question);
        }

        async function buildCommunities() {
            const communityStatus = document.getElementById('communityStatus');
            document.getElementById('communityError').innerText = '';
            buildCommunitiesBtn.disabled = true;
            communityStatus.innerText = 'Building communities...';
            document.getElementById('communityProcessMap').innerHTML = '';

            try {
                const response = await fetch(`${backendBaseUrl}/api/communities/build`, { method: 'POST' });
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.error || 'Community build failed.');
                }

                const items = [];
                if (payload.trace?.steps) {
                    payload.trace.steps.forEach(step => items.push(buildCommunityTraceItem(step)));
                }
                appendCommunityProcessMap(items);
                communityStatus.innerText = 'Communities built.';
            } catch (err) {
                document.getElementById('communityError').innerText = err.message;
                appendCommunityProcessMap([{ title: 'Community build failed', body: err.message }]);
                communityStatus.innerText = 'Community build failed.';
            } finally {
                buildCommunitiesBtn.disabled = false;
            }
        }

        function buildCommunityTraceItem(step) {
            const detail = step.detail || '';
            if (step.name === 'community-schema') {
                return { title: step.summary || step.name, bodyHtml: buildCommunitySchemaTabs(detail) };
            }
            if (step.name === 'community-load') {
                return { title: step.summary || step.name, bodyHtml: buildCommunityLoadTabs(detail) };
            }
            if (step.name === 'community-clustering') {
                return { title: step.summary || step.name, bodyHtml: buildCommunityClusteringTabs(detail) };
            }
            if (step.name === 'community-summary') {
                return { title: step.summary || step.name, bodyHtml: buildCommunitySummaryTabs(detail) };
            }

            return { title: step.summary || step.name, scroll: true, body: detail };
        }

        function buildCommunitySchemaTabs(detail) {
            const sql = sectionAfter(detail, 'SQL:');
            const overview = sectionBefore(detail, 'SQL:') || detail;
            const tabs = [
                { title: 'communities', content: extractSqlStatement(sql, 'CREATE TABLE IF NOT EXISTS communities'), pre: true },
                { title: 'community_members', content: extractSqlStatement(sql, 'CREATE TABLE IF NOT EXISTS community_members'), pre: true },
                { title: 'community_sources', content: extractSqlStatement(sql, 'CREATE TABLE IF NOT EXISTS community_sources'), pre: true },
                { title: 'indexes', content: sql.split(';').map(s => s.trim()).filter(s => /^CREATE INDEX|^DO \$\$/i.test(s)).map(s => `${s};`).join('\n\n'), pre: true }
            ];
            return `<div class="fw-semibold mb-1">Tables:</div>${buildTabsHtml('community-schema-tabs', tabs, overview)}`;
        }

        function buildCommunityLoadTabs(detail) {
            const overview = sectionBefore(detail, 'Entity SQL:') || detail;
            const entitySql = betweenSections(detail, 'Entity SQL:', 'Entity output sample (top 50):');
            const entityOutput = betweenSections(detail, 'Entity output sample (top 50):', 'Relationship SQL:');
            const relationshipSql = betweenSections(detail, 'Relationship SQL:', 'Relationship output sample (top 50):');
            const relationshipOutput = sectionAfter(detail, 'Relationship output sample (top 50):');
            const entityContent = buildSqlAndResultsetHtml('Entity details', entitySql, entityOutput);
            const relationshipContent = buildSqlAndResultsetHtml('Relationship details', relationshipSql, relationshipOutput);
            return buildTabsHtml('community-load-tabs', [
                { title: 'Entity', contentHtml: entityContent },
                { title: 'Relationship', contentHtml: relationshipContent }
            ], overview);
        }

        function buildCommunityClusteringTabs(detail) {
            const allLines = detail.split(/\r?\n/);
            const componentStart = allLines.findIndex(line => line.startsWith('Components') || line.startsWith('Largest components'));
            const overview = componentStart >= 0 ? allLines.slice(0, componentStart).join('\n') : detail;
            const components = componentStart >= 0 ? allLines.slice(componentStart + 1).filter(Boolean) : [];
            const multi = components.filter(line => /entities=(?!1,)/.test(line));
            const singletons = components.filter(line => /entities=1,/.test(line));
            return buildTabsHtml('community-clustering-tabs', [
                { title: `Multi-Entity (${multi.length})`, content: multi.join('\n') || '(none)', pre: true },
                { title: `Singleton (${singletons.length})`, content: singletons.join('\n') || '(none)', pre: true },
                { title: `All (${components.length})`, content: components.join('\n') || '(none)', pre: true }
            ], overview);
        }

        function buildCommunitySummaryTabs(detail) {
            const firstCommunity = detail.indexOf('Community id:');
            const intro = firstCommunity >= 0 ? detail.slice(0, firstCommunity).trim() : detail;
            const communitiesText = firstCommunity >= 0 ? detail.slice(firstCommunity).trim() : '';
            const sqlStart = intro.indexOf('Write SQL templates:');
            const bullets = sqlStart >= 0 ? intro.slice(0, sqlStart).trim() : intro;
            const sqlTemplates = sqlStart >= 0 ? intro.slice(sqlStart + 'Write SQL templates:'.length).trim() : '';
            const communityBlocks = communitiesText ? communitiesText.split(/\n\s*---\s*\n/).filter(Boolean) : [];
            const tabs = communityBlocks.map((block, index) => ({ title: `Community ${index + 1}`, contentHtml: buildCommunityDetailTabs(block, sqlTemplates) }));
            return buildTabsHtml('community-summary-tabs', tabs, bullets);
        }

        function buildCommunityDetailTabs(block, sqlTemplates) {
            const variables = sectionBefore(block, 'LLM question:');
            const prompt = betweenSections(block, 'LLM question:', 'LLM context:');
            const context = betweenSections(block, 'LLM context:', 'Generated summary:');
            const completion = sectionAfter(block, 'Generated summary:');
            const sqlTemplateTabs = buildCommunitySqlTemplateTabs(sqlTemplates, block);
            return buildTabsHtml('community-detail-tabs', [
                { title: 'Variables', content: variables || '(none)', pre: true },
                { title: 'Prompt', content: buildCommunityPromptText(prompt, context), pre: true },
                { title: 'Completion', content: completion || '(none)', pre: true },
                { title: 'SQL', contentHtml: sqlTemplateTabs }
            ]);
        }

        function buildCommunityPromptText(question, context) {
            return `LLM question:\n${(question || '(none)').trim()}\n\nLLM context:\n${(context || '(none)').trim()}`;
        }

        function buildCommunitySqlTemplateTabs(sqlTemplates, sampleCommunityBlock) {
            const statements = splitCommunitySqlTemplates(sqlTemplates);
            const sample = parseCommunitySample(sampleCommunityBlock);
            return buildTabsHtml('community-write-template-tabs', [
                {
                    title: 'communities',
                    contentHtml: buildSqlVariablesOutputTabs(
                        statements.communities,
                        buildCommunityVariables(sample),
                        sample.communitiesOutput || (sample.id ? `RETURNING id: ${sample.id}` : 'RETURNING id: (generated community id)'))
                },
                {
                    title: 'community_members',
                    contentHtml: buildSqlVariablesOutputTabs(
                        statements.members,
                        `@@community_id = ${sample.id || '(generated community id)'}\n@@entity_id = one entity id from the selected component\nRows attempted = ${sample.entities || '(entity count)'}`,
                        sample.membersOutput || (sample.entities ? `Inserted or kept ${sample.entities} community/entity membership rows.` : 'One row per entity in the community.'))
                },
                {
                    title: 'community_sources',
                    contentHtml: buildSqlVariablesOutputTabs(
                        statements.sources,
                        `@@community_id = ${sample.id || '(generated community id)'}\n@@document_id = one source document id from community relationship evidence`,
                        sample.sourcesOutput || 'One row per distinct source document that contributed evidence to the community.')
                }
            ]);
        }

        function buildSqlVariablesOutputTabs(sql, variables, output) {
            return buildTabsHtml('community-write-template-detail-tabs', [
                { title: 'SQL', content: `Variables:\n${variables || '(none)'}\n\nSQL:\n${sql || '(none)'}`, pre: true },
                { title: 'Real output', content: output || '(none)', pre: true }
            ]);
        }

        function splitCommunitySqlTemplates(sqlTemplates) {
            return {
                communities: extractSqlStatement(sqlTemplates, 'INSERT INTO communities'),
                members: extractSqlStatement(sqlTemplates, 'INSERT INTO community_members'),
                sources: extractSqlStatement(sqlTemplates, 'INSERT INTO community_sources')
            };
        }

        function parseCommunitySample(block) {
            const read = (regex) => {
                const match = block.match(regex);
                return match ? match[1].trim() : '';
            };
            return {
                id: read(/Community id:\s*(.+)/),
                key: read(/Community key:\s*(.+)/),
                title: read(/Title:\s*(.+)/),
                entities: read(/Entities:\s*(\d+)/),
                relationships: read(/Relationships:\s*(\d+)/),
                communitiesOutput: readBlock(block, 'Persisted communities row:', 'Persisted community_members rows (top 50):'),
                membersOutput: readBlock(block, 'Persisted community_members rows (top 50):', 'Persisted community_sources rows (top 50):'),
                sourcesOutput: readBlock(block, 'Persisted community_sources rows (top 50):', 'LLM question:'),
                summary: read(/Generated summary:\s*([\s\S]+)/)
            };
        }

        function readBlock(value, startMarker, endMarker) {
            const start = value.indexOf(startMarker);
            if (start < 0) return '';
            const contentStart = start + startMarker.length;
            const end = value.indexOf(endMarker, contentStart);
            return (end >= 0 ? value.slice(contentStart, end) : value.slice(contentStart)).trim();
        }

        function buildCommunityVariables(sample) {
            const summaryPreview = sample.summary ? truncateText(sample.summary.replace(/\s+/g, ' '), 240) : '(generated summary text)';
            return [
                `@@key = ${sample.key || '(computed from sorted entity ids)'}`,
                `@@title = ${sample.title || '(top community entity names)'}`,
                `@@summary = ${summaryPreview}`,
                '@@embedding = vector embedding of @@summary (1536 dimensions)',
                `@@entity_count = ${sample.entities || '(entity count)'}`,
                `@@relationship_count = ${sample.relationships || '(relationship count)'}`,
                '@@start_date = earliest document_date in community evidence, if present',
                '@@end_date = latest document_date in community evidence, if present'
            ].join('\n');
        }

        function buildTabsHtml(idPrefix, tabs, overview = '') {
            const id = `${idPrefix}-${Math.random().toString(36).slice(2)}`;
            const safeTabs = tabs.filter(tab => tab && (tab.contentHtml || tab.content || tab.content === ''));
            const normalizedOverview = normalizeDisplayText(overview);
            const overviewHtml = normalizedOverview ? `<div class="community-tab-overview mb-2">${escapeHtml(normalizedOverview).replace(/\n/g, '<br />')}</div>` : '';
            if (safeTabs.length === 0) {
                return `<div class="community-tabs">${overviewHtml}</div>`;
            }

            const buttons = safeTabs.map((tab, index) => `<button type="button" class="btn btn-sm btn-outline-secondary community-tab-btn ${index === 0 ? 'active' : ''}" data-tab-target="${id}-${index}" aria-selected="${index === 0 ? 'true' : 'false'}">${escapeHtml(tab.title)}</button>`).join('');
            const panels = safeTabs.map((tab, index) => {
                const content = escapeHtml((tab.content || '').trim() || '(none)');
                const body = tab.contentHtml || (tab.pre ? `<pre class="sql-toggle-view mb-0">${content}</pre>` : `<div>${content.replace(/\n/g, '<br />')}</div>`);
                return `<div class="community-tab-panel ${index === 0 ? '' : 'd-none'}" id="${id}-${index}" data-tab-index="${index}">${body}</div>`;
            }).join('');
            return `<div class="community-tabs">${overviewHtml}<div class="btn-group btn-group-sm flex-wrap mb-2" role="group">${buttons}</div>${panels}</div>`;
        }

        function buildSqlAndResultsetHtml(label, sql, resultset) {
            const nestedTabs = buildTabsHtml('community-nested-sql-tabs', [
                { title: 'SQL', content: sql || '(none)', pre: true },
                { title: 'SQL resultset', content: resultset || '(none)', pre: true }
            ]);
            return `<div class="border rounded px-2 py-1 mt-2 bg-white"><div class="text-muted small fw-semibold mb-1">${escapeHtml(label)}</div>${nestedTabs}</div>`;
        }

            function normalizeDisplayText(value) {
                return String(value || '')
                .replace(/\r\n/g, '\n')
                .replace(/\n{3,}/g, '\n\n')
                .trim();
            }

        function sectionBefore(value, marker) {
            const index = value.indexOf(marker);
            return index >= 0 ? value.slice(0, index).trim() : value.trim();
        }

        function sectionAfter(value, marker) {
            const index = value.indexOf(marker);
            return index >= 0 ? value.slice(index + marker.length).trim() : '';
        }

        function betweenSections(value, startMarker, endMarker) {
            const start = value.indexOf(startMarker);
            if (start < 0) return '';
            const end = value.indexOf(endMarker, start + startMarker.length);
            return (end >= 0 ? value.slice(start + startMarker.length, end) : value.slice(start + startMarker.length)).trim();
        }

        function extractSqlStatement(sql, prefix) {
            const start = sql.indexOf(prefix);
            if (start < 0) return '';
            const end = sql.indexOf(';', start);
            return end >= 0 ? sql.slice(start, end + 1).trim() : sql.slice(start).trim();
        }

        async function runGlobalGraphRag(question) {
            const hybridStatus = document.getElementById('hybridStatus');
            const includeTrace = document.getElementById('hybridTraceToggle').checked;
            const includeAnswer = document.getElementById('hybridAnswerToggle').checked;
            document.getElementById('hybridError').innerText = '';
            renderProcessMap([{ title: 'Global / Temporal question received', body: question }], false);
            runHybridBtn.disabled = true;
            hybridStatus.innerText = 'Running global GraphRAG...';

            try {
                const response = await fetch(`${backendBaseUrl}/api/retrieval/global`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ query: question, limit: 6, includeTrace, includeAnswer })
                });
                const payload = await response.json();
                if (!response.ok || !payload.success) {
                    throw new Error(payload.error || 'Global GraphRAG failed.');
                }

                const items = [];
                if (payload.trace?.steps) {
                    payload.trace.steps.forEach(step => items.push({
                        title: step.summary || step.name,
                        scroll: true,
                        body: step.detail || ''
                    }));
                }
                const communityLines = (payload.communities || []).map(c => `Community ${c.id}: ${c.title}\n${c.summary}`);
                items.push({ title: 'Community summary output', indent: true, scroll: true, body: communityLines.length ? communityLines.join('\n\n') : '(none - build communities first)' });
                const timelineLines = (payload.timeline || []).map(d => `${d.documentDate || 'undated'}: ${d.title}`);
                items.push({ title: 'Temporal timeline output', indent: true, scroll: true, body: timelineLines.length ? timelineLines.join('\n') : '(none)' });
                if (includeAnswer) {
                    items.push({ title: 'Global GraphRAG answer', indent: true, scroll: true, body: payload.answer || '(no answer returned)' });
                }
                appendProcessMap(items);
                hybridStatus.innerText = 'Global GraphRAG complete.';
            } catch (err) {
                document.getElementById('hybridError').innerText = err.message;
                appendProcessMap([{ title: 'Global GraphRAG failed', body: err.message }]);
                hybridStatus.innerText = 'Global GraphRAG failed.';
            } finally {
                runHybridBtn.disabled = false;
            }
        }

        function renderDecomposition(payload) {
            const systemPrompt = payload.decompositionSystemPrompt || '(no system prompt returned)';
            document.getElementById('originalContent').textContent = payload.originalContent || '(no original content returned)';
            document.getElementById('graphMakerAgentPrompt').textContent = systemPrompt;
            document.getElementById('decompositionSystemPrompt').textContent = systemPrompt;
            renderList('chunksOutput', payload.chunks.map(c => `#${c.id}: ${c.text}`));
            renderList('entitiesOutput', payload.entities.map(e => `${e.label}: ${e.name}`));
            renderList('mentionsOutput', payload.mentions.map(m => `Chunk ${m.chunkId} -> ${m.entityLabel}(${m.entityName})`));
            renderList('relationshipsOutput', (payload.relationships || []).map(r => {
                const chunk = r.chunkId ? ` | chunk ${r.chunkId}` : '';
                const confidence = r.confidence !== null && r.confidence !== undefined ? ` | confidence ${r.confidence}` : '';
                return `${r.sourceName} -[${r.relationship}]-> ${r.targetName}${chunk}${confidence}`;
            }));
        }

        function renderStatus(status) {
            document.getElementById('statusOutput').innerText =
                `Document ${status.documentId}: ${status.state} | ${status.message} | Updated: ${status.updatedAt}`;
        }

        function renderList(elementId, items) {
            const list = document.getElementById(elementId);
            list.innerHTML = '';
            for (const item of items) {
                const li = document.createElement('li');
                li.innerText = item;
                list.appendChild(li);
            }
        }

        function renderProcessMap(items, append = false, containerId = 'hybridProcessMap') {
            const container = document.getElementById(containerId);
            if (!append) {
                container.innerHTML = '';
            }

            if (!items || items.length === 0) {
                if (!append) {
                    container.innerText = '(no process steps to display)';
                }
                return;
            }

            if (append && container.children.length > 0) {
                const connector = document.createElement('div');
                connector.className = 'process-connector';
                if (items[0].indent) {
                    connector.classList.add('process-connector-indent');
                }
                container.appendChild(connector);
            }

            items.forEach((item, index) => {
                const bubble = createProcessBubble(item);
                container.appendChild(bubble);

                if (index < items.length - 1) {
                    const connector = document.createElement('div');
                    connector.className = 'process-connector';
                    if (item.indent) {
                        connector.classList.add('process-connector-indent');
                    }
                    container.appendChild(connector);
                }
            });
        }

        function appendProcessMap(items) {
            renderProcessMap(items, true);
        }

        function renderCommunityProcessMap(items, append = false) {
            renderProcessMap(items, append, 'communityProcessMap');
        }

        function appendCommunityProcessMap(items) {
            renderCommunityProcessMap(items, true);
        }

        function createProcessBubble(item) {
            const bubble = document.createElement('div');
            bubble.className = 'process-bubble';
            if (item.indent) {
                bubble.classList.add('process-bubble-indent');
            }
            if (item.scroll) {
                bubble.classList.add('process-bubble-scroll');
            }
            if (item.variant === 'agent') {
                bubble.classList.add('process-bubble-agent');
            } else if (item.variant === 'purpose') {
                bubble.classList.add('process-bubble-purpose');
            }

            const title = document.createElement('div');
            title.className = 'process-bubble-title';
            title.innerText = item.title || 'Step';
            bubble.appendChild(title);

            if (item.role) {
                const section = document.createElement('div');
                section.className = 'process-bubble-section';
                section.innerHTML = `<span class="label">Role:</span> ${escapeHtml(item.role)}`;
                bubble.appendChild(section);
            }

            if (item.purpose) {
                const section = document.createElement('div');
                section.className = 'process-bubble-section';
                section.innerHTML = `<span class="label">Purpose:</span> ${escapeHtml(item.purpose)}`;
                bubble.appendChild(section);
            }

            if (item.inputText) {
                const section = document.createElement('div');
                section.className = 'process-bubble-section';
                section.innerHTML = `<span class="label">Input:</span> ${escapeHtml(item.inputText)}`;
                bubble.appendChild(section);
            }

            if (item.body || item.bodyHtml) {
                const body = document.createElement('div');
                body.className = 'process-bubble-body';
                if (item.bodyHtml) {
                    body.innerHTML = item.bodyHtml;
                } else {
                    body.innerText = item.body;
                }
                bubble.appendChild(body);
            }

            if (item.systemPrompt) {
                const details = document.createElement('details');
                details.className = 'process-bubble-systemprompt';
                const summary = document.createElement('summary');
                summary.innerText = item.systemPromptTitle || 'Agent System Prompt';
                details.appendChild(summary);
                const pre = document.createElement('pre');
                pre.innerText = item.systemPrompt;
                details.appendChild(pre);
                bubble.appendChild(details);
            }

            if (item.tokenUsage) {
                const tokens = document.createElement('div');
                tokens.className = 'process-bubble-tokens';
                const p = item.tokenUsage.promptTokens;
                const c = item.tokenUsage.completionTokens;
                const promptText = (p === null || p === undefined) ? 'n/a' : p;
                const completionText = (c === null || c === undefined) ? 'n/a' : c;
                tokens.innerText = `Token usage: prompt: ${promptText} | completion: ${completionText}`;
                bubble.appendChild(tokens);
            }

            if (item.clarification) {
                const inputGroup = document.createElement('div');
                inputGroup.className = 'input-group mt-2';

                const input = document.createElement('input');
                input.className = 'form-control';
                input.type = 'text';
                input.placeholder = 'Your clarification...';

                const button = document.createElement('button');
                button.className = 'btn btn-outline-primary';
                button.type = 'button';
                button.innerText = 'Submit clarification';
                if (hybridClarificationAttempts >= 3) {
                    input.disabled = true;
                    button.disabled = true;
                }
                button.addEventListener('click', () => {
                    const value = input.value.trim();
                    if (!value) {
                        return;
                    }

                        const base = item.baseQuestion || document.getElementById('hybridQuestion').value.trim();
                        document.getElementById('hybridQuestion').value = base;
                        window.lastClarificationResponse = value;
                    hybridClarificationAttempts += 1;
                    runHybridRetrieval(true);
                });

                inputGroup.appendChild(input);
                inputGroup.appendChild(button);
                bubble.appendChild(inputGroup);
            }

            return bubble;
        }

        function getTraceStep(trace, name) {
            if (!trace || !Array.isArray(trace.steps)) {
                return null;
            }

            return trace.steps.find(step => step.name === name) || null;
        }

        function truncateText(value, maxLength) {
            if (!value) {
                return '';
            }

            return value.length > maxLength ? `${value.slice(0, maxLength)}...` : value;
        }

        function escapeHtml(value) {
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function parseSqlSections(value) {
            if (!value) {
                return null;
            }

            const parameterizedHeader = 'Parameterized SQL:';
            const executableHeader = 'Executable SQL:';
            const parameterizedIndex = value.indexOf(parameterizedHeader);
            const executableIndex = value.indexOf(executableHeader);
            if (parameterizedIndex === -1 || executableIndex === -1) {
                return null;
            }

            const parameterized = value
                .slice(parameterizedIndex + parameterizedHeader.length, executableIndex)
                .trim();
            const executable = value
                .slice(executableIndex + executableHeader.length)
                .trim();
            return { parameterized, executable };
        }

        function buildSqlToggleHtml(parameterizedSql, executableSql) {
            const parameterized = escapeHtml(parameterizedSql);
            const executable = escapeHtml(executableSql);
            return `
                <div class="sql-toggle" data-view="parameterized">
                    <div class="btn-group btn-group-sm sql-toggle-buttons" role="group">
                        <button type="button" class="btn btn-outline-secondary sql-toggle-btn active" data-view="parameterized">Parameterized</button>
                        <button type="button" class="btn btn-outline-secondary sql-toggle-btn" data-view="executable">Executable</button>
                    </div>
                    <pre class="sql-toggle-view sql-toggle-view-parameterized">${parameterized}</pre>
                    <pre class="sql-toggle-view sql-toggle-view-executable d-none">${executable}</pre>
                </div>`;
        }

        document.addEventListener('click', (event) => {
            const communityTabButton = event.target.closest('.community-tab-btn');
            if (communityTabButton) {
                const wrapper = communityTabButton.closest('.community-tabs');
                if (!wrapper) {
                    return;
                }

                const buttons = getOwnCommunityTabButtons(wrapper);
                const panels = getOwnCommunityTabPanels(wrapper);
                buttons.forEach(btn => btn.classList.remove('active'));
                buttons.forEach(btn => btn.setAttribute('aria-selected', 'false'));
                panels.forEach(panel => panel.classList.add('d-none'));
                communityTabButton.classList.add('active');
                communityTabButton.setAttribute('aria-selected', 'true');
                const target = panels.find(panel => panel.id === communityTabButton.dataset.tabTarget);
                if (target) {
                    target.classList.remove('d-none');
                    resetNestedCommunityTabs(target);
                } else {
                    showFirstCommunityTab(wrapper);
                }
                return;
            }

            const button = event.target.closest('.sql-toggle-btn');
            if (!button) {
                return;
            }

            const container = button.closest('.sql-toggle');
            if (!container) {
                return;
            }

            const view = button.dataset.view;
            container.querySelectorAll('.sql-toggle-view').forEach((element) => {
                element.classList.toggle('d-none', !element.classList.contains(`sql-toggle-view-${view}`));
            });
            container.querySelectorAll('.sql-toggle-btn').forEach((btn) => {
                btn.classList.toggle('active', btn === button);
            });
        });

        function showFirstCommunityTab(wrapper) {
            const buttons = getOwnCommunityTabButtons(wrapper);
            const panels = getOwnCommunityTabPanels(wrapper);
            const firstButton = buttons[0];
            const firstPanel = panels[0];
            if (!firstButton || !firstPanel) {
                return;
            }

            buttons.forEach(btn => {
                btn.classList.remove('active');
                btn.setAttribute('aria-selected', 'false');
            });
            panels.forEach(panel => panel.classList.add('d-none'));
            firstButton.classList.add('active');
            firstButton.setAttribute('aria-selected', 'true');
            firstPanel.classList.remove('d-none');
            resetNestedCommunityTabs(firstPanel);
        }

        function getOwnCommunityTabButtons(wrapper) {
            return Array.from(wrapper.querySelectorAll(':scope > .btn-group > .community-tab-btn'));
        }

        function getOwnCommunityTabPanels(wrapper) {
            return Array.from(wrapper.querySelectorAll(':scope > .community-tab-panel'));
        }

        function resetNestedCommunityTabs(container) {
            container.querySelectorAll('.community-tabs').forEach(showFirstCommunityTab);
        }

        function renderResults(rows) {
            const table = document.getElementById('resultsTable');
            table.innerHTML = '';
            if (!rows.length) {
                return;
            }

            const keys = Object.keys(rows[0]);
            const thead = document.createElement('thead');
            const headRow = document.createElement('tr');
            keys.forEach(k => {
                const th = document.createElement('th');
                th.innerText = k;
                headRow.appendChild(th);
            });
            thead.appendChild(headRow);
            table.appendChild(thead);

            const tbody = document.createElement('tbody');
            rows.forEach(row => {
                const tr = document.createElement('tr');
                keys.forEach(key => {
                    const td = document.createElement('td');
                    td.innerText = row[key] ?? '';
                    tr.appendChild(td);
                });
                tbody.appendChild(tr);
            });
            table.appendChild(tbody);
        }

        function renderGraph(nodes, edges) {
            const container = document.getElementById('graphView');
            container.innerHTML = '';
            resetGraphSelectionDetails();
            destroyGraphInstance();
            currentGraphNodes = nodes || [];
            currentGraphEdges = edges || [];
            currentGraphNodeMap = new Map(currentGraphNodes.map(node => [String(node.id), node]));
            currentGraphEdgeMap = new Map();
            currentGraphLabelColorMap = buildLegacyVisColorMap(currentGraphNodes);
            setGraphStats(currentGraphNodes.length, currentGraphEdges.length);

            if (!currentGraphNodes.length) {
                container.innerText = 'No graph primitives returned. Use a query that returns vertices/edges.';
                return;
            }

            const degreeById = calculateDegrees(currentGraphNodes, currentGraphEdges);
            if (graphSettings.engine === 'vis') {
                renderVisNetworkGraph(container, degreeById);
                return;
            }

            renderCytoscapeGraph(container, degreeById);
        }

        function renderCytoscapeGraph(container, degreeById) {
            if (!window.cytoscape) {
                container.innerText = 'Cytoscape.js failed to load. Check internet access or bundle the library locally.';
                return;
            }

            graphCy = cytoscape({
                container,
                elements: buildCytoscapeElements(currentGraphNodes, currentGraphEdges, degreeById),
                style: buildCytoscapeStyle(),
                layout: buildCytoscapeLayout(false),
                minZoom: 0.08,
                maxZoom: 3,
                wheelSensitivity: 0.18
            });

            graphCy.nodes().grabify();

            graphCy.on('tap', 'node', (event) => {
                const node = event.target.data('original');
                if (node) {
                    showGraphNodeDetails(node);
                    updateGraphHighlight(event.target);
                }
            });

            graphCy.on('tap', 'edge', (event) => {
                const edge = event.target.data('original');
                if (edge) {
                    showGraphEdgeDetails(edge, currentGraphNodeMap);
                    updateGraphHighlight(event.target);
                }
            });

            graphCy.on('tap', (event) => {
                if (event.target === graphCy) {
                    clearGraphHighlight();
                    resetGraphSelectionDetails();
                }
            });

            updateBackgroundForceButton();
        }

        function renderVisNetworkGraph(container, degreeById) {
            if (!window.vis?.Network || !window.vis?.DataSet) {
                container.innerText = 'vis-network failed to load. Check internet access or bundle the library locally.';
                return;
            }

            currentVisNodeItems = buildVisNetworkNodes(currentGraphNodes, degreeById);
            currentVisEdgeItems = buildVisNetworkEdges(currentGraphEdges);
            currentVisNodeDataSet = new vis.DataSet(currentVisNodeItems);
            currentVisEdgeDataSet = new vis.DataSet(currentVisEdgeItems);
            const visData = {
                nodes: currentVisNodeDataSet,
                edges: currentVisEdgeDataSet
            };
            graphNetwork = new vis.Network(container, visData, buildVisNetworkOptions());

            graphNetwork.on('click', (params) => {
                if (params.nodes.length) {
                    const node = currentGraphNodeMap.get(String(params.nodes[0]));
                    if (node) {
                        showGraphNodeDetails(node);
                    }
                    return;
                }

                if (params.edges.length) {
                    const edge = currentGraphEdgeMap.get(String(params.edges[0]));
                    if (edge) {
                        showGraphEdgeDetails(edge, currentGraphNodeMap);
                    }
                    return;
                }

                graphNetwork.unselectAll();
                resetGraphSelectionDetails();
            });

            updateBackgroundForceButton();
        }

        function destroyGraphInstance() {
            stopBackgroundForceLayout();

            if (graphCy) {
                graphCy.destroy();
                graphCy = null;
            }

            if (graphNetwork) {
                graphNetwork.destroy();
                graphNetwork = null;
            }
            currentVisNodeDataSet = null;
            currentVisEdgeDataSet = null;
            currentVisNodeItems = [];
            currentVisEdgeItems = [];
            updateBackgroundForceButton();
        }

        function buildCytoscapeElements(nodes, edges, degreeById) {
            const cyNodes = nodes.map(node => {
                const id = String(node.id);
                return {
                    group: 'nodes',
                    data: buildGraphNodeVisualData(node, degreeById)
                };
            });

            const cyEdges = edges
                .filter(edge => currentGraphNodeMap.has(String(edge.source)) && currentGraphNodeMap.has(String(edge.target)))
                .map((edge, index) => {
                    const id = `edge-${index}`;
                    currentGraphEdgeMap.set(id, edge);
                    return {
                        group: 'edges',
                        data: {
                            id,
                            source: String(edge.source),
                            target: String(edge.target),
                            label: edge.label || '',
                            original: edge
                        }
                    };
                });

            return [...cyNodes, ...cyEdges];
        }

        function buildGraphNodeVisualData(node, degreeById) {
            const id = String(node.id);
            return {
                id,
                title: node.title || id,
                kgLabel: node.label || 'Node',
                nodeKind: getGraphNodeKind(node),
                legacyVisColor: currentGraphLabelColorMap.get(node.label || 'Node')?.background || legacyVisNetworkPalette[0].background,
                legacyVisBorderColor: currentGraphLabelColorMap.get(node.label || 'Node')?.border || legacyVisNetworkPalette[0].border,
                degree: degreeById.get(id) || 0,
                original: node
            };
        }

        function buildVisNetworkNodes(nodes, degreeById) {
            if (graphSettings.layout === 'visDefault') {
                const nodeScale = Number(graphSettings.nodeScale) || 1;
                return nodes.map((node) => ({
                    id: String(node.id),
                    label: graphSettings.showNodeLabels ? node.title || String(node.id) : '',
                    title: JSON.stringify(node.properties || {}, null, 2),
                    group: node.label || 'Node',
                    shape: graphSettings.nodeTextInside ? 'ellipse' : 'dot',
                    size: Math.round(16 * nodeScale),
                    font: {
                        color: graphSettings.nodeTextInside ? '#ffffff' : '#212529',
                        face: 'system-ui, -apple-system, Segoe UI, sans-serif',
                        size: 12,
                        bold: graphSettings.nodeTextInside,
                        strokeWidth: graphSettings.nodeTextInside ? 3 : 0,
                        strokeColor: 'rgba(0, 0, 0, 0.36)'
                    },
                    margin: graphSettings.nodeTextInside ? 8 : undefined,
                    widthConstraint: graphSettings.nodeTextInside ? { maximum: 120 } : undefined
                }));
            }

            const nodeScale = Number(graphSettings.nodeScale) || 1;
            const positions = buildVisNetworkPositions(nodes, degreeById);
            return nodes.map((node) => {
                const data = buildGraphNodeVisualData(node, degreeById);
                const nodeSize = Math.round((18 + Math.min(data.degree, 8) * 2) * nodeScale);
                const color = getCytoscapeNodeColor(data);
                const borderColor = getCytoscapeNodeBorderColor(data);
                const position = positions.get(data.id) || {};
                return {
                    id: data.id,
                    label: graphSettings.showNodeLabels ? data.title : '',
                    title: `${data.kgLabel}: ${data.title}`,
                    group: data.kgLabel,
                    shape: graphSettings.nodeTextInside ? 'ellipse' : 'dot',
                    size: nodeSize,
                    borderWidth: 2,
                    color: {
                        background: color,
                        border: borderColor,
                        highlight: { background: color, border: '#111827' },
                        hover: { background: color, border: '#111827' }
                    },
                    font: {
                        color: graphSettings.nodeTextInside ? '#ffffff' : '#212529',
                        face: 'system-ui, -apple-system, Segoe UI, sans-serif',
                        size: 12,
                        bold: graphSettings.nodeTextInside,
                        strokeWidth: graphSettings.nodeTextInside ? 3 : 0,
                        strokeColor: 'rgba(0, 0, 0, 0.36)'
                    },
                    margin: graphSettings.nodeTextInside ? 8 : undefined,
                    widthConstraint: graphSettings.nodeTextInside ? { maximum: Math.max(70, nodeSize * 4) } : undefined,
                    ...position
                };
            });
        }

        function buildVisNetworkEdges(edges) {
            if (graphSettings.layout === 'visDefault') {
                return edges
                    .filter(edge => currentGraphNodeMap.has(String(edge.source)) && currentGraphNodeMap.has(String(edge.target)))
                    .map((edge, index) => {
                        const id = edge.id ? String(edge.id) : `edge-${index}`;
                        currentGraphEdgeMap.set(id, edge);
                        return {
                            id,
                            from: String(edge.source),
                            to: String(edge.target),
                            label: graphSettings.showEdgeLabels ? edge.label || '' : ''
                        };
                    });
            }

            const edgeWidth = Number(graphSettings.edgeWidth) || 2;
            return edges
                .filter(edge => currentGraphNodeMap.has(String(edge.source)) && currentGraphNodeMap.has(String(edge.target)))
                .map((edge, index) => {
                    const id = `edge-${index}`;
                    currentGraphEdgeMap.set(id, edge);
                    return {
                        id,
                        from: String(edge.source),
                        to: String(edge.target),
                        label: graphSettings.showEdgeLabels ? edge.label || '' : '',
                        arrows: graphSettings.showArrows ? 'to' : '',
                        width: edgeWidth,
                        color: { color: '#8c9aa8', highlight: '#111827', hover: '#111827' },
                        font: { color: '#495057', size: 10, align: 'middle', strokeWidth: 3, strokeColor: '#ffffff' },
                        smooth: { type: 'dynamic' }
                    };
                });
        }

        function buildVisNetworkOptions() {
            if (graphSettings.layout === 'visDefault') {
                return {};
            }

            const physicsStrength = Number(graphSettings.physicsStrength) || 1;
            const physicsSpringLength = Number(graphSettings.physicsSpringLength) || 110;
            const physicsGravity = Number(graphSettings.physicsGravity) || 0.7;
            const layoutSpacing = Number(graphSettings.layoutSpacing) || 1.35;
            const forceLayouts = ['physics', 'fcose', 'cose', 'cose-bilkent', 'cola', 'cise', 'random'];
            const hierarchicalLayouts = ['breadthfirst', 'dagre', 'elk'];
            const physicsEnabled = forceLayouts.includes(graphSettings.layout);
            const hierarchicalEnabled = hierarchicalLayouts.includes(graphSettings.layout);
            return {
                autoResize: true,
                layout: {
                    improvedLayout: !hierarchicalEnabled,
                    hierarchical: hierarchicalEnabled
                        ? { enabled: true, direction: mapLayoutDirectionForVis(graphSettings.layoutDirection), sortMethod: 'directed', nodeSpacing: Math.round(110 * layoutSpacing), levelSeparation: physicsSpringLength }
                        : false
                },
                interaction: { hover: true, multiselect: false, navigationButtons: false, keyboard: false },
                nodes: { shadow: false },
                edges: { shadow: false, selectionWidth: 2 },
                physics: {
                    enabled: physicsEnabled,
                    solver: 'forceAtlas2Based',
                    stabilization: { enabled: true, iterations: Math.round(550 * physicsStrength), fit: Boolean(graphSettings.autoFitLayout) },
                    forceAtlas2Based: {
                        gravitationalConstant: -55 * physicsStrength,
                        centralGravity: Math.max(0.005, physicsGravity / 10),
                        springLength: physicsSpringLength,
                        springConstant: 0.08 * physicsStrength,
                        damping: 0.42,
                        avoidOverlap: 0.55
                    }
                }
            };
        }

        function mapLayoutDirectionForVis(direction) {
            switch (direction) {
                case 'LR':
                    return 'LR';
                case 'BT':
                    return 'DU';
                case 'RL':
                    return 'RL';
                case 'TB':
                default:
                    return 'UD';
            }
        }

        function buildVisNetworkPositions(nodes, degreeById) {
            const positions = new Map();
            if (['physics', 'fcose', 'cose', 'cose-bilkent', 'cola', 'cise', 'breadthfirst', 'dagre', 'elk', 'random'].includes(graphSettings.layout)) {
                return positions;
            }

            const nodeCount = Math.max(nodes.length, 1);
            const spacing = 85 * (Number(graphSettings.layoutSpacing) || 1.35);
            if (graphSettings.layout === 'grid') {
                const columns = Math.ceil(Math.sqrt(nodeCount));
                nodes.forEach((node, index) => {
                    const row = Math.floor(index / columns);
                    const column = index % columns;
                    positions.set(String(node.id), { x: (column - columns / 2) * spacing, y: row * spacing, fixed: { x: true, y: true } });
                });
                return positions;
            }

            const orderedNodes = graphSettings.layout === 'concentric'
                ? [...nodes].sort((left, right) => (degreeById.get(String(right.id)) || 0) - (degreeById.get(String(left.id)) || 0))
                : nodes;
            orderedNodes.forEach((node, index) => {
                const radius = graphSettings.layout === 'concentric' ? 95 + Math.floor(index / 8) * 90 : Math.max(130, nodeCount * 14);
                const angle = (index / nodeCount) * Math.PI * 2;
                positions.set(String(node.id), { x: Math.cos(angle) * radius, y: Math.sin(angle) * radius, fixed: { x: true, y: true } });
            });
            return positions;
        }

        function calculateDegrees(nodes, edges) {
            const degreeById = new Map(nodes.map(node => [String(node.id), 0]));
            edges.forEach(edge => {
                const source = String(edge.source);
                const target = String(edge.target);
                degreeById.set(source, (degreeById.get(source) || 0) + 1);
                degreeById.set(target, (degreeById.get(target) || 0) + 1);
            });
            return degreeById;
        }

        function buildCytoscapeStyle() {
            const nodeScale = Number(graphSettings.nodeScale) || 1;
            const edgeWidth = Number(graphSettings.edgeWidth) || 2;
            const nodeSize = 34 * nodeScale;
            const labelInside = graphSettings.nodeTextInside;
            return [
                {
                    selector: 'node',
                    style: {
                        'width': nodeSize,
                        'height': nodeSize,
                        'background-color': (element) => getCytoscapeNodeColor(element.data()),
                        'border-width': 2,
                        'border-color': (element) => getCytoscapeNodeBorderColor(element.data()),
                        'label': graphSettings.showNodeLabels ? 'data(title)' : '',
                        'font-size': 11,
                        'font-family': 'system-ui, -apple-system, Segoe UI, sans-serif',
                        'font-weight': labelInside ? 700 : 500,
                        'color': labelInside ? '#ffffff' : '#212529',
                        'text-wrap': 'wrap',
                        'text-max-width': labelInside ? Math.max(28, nodeSize * 1.15) : 120,
                        'text-valign': labelInside ? 'center' : 'bottom',
                        'text-halign': 'center',
                        'text-margin-y': labelInside ? 0 : 6,
                        'text-background-color': '#ffffff',
                        'text-background-opacity': graphSettings.showNodeLabels && !labelInside ? 0.78 : 0,
                        'text-background-padding': 2,
                        'text-outline-color': labelInside ? 'rgba(0, 0, 0, 0.36)' : 'transparent',
                        'text-outline-width': labelInside ? 2 : 0,
                        'overlay-opacity': 0,
                        'transition-property': 'background-color, border-color, opacity, width, height, line-color, target-arrow-color',
                        'transition-duration': '120ms'
                    }
                },
                {
                    selector: 'edge',
                    style: {
                        'width': edgeWidth,
                        'line-color': '#8c9aa8',
                        'target-arrow-color': '#8c9aa8',
                        'target-arrow-shape': graphSettings.showArrows ? 'triangle' : 'none',
                        'curve-style': 'bezier',
                        'label': graphSettings.showEdgeLabels ? 'data(label)' : '',
                        'font-size': 9,
                        'color': '#495057',
                        'text-background-color': '#ffffff',
                        'text-background-opacity': graphSettings.showEdgeLabels ? 0.75 : 0,
                        'text-background-padding': 2,
                        'text-rotation': 'autorotate',
                        'transition-property': 'line-color, target-arrow-color, opacity, width',
                        'transition-duration': '120ms'
                    }
                },
                {
                    selector: '.faded',
                    style: {
                        'opacity': 0.16,
                        'text-opacity': 0.08
                    }
                },
                {
                    selector: '.highlighted',
                    style: {
                        'opacity': 1,
                        'border-color': '#111827',
                        'line-color': '#111827',
                        'target-arrow-color': '#111827',
                        'width': (element) => element.isEdge() ? Math.max(edgeWidth + 1, 3) : nodeSize
                    }
                }
            ];
        }

        function getCytoscapeNodeColor(data) {
            if (graphSettings.colorMode === 'legacyVis') {
                return data.legacyVisColor || legacyVisNetworkPalette[0].background;
            }

            if (graphSettings.colorMode === 'neutral') {
                return '#5f6c7b';
            }

            if (graphSettings.colorMode === 'degree') {
                const degree = Number(data.degree) || 0;
                if (degree >= 6) return '#c2410c';
                if (degree >= 3) return '#0f766e';
                return '#4f46e5';
            }

            if (graphSettings.colorMode === 'kind') {
                switch (data.nodeKind) {
                    case 'document':
                        return '#2563eb';
                    case 'chunk':
                        return '#059669';
                    case 'entity':
                        return '#7c3aed';
                    default:
                        return '#6b7280';
                }
            }

            const palette = ['#2563eb', '#059669', '#d97706', '#7c3aed', '#be123c', '#0891b2', '#65a30d'];
            const label = String(data.kgLabel || 'Node');
            let hash = 0;
            for (let index = 0; index < label.length; index += 1) {
                hash = ((hash << 5) - hash) + label.charCodeAt(index);
                hash |= 0;
            }
            return palette[Math.abs(hash) % palette.length];
        }

        function getCytoscapeNodeBorderColor(data) {
            if (graphSettings.colorMode === 'legacyVis') {
                return data.legacyVisBorderColor || legacyVisNetworkPalette[0].border;
            }

            return '#ffffff';
        }

        function buildLegacyVisColorMap(nodes) {
            const colorMap = new Map();
            nodes.forEach((node) => {
                const label = node.label || 'Node';
                if (!colorMap.has(label)) {
                    colorMap.set(label, legacyVisNetworkPalette[colorMap.size % legacyVisNetworkPalette.length]);
                }
            });
            return colorMap;
        }

        function getGraphNodeKind(node) {
            const label = String(node.label || '').toLowerCase();
            const properties = node.properties || {};
            const title = String(node.title || properties.title || properties.name || '').toLowerCase();
            const candidates = [label, title, String(properties.type || '').toLowerCase(), String(properties.kind || '').toLowerCase()];

            if (candidates.some(value => value.includes('document'))) {
                return 'document';
            }

            if (candidates.some(value => value.includes('chunk'))) {
                return 'chunk';
            }

            if (candidates.some(value => value.includes('entity'))) {
                return 'entity';
            }

            return 'other';
        }

        function buildCytoscapeLayout(animated) {
            const physicsStrength = Number(graphSettings.physicsStrength) || 1;
            const physicsSpringLength = Number(graphSettings.physicsSpringLength) || 110;
            const physicsGravity = Number(graphSettings.physicsGravity) || 0.7;
            const layoutPadding = Number(graphSettings.layoutPadding) || 35;
            const layoutSpacing = Number(graphSettings.layoutSpacing) || 1.35;
            const animateLayout = Boolean(graphSettings.animateLayout) && animated;
            const layoutDirection = graphSettings.layoutDirection || 'TB';
            const common = {
                fit: Boolean(graphSettings.autoFitLayout),
                padding: layoutPadding,
                animate: animateLayout,
                animationDuration: animateLayout ? 500 : 0
            };

            switch (graphSettings.layout) {
                case 'physics':
                case 'fcose':
                    return {
                        ...common,
                        name: isCytoscapeLayoutAvailable('fcose') ? 'fcose' : 'cose',
                        quality: graphSettings.layoutQuality || 'proof',
                        randomize: true,
                        nodeSeparation: Math.round(75 * layoutSpacing),
                        nodeRepulsion: () => Math.round(6500 * physicsStrength),
                        idealEdgeLength: () => physicsSpringLength,
                        edgeElasticity: () => Math.round(90 * physicsStrength),
                        gravity: physicsGravity,
                        gravityRangeCompound: 1.5,
                        gravityCompound: 1.0,
                        numIter: Math.round(1600 * physicsStrength),
                        tile: true
                    };
                case 'cola':
                    return {
                        ...common,
                        name: isCytoscapeLayoutAvailable('cola') ? 'cola' : 'cose',
                        maxSimulationTime: Math.round(3000 * physicsStrength),
                        nodeSpacing: Math.round(30 * layoutSpacing),
                        edgeLength: physicsSpringLength,
                        flow: layoutDirection === 'LR' ? { axis: 'x', minSeparation: physicsSpringLength } : undefined,
                        alignment: undefined,
                        groupCompaction: 0.8,
                        infinite: false
                    };
                case 'cose-bilkent':
                    return {
                        ...common,
                        name: isCytoscapeLayoutAvailable('coseBilkent') ? 'cose-bilkent' : 'cose',
                        nodeDimensionsIncludeLabels: true,
                        idealEdgeLength: physicsSpringLength,
                        nodeRepulsion: Math.round(4500 * physicsStrength),
                        gravity: Math.max(0.05, physicsGravity / 3),
                        gravityRange: 3.8,
                        numIter: Math.round(1800 * physicsStrength)
                    };
                case 'dagre':
                    return {
                        ...common,
                        name: isCytoscapeLayoutAvailable('dagre') ? 'dagre' : 'breadthfirst',
                        rankDir: layoutDirection,
                        align: layoutDirection === 'LR' || layoutDirection === 'RL' ? 'UL' : undefined,
                        nodeSep: Math.round(50 * layoutSpacing),
                        rankSep: physicsSpringLength,
                        edgeSep: 10,
                        ranker: 'network-simplex'
                    };
                case 'elk':
                    return {
                        ...common,
                        name: isCytoscapeLayoutAvailable('elk') ? 'elk' : 'breadthfirst',
                        algorithm: graphSettings.layoutQuality === 'draft' ? 'mrtree' : graphSettings.layoutQuality === 'default' ? 'layered' : 'stress',
                        nodeDimensionsIncludeLabels: true,
                        randomize: true,
                        elk: {
                            'elk.direction': mapLayoutDirectionForElk(layoutDirection),
                            'elk.spacing.nodeNode': Math.round(60 * layoutSpacing),
                            'elk.layered.spacing.baseValue': physicsSpringLength,
                            'elk.layered.spacing.nodeNodeBetweenLayers': physicsSpringLength
                        }
                    };
                case 'cise':
                    return {
                        ...common,
                        name: isCytoscapeLayoutAvailable('cise') ? 'cise' : 'circle',
                        clusters: buildCiseClusters(),
                        allowNodesInsideCircle: true,
                        maxRatioOfNodesInsideCircle: 0.1,
                        springCoeff: 0.45,
                        nodeRepulsion: Math.round(4500 * physicsStrength),
                        gravity: Math.max(0.05, physicsGravity / 3),
                        gravityRange: 3.8
                    };
                case 'breadthfirst':
                    return { ...common, name: 'breadthfirst', directed: true, spacingFactor: layoutSpacing, maximal: false };
                case 'concentric':
                    return { ...common, name: 'concentric', minNodeSpacing: Math.round(45 * layoutSpacing), concentric: node => node.degree(), levelWidth: nodes => Math.max(1, nodes.maxDegree() / 3), equidistant: graphSettings.layoutQuality === 'proof' };
                case 'circle':
                    return { ...common, name: 'circle', avoidOverlap: true, spacingFactor: layoutSpacing, startAngle: (3 / 2) * Math.PI, clockwise: true };
                case 'grid':
                    return { ...common, name: 'grid', avoidOverlap: true, avoidOverlapPadding: Math.round(20 * layoutSpacing), spacingFactor: layoutSpacing };
                case 'random':
                    return { ...common, name: 'random' };
                case 'cose':
                default:
                    return { ...common, name: 'cose', randomize: true, nodeOverlap: 20, componentSpacing: Math.round(40 * layoutSpacing), nodeRepulsion: Math.round(400000 * physicsStrength), idealEdgeLength: physicsSpringLength, edgeElasticity: Math.round(100 * physicsStrength), nestingFactor: 5, gravity: Math.round(80 * physicsGravity), numIter: Math.round(1000 * physicsStrength), initialTemp: 200, coolingFactor: 0.95, minTemp: 1.0 };
            }
        }

        function isCytoscapeLayoutAvailable(layoutName) {
            return Boolean(cytoscapeExtensions[layoutName]);
        }

        function mapLayoutDirectionForElk(direction) {
            switch (direction) {
                case 'LR':
                    return 'RIGHT';
                case 'BT':
                    return 'UP';
                case 'RL':
                    return 'LEFT';
                case 'TB':
                default:
                    return 'DOWN';
            }
        }

        function buildCiseClusters() {
            const clustersByLabel = new Map();
            currentGraphNodes.forEach((node) => {
                const label = node.label || 'Node';
                const cluster = clustersByLabel.get(label) || [];
                cluster.push(String(node.id));
                clustersByLabel.set(label, cluster);
            });
            return [...clustersByLabel.values()].filter(cluster => cluster.length > 1);
        }

        function updateGraphSettingFromControl(event) {
            const control = event.currentTarget;
            const setting = control.dataset.graphSetting;
            if (!setting) {
                return;
            }

            graphSettings[setting] = control.type === 'checkbox' ? control.checked : control.value;
            if (setting === 'engine') {
                applyGraphEngineDefaults(graphSettings.engine);
            }

            if (!currentGraphNodes.length) {
                return;
            }

            if (setting === 'engine') {
                renderGraph(currentGraphNodes, currentGraphEdges);
                return;
            }

            if (graphSettings.engine === 'vis') {
                if (setting === 'highlightNeighborhood') {
                    clearGraphHighlight();
                    return;
                }

                renderGraph(currentGraphNodes, currentGraphEdges);
                return;
            }

            if (!graphCy) {
                return;
            }

            const layoutSettings = new Set(['layout', 'physicsStrength', 'physicsSpringLength', 'physicsGravity', 'layoutQuality', 'layoutDirection', 'layoutPadding', 'layoutSpacing', 'animateLayout', 'autoFitLayout']);
            if (layoutSettings.has(setting)) {
                runGraphLayout(true);
                return;
            }

            graphCy.style(buildCytoscapeStyle()).update();
            clearGraphHighlight();
        }

        function applyGraphEngineDefaults(engine) {
            Object.assign(graphSettings, engine === 'vis' ? visDefaultGraphSettings : defaultGraphSettings, { engine });
            syncGraphSettingsControls();
        }

        function syncGraphSettingsControls() {
            document.querySelectorAll('[data-graph-setting]').forEach((control) => {
                const setting = control.dataset.graphSetting;
                if (control.type === 'checkbox') {
                    control.checked = Boolean(graphSettings[setting]);
                } else {
                    control.value = graphSettings[setting];
                }
            });
        }

        function applyGraphSettingTooltips() {
            document.querySelectorAll('[data-graph-setting]').forEach((control) => {
                const description = graphSettingDescriptions[control.dataset.graphSetting];
                if (!description) {
                    return;
                }

                control.title = description;
                control.setAttribute('aria-label', description);
                const label = control.id ? document.querySelector(`label[for="${control.id}"]`) : null;
                if (label) {
                    label.title = description;
                }
            });

            Object.entries(graphActionDescriptions).forEach(([id, description]) => {
                const button = document.getElementById(id);
                if (!button) {
                    return;
                }

                button.title = description;
                button.setAttribute('aria-label', description);
            });
        }

        function runGraphLayout(animated) {
            if (graphSettings.engine === 'vis') {
                if (currentGraphNodes.length) {
                    renderGraph(currentGraphNodes, currentGraphEdges);
                }
                return;
            }

            if (!graphCy || graphCy.nodes().empty()) {
                return;
            }

            stopBackgroundForceLayout();
            graphCy.layout(buildCytoscapeLayout(animated)).run();
        }

        function toggleBackgroundForceLayout() {
            if (backgroundCytoscapeLayout) {
                stopBackgroundForceLayout();
                return;
            }

            startBackgroundForceLayout();
        }

        function startBackgroundForceLayout() {
            if (graphSettings.engine !== 'cytoscape' || !graphCy || graphCy.nodes().empty()) {
                return;
            }

            stopBackgroundForceLayout();
            graphCy.nodes().unlock().grabify();
            const layout = graphCy.layout(buildCytoscapeBackgroundForceLayout());
            backgroundCytoscapeLayout = layout;
            updateBackgroundForceButton();
            layout.on('layoutstop', () => {
                if (backgroundCytoscapeLayout === layout) {
                    backgroundCytoscapeLayout = null;
                    graphCy?.nodes().unlock().grabify();
                    updateBackgroundForceButton();
                }
            });
            layout.run();
        }

        function stopBackgroundForceLayout() {
            if (!backgroundCytoscapeLayout) {
                updateBackgroundForceButton();
                return;
            }

            const layout = backgroundCytoscapeLayout;
            backgroundCytoscapeLayout = null;
            layout.stop?.();
            graphCy?.nodes().unlock().grabify();
            updateBackgroundForceButton();
        }

        function buildCytoscapeBackgroundForceLayout() {
            const physicsStrength = Number(graphSettings.physicsStrength) || 1;
            const physicsSpringLength = Number(graphSettings.physicsSpringLength) || 110;
            const layoutSpacing = Number(graphSettings.layoutSpacing) || 1.35;
            const layoutDirection = graphSettings.layoutDirection || 'TB';

            if (isCytoscapeLayoutAvailable('cola')) {
                return {
                    name: 'cola',
                    fit: false,
                    animate: true,
                    refresh: 1,
                    maxSimulationTime: 0,
                    ungrabifyWhileSimulating: false,
                    randomize: false,
                    centerGraph: false,
                    avoidOverlap: true,
                    handleDisconnected: true,
                    nodeSpacing: Math.round(35 * layoutSpacing),
                    edgeLength: physicsSpringLength,
                    flow: layoutDirection === 'LR' ? { axis: 'x', minSeparation: physicsSpringLength } : undefined,
                    convergenceThreshold: 0.00001,
                    infinite: true
                };
            }

            return {
                name: 'cose',
                fit: false,
                animate: true,
                randomize: false,
                nodeOverlap: 20,
                componentSpacing: Math.round(40 * layoutSpacing),
                nodeRepulsion: Math.round(420000 * physicsStrength),
                idealEdgeLength: physicsSpringLength,
                edgeElasticity: Math.round(100 * physicsStrength),
                gravity: Math.round(80 * (Number(graphSettings.physicsGravity) || 0.7)),
                numIter: Math.round(2500 * physicsStrength),
                initialTemp: 160,
                coolingFactor: 0.98,
                minTemp: 0.25
            };
        }

        function updateBackgroundForceButton() {
            if (!graphBackgroundForceBtn) {
                return;
            }

            const canRun = graphSettings.engine === 'cytoscape' && Boolean(graphCy) && !graphCy.nodes().empty();
            graphBackgroundForceBtn.disabled = !canRun;
            graphBackgroundForceBtn.classList.toggle('btn-success', Boolean(backgroundCytoscapeLayout));
            graphBackgroundForceBtn.classList.toggle('btn-outline-secondary', !backgroundCytoscapeLayout);
            graphBackgroundForceBtn.innerText = backgroundCytoscapeLayout ? 'Stop force' : 'Start force';
        }

        function fitGraphView() {
            if (graphSettings.engine === 'vis') {
                graphNetwork?.fit({ animation: { duration: 450, easingFunction: 'easeInOutQuad' } });
                return;
            }

            graphCy?.animate({ fit: { eles: graphCy.elements(), padding: 50 }, duration: 500, easing: 'ease-out-cubic' });
        }

        function toggleGraphSettingsPane() {
            graphSettingsCollapsed = !graphSettingsCollapsed;
            const workbench = document.querySelector('.graph-workbench');
            workbench?.classList.toggle('graph-settings-collapsed', graphSettingsCollapsed);
            graphSettingsToggleBtn.innerText = graphSettingsCollapsed ? 'Settings' : 'Minimize';
            graphSettingsToggleBtn.setAttribute('aria-expanded', String(!graphSettingsCollapsed));

            window.requestAnimationFrame(() => {
                graphCy?.resize();
                graphNetwork?.redraw();
                fitGraphView();
            });
        }

        function toggleQuerySidebarPane() {
            querySidebarCollapsed = !querySidebarCollapsed;
            const workbench = document.querySelector('.query-workbench-layout');
            workbench?.classList.toggle('query-sidebar-collapsed', querySidebarCollapsed);
            querySidebarToggleBtn.innerText = querySidebarCollapsed ? 'Query' : 'Minimize';
            querySidebarToggleBtn.setAttribute('aria-expanded', String(!querySidebarCollapsed));

            window.requestAnimationFrame(() => {
                graphCy?.resize();
                graphNetwork?.redraw();
                fitGraphView();
            });
        }

        function centerGraphView() {
            if (graphSettings.engine === 'vis') {
                graphNetwork?.moveTo({ position: { x: 0, y: 0 }, animation: { duration: 450, easingFunction: 'easeInOutQuad' } });
                return;
            }

            graphCy?.animate({ center: { eles: graphCy.elements() }, duration: 500 });
        }

        function zoomGraphView(scale) {
            if (graphSettings.engine === 'vis') {
                const zoom = graphNetwork?.getScale?.() || 1;
                graphNetwork?.moveTo({ scale: zoom * scale, animation: { duration: 350, easingFunction: 'easeInOutQuad' } });
                return;
            }

            if (!graphCy) {
                return;
            }

            graphCy.animate({ zoom: graphCy.zoom() * scale, duration: 350, easing: 'ease-in-out-cubic' });
        }

        function applyLayoutToSelectedNeighborhood() {
            if (graphSettings.engine === 'vis') {
                runGraphLayout(true);
                return;
            }

            if (!graphCy) {
                return;
            }

            const selectedNodes = graphCy.nodes(':selected');
            if (!selectedNodes.length) {
                return;
            }

            const boundingBox = selectedNodes.boundingBox();
            const center = {
                x: (boundingBox.x1 + boundingBox.x2) / 2,
                y: (boundingBox.y1 + boundingBox.y2) / 2
            };
            const neighborhood = selectedNodes.neighborhood().add(selectedNodes);
            const otherNodes = graphCy.nodes().not(neighborhood);
            const positions = {};
            otherNodes.forEach((node) => {
                positions[node.id()] = { ...node.position() };
            });

            const layout = neighborhood.layout({
                ...buildCytoscapeLayout(true),
                fit: false,
                boundingBox: {
                    x1: center.x - 140,
                    y1: center.y - 140,
                    x2: center.x + 140,
                    y2: center.y + 140
                }
            });
            layout.on('layoutstop', () => {
                otherNodes.forEach((node) => {
                    node.animate({ position: positions[node.id()], duration: 500 });
                });
            });
            layout.run();
        }

        function updateGraphHighlight(target) {
            if (!graphCy || !graphSettings.highlightNeighborhood) {
                return;
            }

            graphCy.elements().removeClass('highlighted faded');
            const focus = target.closedNeighborhood ? target.closedNeighborhood() : target.connectedNodes().union(target);
            graphCy.elements().difference(focus).addClass('faded');
            focus.addClass('highlighted');
        }

        function clearGraphHighlight() {
            graphCy?.elements().removeClass('highlighted faded');
            graphNetwork?.unselectAll();
        }

        function resetGraphSettings() {
            Object.assign(graphSettings, graphSettings.engine === 'vis' ? visDefaultGraphSettings : defaultGraphSettings);
            syncGraphSettingsControls();

            if (graphCy) {
                graphCy.style(buildCytoscapeStyle()).update();
                runGraphLayout(true);
                clearGraphHighlight();
            } else if (graphNetwork && currentGraphNodes.length) {
                renderGraph(currentGraphNodes, currentGraphEdges);
            }
        }

        function setGraphStats(nodeCount, edgeCount) {
            const stats = document.getElementById('graphRenderStats');
            if (stats) {
                const engineName = graphSettings.engine === 'vis' ? 'vis-network' : 'Cytoscape.js';
                stats.innerText = `${nodeCount} nodes, ${edgeCount} edges rendered with ${engineName}.`;
            }
        }

        function resetGraphSelectionDetails() {
            const details = document.getElementById('graphSelectionDetails');
            const summary = document.getElementById('graphSelectionSummary');
            const content = document.getElementById('graphSelectionContent');
            details.open = false;
            summary.innerText = 'Selected graph item details';
            content.className = 'graph-selection-content text-muted small';
            content.innerText = 'Click a node or edge in the graph to inspect it.';
        }

        async function showGraphNodeDetails(node) {
            showGraphSelectionDetails(`Node: ${node.title || node.id}`, [
                ['Type', 'Node', 'Cytoscape.js selection'],
                ['AGE ID', node.id, 'AGE vertex.id'],
                ['Label', node.label, 'AGE vertex.label'],
                ['Title', node.title, 'display value'],
                ...objectEntriesToRows(node.properties || {}, (key) => `AGE vertex.properties.${key}`)
            ], true);

            try {
                const response = await fetch(`${backendBaseUrl}/api/graph/node/details`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id: String(node.id),
                        label: node.label || '',
                        title: node.title || '',
                        properties: node.properties || {}
                    })
                });
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    setGraphRelationalDetails(payload?.error || `Could not load kg_data details (status ${response.status}).`, true);
                    return;
                }

                setGraphRelationalDetails(payload?.attributes || {}, payload?.attributeSources || {}, false, node, payload?.attributeSourceSqls || {});
            } catch (err) {
                setGraphRelationalDetails(`Could not load kg_data details: ${err.message}`, true);
            }
        }

        function showGraphEdgeDetails(edge, nodesById) {
            const source = nodesById.get(String(edge.source));
            const target = nodesById.get(String(edge.target));
            showGraphSelectionDetails(`Edge: ${edge.label || 'relationship'}`, [
                ['Type', 'Edge', 'Cytoscape.js selection'],
                ['Label', edge.label, 'AGE edge.label'],
                ['Source ID', edge.source, 'AGE edge.start_id'],
                ['Source title', source?.title || '', 'display value'],
                ['Target ID', edge.target, 'AGE edge.end_id'],
                ['Target title', target?.title || '', 'display value']
            ]);
        }

        function showGraphSelectionDetails(summaryText, rows, includeRelationalDetails = false) {
            const details = document.getElementById('graphSelectionDetails');
            const summary = document.getElementById('graphSelectionSummary');
            const content = document.getElementById('graphSelectionContent');

            summary.innerText = summaryText;
            content.className = 'graph-selection-content';
            content.innerHTML = '';

            const grid = document.createElement('div');
            grid.className = includeRelationalDetails ? 'graph-selection-grid' : '';

            const graphPanel = document.createElement('div');
            const graphTitle = document.createElement('div');
            graphTitle.className = 'graph-selection-panel-title';
            graphTitle.innerText = 'Graph item';
            graphPanel.appendChild(graphTitle);
            graphPanel.appendChild(createGraphAttributeTable(rows));
            grid.appendChild(graphPanel);

            if (includeRelationalDetails) {
                const relationalPanel = document.createElement('div');
                const relationalTitle = document.createElement('div');
                relationalTitle.className = 'graph-selection-panel-title';
                relationalTitle.innerText = 'kg_data attributes';
                relationalPanel.appendChild(relationalTitle);

                const relationalContent = document.createElement('div');
                relationalContent.id = 'graphRelationalDetails';
                relationalContent.className = 'text-muted small';
                relationalContent.innerText = 'Loading relational details...';
                relationalPanel.appendChild(relationalContent);
                grid.appendChild(relationalPanel);
            }

            content.appendChild(grid);
            details.open = true;
        }

        function createGraphAttributeTable(rows) {
            const table = document.createElement('table');
            table.className = 'table table-sm table-bordered mb-0 graph-selection-table';
            const thead = document.createElement('thead');
            const headerRow = document.createElement('tr');
            const columnDescriptions = {
                Attribute: 'The displayed field name for the selected graph item or relational row.',
                Value: 'The value returned for that field. Long values are shortened until expanded.',
                Source: 'Where the value came from. For derived values, this can be executable SQL.'
            };
            ['Attribute', 'Value', 'Source'].forEach((label) => {
                const th = document.createElement('th');
                th.scope = 'col';
                th.innerText = label;
                th.title = columnDescriptions[label];
                headerRow.appendChild(th);
            });
            thead.appendChild(headerRow);
            table.appendChild(thead);

            const tbody = document.createElement('tbody');
            rows.forEach(([label, value, source, sourceSql]) => {
                const tr = document.createElement('tr');
                const th = document.createElement('th');
                th.scope = 'row';
                th.innerText = label;
                const td = document.createElement('td');
                appendExpandableCellContent(td, value ?? '');
                const sourceTd = document.createElement('td');
                sourceTd.className = 'graph-selection-source';
                appendSourceCellContent(sourceTd, source || '', sourceSql || '');
                tr.appendChild(th);
                tr.appendChild(td);
                tr.appendChild(sourceTd);
                tbody.appendChild(tr);
            });
            table.appendChild(tbody);
            return table;
        }

        function appendExpandableCellContent(cell, value) {
            const text = String(value ?? '');
            const maxLength = 140;
            if (text.length <= maxLength) {
                cell.innerText = text;
                return;
            }

            const textSpan = document.createElement('span');
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn btn-sm btn-outline-secondary graph-cell-toggle';
            button.title = 'Expand or collapse full cell text';

            let expanded = false;
            const render = () => {
                textSpan.innerText = expanded ? text : `${text.slice(0, maxLength)}...`;
                button.innerText = expanded ? 'Collapse' : 'Expand';
            };
            button.addEventListener('click', () => {
                expanded = !expanded;
                render();
            });

            render();
            cell.appendChild(textSpan);
            cell.appendChild(document.createTextNode(' '));
            cell.appendChild(button);
        }

        function appendSourceCellContent(cell, source, sourceSql) {
            if (!sourceSql) {
                appendExpandableCellContent(cell, source);
                return;
            }

            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn btn-link graph-source-link';
            button.title = 'Show executable SQL for this source';
            button.innerText = source;
            button.addEventListener('click', () => showSourceSqlDialog(source, sourceSql));
            cell.appendChild(button);
        }

        function setGraphRelationalDetails(value, sourcesOrIsError = {}, isError = false, selectedNode = null, sourceSqls = {}) {
            if (typeof sourcesOrIsError === 'boolean') {
                isError = sourcesOrIsError;
                sourcesOrIsError = {};
            }

            const container = document.getElementById('graphRelationalDetails');
            if (!container) {
                return;
            }

            container.className = isError ? 'text-danger small' : '';
            container.innerHTML = '';
            if (typeof value === 'string') {
                container.innerText = value;
                return;
            }

            const rows = objectEntriesToRows(
                value,
                (key) => sourcesOrIsError[key] || 'kg_data',
                (key) => sourceSqls[key] || '');
            if (rows.length === 0) {
                container.className = 'text-muted small';
                container.innerText = 'No relational details found.';
                return;
            }

            appendEntityFocusAction(container, selectedNode);
            container.appendChild(createGraphAttributeTable(rows));
        }

        function appendEntityFocusAction(container, selectedNode) {
            const entityName = selectedNode?.properties?.name;
            if (!entityName || selectedNode.label === 'Document' || selectedNode.label === 'Chunk') {
                return;
            }

            const note = document.createElement('div');
            note.className = 'graph-selection-hint mb-2';
            note.innerText = 'The canvas only shows relationships returned by the active Cypher query. Focus this entity to show all MENTIONS edges returned for it.';

            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'btn btn-sm btn-outline-primary mb-2';
            button.innerText = 'Show linked chunks in graph';
            button.addEventListener('click', async () => {
                document.getElementById('queryInput').value = `MATCH (c:Chunk)-[r:MENTIONS]->(e)\nWHERE e.name = "${escapeCypherString(entityName)}"\nRETURN c, r, e\nLIMIT 200`;
                await runQuery();
            });

            container.appendChild(note);
            container.appendChild(button);
        }

        function escapeCypherString(value) {
            return String(value)
                .replace(/\\/g, '\\\\')
                .replace(/"/g, '\\"');
        }

        function objectEntriesToRows(value, sourceFactory = () => '', sourceSqlFactory = () => '') {
            return Object.entries(value || {}).map(([key, val]) => [formatAttributeLabel(key), val, sourceFactory(key), sourceSqlFactory(key)]);
        }

        function showSourceSqlDialog(source, sql) {
            const existing = document.getElementById('sourceSqlDialog');
            if (existing) {
                existing.remove();
            }

            const overlay = document.createElement('div');
            overlay.id = 'sourceSqlDialog';
            overlay.className = 'source-sql-overlay';

            const dialog = document.createElement('div');
            dialog.className = 'source-sql-dialog';
            dialog.setAttribute('role', 'dialog');
            dialog.setAttribute('aria-modal', 'true');
            dialog.setAttribute('aria-label', 'Executable source SQL');

            const header = document.createElement('div');
            header.className = 'source-sql-header';
            const title = document.createElement('div');
            title.className = 'source-sql-title';
            title.innerText = source;
            const closeButton = document.createElement('button');
            closeButton.type = 'button';
            closeButton.className = 'btn btn-sm btn-outline-secondary';
            closeButton.innerText = 'Close';
            closeButton.addEventListener('click', () => overlay.remove());
            header.appendChild(title);
            header.appendChild(closeButton);

            const pre = document.createElement('pre');
            pre.className = 'source-sql-code';
            pre.innerText = sql;

            dialog.appendChild(header);
            dialog.appendChild(pre);
            overlay.appendChild(dialog);
            overlay.addEventListener('click', (event) => {
                if (event.target === overlay) {
                    overlay.remove();
                }
            });
            document.body.appendChild(overlay);
            closeButton.focus();
        }

        function formatAttributeLabel(value) {
            return String(value)
                .replace(/_/g, ' ')
                .replace(/\b\w/g, (match) => match.toUpperCase());
        }

        function setMessage(id, text, cssClass) {
            const el = document.getElementById(id);
            el.className = cssClass;
            el.innerText = text;
        }
    </script>
}
