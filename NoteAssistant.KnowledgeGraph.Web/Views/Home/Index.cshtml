            graphResetStyleBtn: 'Reset graph settings to the defaults for the selected engine.'
        });

        const uploadBtn = document.getElementById('uploadBtn');
        const uploadCacheBtn = document.getElementById('uploadCacheBtn');
        const uploadedDocumentsList = document.getElementById('uploadedDocumentsList');
        const selectAllDocsBtn = document.getElementById('selectAllDocsBtn');
        const clearSelectedDocsBtn = document.getElementById('clearSelectedDocsBtn');
