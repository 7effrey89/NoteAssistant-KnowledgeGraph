        });
        updateCommunityConfigOutput();
        setCommunityFurtherTuningAvailability(false);
        communityLoadProfilesBtn.addEventListener('click', () => loadCommunityProfiles(true));
        communityContinueBtn.addEventListener('click', onCommunityContinueClicked);
        communityPostTuneBtn.addEventListener('click', (event) => tuneCommunityProfile('post-build', event.currentTarget));
        communityRevertProfileBtn.addEventListener('click', cancelCommunityPostBuildActions);
        communityProceedBuildBtn.addEventListener('click', (event) => proceedCommunityBuild(event.currentTarget));
        communityTuneBeforeBuildBtn.addEventListener('click', (event) => tuneCommunityProfile('pre-build', event.currentTarget));
