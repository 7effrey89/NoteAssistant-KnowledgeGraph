        const graphActionDescriptions = Object.freeze({
            querySidebarToggleBtn: 'Collapse or expand the query tools column so the graph and results area can use more width.',
            graphSettingsToggleBtn: 'Collapse or expand the graph settings pane so the graph canvas can use more space.',
