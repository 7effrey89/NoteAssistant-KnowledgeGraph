            physicsSpringLength: 'Set the preferred distance between connected nodes in force and hierarchy layouts.',
            physicsGravity: 'Tune how strongly layouts pull nodes toward the center.',
            layoutQuality: 'Choose the speed/detail tradeoff for layouts that support quality modes.',
            layoutDirection: 'Choose the direction used by hierarchical layouts such as Dagre, ELK, and breadthfirst.',
            layoutPadding: 'Set empty space around the graph when a layout fits the viewport.',
            layoutSpacing: 'Scale spacing between nodes for layouts that support spacing.',
            animateLayout: 'Animate layout changes instead of jumping directly to new positions.',
            autoFitLayout: 'Automatically fit the graph into the viewport after layout runs.',
            showNodeLabels: 'Show or hide node labels.',
            nodeTextInside: 'Render node labels inside node shapes when supported by the selected engine.',
            showEdgeLabels: 'Show or hide relationship labels on edges.',
            showArrows: 'Show or hide edge direction arrows.',
            highlightNeighborhood: 'In Cytoscape.js, keep related nodes and edges prominent and dim unrelated graph items. vis-network uses its native selection behavior.'
