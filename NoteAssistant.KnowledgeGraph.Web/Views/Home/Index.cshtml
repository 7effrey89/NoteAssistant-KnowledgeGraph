@{
    ViewData["Title"] = "Knowledge Graph Workbench";
    var backendBaseUrl = (string?)ViewData["BackendBaseUrl"] ?? "https://localhost:7228";
}

<div class="container py-3">
    <h1 class="mb-4">Knowledge Graph Workbench</h1>

    <div class="alert alert-info">
        <div class="d-flex flex-wrap align-items-center gap-2">
            <span>Backend endpoint: <code id="backendBaseUrl">@backendBaseUrl</code></span>
            <span class="d-flex align-items-center gap-1">
                <span id="backendLamp" class="status-lamp"></span>
                <small id="backendStatusText" class="text-muted">Checking backend...</small>
            </span>
            <label class="d-flex align-items-center gap-1 ms-auto mb-0">
                <span class="small text-muted">LLM parallelism</span>
                <input class="form-control form-control-sm parallelism-input" type="number" id="llmParallelismInput" min="1" max="8" value="2" />
            </label>
        </div>
    </div>
    <div id="ageStatus" class="alert alert-warning d-none"></div>

    <div class="card mb-4">
        <div class="card-header">0) Optional: Reset PostgreSQL (dev only)</div>
        <div class="card-body">
            <p class="text-muted small mb-2">Drops the AGE graph, the graph schema, the kg_data schema (documents, chunks, entities, chunk_entities), the public fallback tables (documents, chunks, entities, chunk_entities), the AGE extension (ag_catalog), and clears the cache for document-to-entity breakdown.</p>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-outline-danger" id="resetDbBtn">Reset database</button>
                <button class="btn btn-outline-secondary" id="initScriptBtn">Run init script</button>
            </div>
            <div class="mt-2"><small id="resetDbMessage" class="text-muted">Use with caution.</small></div>
            <div class="mt-3">
                <div class="small text-muted">Init script output</div>
                <pre id="initScriptOutput" class="mt-2 p-2 bg-light border rounded" style="max-height: 240px; overflow:auto;"></pre>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">1) Upload document(s)</div>
        <div class="card-body">
            <div class="upload-tabs-panel">
                <ul class="nav nav-tabs" id="uploadTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="upload-markdown-tab" data-bs-toggle="tab" data-bs-target="#upload-markdown-pane" type="button" role="tab" aria-controls="upload-markdown-pane" aria-selected="true">Markdown</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="upload-cache-tab" data-bs-toggle="tab" data-bs-target="#upload-cache-pane" type="button" role="tab" aria-controls="upload-cache-pane" aria-selected="false">Cache JSON</button>
                    </li>
                </ul>
                <div class="tab-content border border-top-0 p-3 upload-tab-content">
                    <div class="tab-pane fade show active" id="upload-markdown-pane" role="tabpanel" aria-labelledby="upload-markdown-tab">
                        <div class="input-group">
                            <input class="form-control" type="file" id="markdownFile" accept=".md" multiple />
                            <button class="btn btn-primary" id="uploadBtn">Upload</button>
                        </div>
                        <div class="form-text">Select one or more markdown files. Use the file list below to view each document and manage metadata.</div>
                    </div>
                    <div class="tab-pane fade" id="upload-cache-pane" role="tabpanel" aria-labelledby="upload-cache-tab">
                        <div class="input-group">
                            <input class="form-control" type="file" id="cacheFile" accept=".json,application/json" multiple />
                            <button class="btn btn-outline-primary" id="uploadCacheBtn">Upload Cache</button>
                        </div>
                        <div class="form-text">Select one or more cache/analysis JSON files. This loads saved decomposition and skips Foundry/LLM processing.</div>
                    </div>
                </div>
            </div>
            <div class="mt-2"><small id="uploadMessage" class="text-muted"></small></div>
            <ul class="upload-batch-results mt-2 mb-0" id="uploadBatchResults"></ul>

            <div class="row g-3 document-workbench-layout mt-1">
                <div class="col-lg-3">
                    <div class="uploaded-documents-panel h-100">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                            <strong>Selected files</strong>
                            <div class="d-flex flex-wrap gap-2">
                                <button class="btn btn-sm btn-outline-secondary" type="button" id="selectAllDocsBtn">Select all</button>
                                <button class="btn btn-sm btn-outline-secondary" type="button" id="clearSelectedDocsBtn">Clear</button>
                            </div>
                        </div>
                        <div id="uploadedDocumentsList" class="uploaded-documents-list text-muted small">Upload one or more files to manage document-specific decomposition and metadata.</div>
                    </div>
                </div>
                <div class="col-lg-9">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div id="statusOutput" class="mb-0 flex-grow-1"></div>
                        <span id="cachedBadge" class="badge bg-warning text-dark" style="display:none;">cached</span>
                    </div>

                    <ul class="nav nav-tabs" id="documentWorkflowTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="tab-original-btn" data-bs-toggle="tab" data-bs-target="#tab-original" type="button" role="tab">Original Document</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link disabled text-muted" id="tab-decomp-btn" data-bs-toggle="tab" data-bs-target="#tab-decomp" type="button" role="tab" aria-controls="tab-decomp" aria-selected="false" aria-disabled="true" title="Run Decompose documents to enable this tab." disabled>
                                <span id="tab-decomp-status-icon" class="decomp-tab-status-icon decomp-tab-status-warning" aria-hidden="true">&#9888;</span>
                                <span>Decomposition</span>
                            </button>
                        </li>
                    </ul>
                    <div class="tab-content border border-top-0 p-3">
                        <div class="tab-pane fade show active" id="tab-original" role="tabpanel">
                            <pre id="originalContent" style="max-height: 480px; overflow:auto; white-space: pre-wrap;" class="mb-0">Upload a document to see its raw markdown here.</pre>
                        </div>
                        <div class="tab-pane fade decomposition-scroll-panel" id="tab-decomp" role="tabpanel" aria-labelledby="tab-decomp-btn">
                            <details class="mb-3 decomposition-prompt-details" open>
                                <summary>Graph Maker Agent (System Prompt)</summary>
                                <pre id="graphMakerSystemPrompt" class="decomposition-prompt mb-0">Decompose a document to see the system prompt used for Graph Maker Agent.</pre>
                            </details>
                            <details class="mb-3 decomposition-prompt-details" open>
                                <summary>Graph Maker Agent (Input Prompt)</summary>
                                <pre id="graphMakerInputPrompt" class="decomposition-prompt mb-0">Decompose a document to see the full input prompt sent to Graph Maker Agent.</pre>
                            </details>
                            <ul class="nav nav-pills decomposition-subtabs" id="decompositionSubtabs" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="tab-chunks-btn" data-bs-toggle="tab" data-bs-target="#tab-chunks" type="button" role="tab" aria-controls="tab-chunks" aria-selected="true">Chunks</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="tab-entities-btn" data-bs-toggle="tab" data-bs-target="#tab-entities" type="button" role="tab" aria-controls="tab-entities" aria-selected="false">Entities</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="tab-links-btn" data-bs-toggle="tab" data-bs-target="#tab-links" type="button" role="tab" aria-controls="tab-links" aria-selected="false">Links</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="tab-relationships-btn" data-bs-toggle="tab" data-bs-target="#tab-relationships" type="button" role="tab" aria-controls="tab-relationships" aria-selected="false">Relationships</button>
                                </li>
                            </ul>
                            <div class="tab-content decomposition-subtab-content">
                                <div class="tab-pane fade show active" id="tab-chunks" role="tabpanel" aria-labelledby="tab-chunks-btn">
                                    <ul id="chunksOutput" class="mb-0"></ul>
                                </div>
                                <div class="tab-pane fade" id="tab-entities" role="tabpanel" aria-labelledby="tab-entities-btn">
                                    <ul id="entitiesOutput" class="mb-0"></ul>
                                </div>
                                <div class="tab-pane fade" id="tab-links" role="tabpanel" aria-labelledby="tab-links-btn">
                                    <ul id="mentionsOutput" class="mb-0"></ul>
                                </div>
                                <div class="tab-pane fade" id="tab-relationships" role="tabpanel" aria-labelledby="tab-relationships-btn">
                                    <ul id="relationshipsOutput" class="mb-0"></ul>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="metadata-panel mt-3">
                        <div class="fw-semibold mb-2">Metadata for viewed document</div>
                        <input class="d-none" id="noteAssistantMetadataFolderInput" type="file" webkitdirectory directory multiple accept=".json,application/json" />
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label" for="metadataDocumentType">Document type</label>
                                <select class="form-select" id="metadataDocumentType">
                                    <option value="">(select)</option>
                                    <option value="transcription">Transcription</option>
                                    <option value="meeting_summary">Meeting summary</option>
                                    <option value="product_notes">Product notes</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="metadataDocumentDate">Document date</label>
                                <input class="form-control" type="date" id="metadataDocumentDate" />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label" for="metadataTags">Tags (comma-separated)</label>
                                <input class="form-control" id="metadataTags" placeholder="e.g. power bi, external sharing" />
                            </div>
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
                            <button class="btn btn-primary btn-sm" type="button" id="applyMetadataBtn" disabled>Apply metadata to selected documents</button>
                            <button class="btn btn-outline-primary btn-sm" type="button" id="noteAssistantDbImportBtn">noteassistant db import</button>
                            <small id="metadataMessage" class="text-muted">Select uploaded documents, define metadata, then apply it to that subset.</small>
                        </div>
                        <div class="mt-2 text-muted small">Metadata drafts are remembered as you switch viewed documents. Applying metadata updates the selected checked documents.</div>
                    </div>

                    <div class="d-flex justify-content-center mt-3">
                        <button class="btn btn-success" type="button" id="runDecompositionBtn" disabled>Decompose documents</button>
                    </div>
                    <div class="mt-2 text-center">
                        <small id="decompositionStepMessage" class="text-muted">Complete decomposition to continue to Section 3.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">3) Ingest into PostgreSQL (relational)</div>
        <div class="card-body">
            <p class="text-muted small mb-2">Stores documents, chunks, entities, and embeddings in PostgreSQL. Requires <code>ConnectionStrings:AgeDatabase</code>.</p>
            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary" id="ingestBtn" disabled>Ingest all to PostgreSQL</button>
                <button class="btn btn-outline-secondary" id="ingestSqlBtn" disabled>Show SQL</button>
                <button class="btn btn-outline-secondary" id="ingestLogBtn" disabled>Refresh log</button>
            </div>
            <div class="mt-2"><small id="ingestMessage" class="text-muted">Upload a document first.</small></div>
            <ul class="upload-batch-results mt-2 mb-0" id="ingestBatchResults"></ul>
            <details class="mt-3">
                <summary>Ingest SQL</summary>
                <pre id="ingestSqlOutput" class="mt-2 p-2 bg-light border rounded" style="max-height: 240px; overflow:auto;"></pre>
            </details>
            <details class="mt-2">
                <summary>Ingest execution log</summary>
                <pre id="ingestLogOutput" class="mt-2 p-2 bg-light border rounded" style="max-height: 240px; overflow:auto;"></pre>
            </details>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">4) Build Apache AGE graph</div>
        <div class="card-body">
            <p class="text-muted small mb-2">Creates (if needed) and populates the AGE graph with the current document.</p>
            <button class="btn btn-outline-primary" id="initGraphBtn" disabled>Build graph</button>
            <div class="mt-2"><small id="initGraphMessage" class="text-muted">Upload a document first.</small></div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">5) Query editor + graph explorer</div>
        <div class="card-body">
            <div class="row g-3 query-workbench-layout">
                <div class="col-lg-3 query-workbench-sidebar">
                    <div class="query-sidebar-panel">
                        <div class="query-sidebar-header">
                            <div class="query-sidebar-title">Query tools</div>
                            <button class="btn btn-sm btn-outline-secondary query-sidebar-toggle" type="button" id="querySidebarToggleBtn" aria-expanded="true" aria-controls="querySidebarContent">Minimize</button>
                        </div>
                        <div id="querySidebarContent" class="query-sidebar-content">
                            <div class="mb-2">
                                <label class="form-label" for="assistantPrompt">Assistant prompt</label>
                                <div class="assistant-prompt-group">
                                    <textarea class="form-control" id="assistantPrompt" rows="3" placeholder="e.g. show all chunks and mentioned entities"></textarea>
                                    <button class="btn btn-outline-primary" id="assistBtn">Suggest query</button>
                                </div>
                                <div class="mt-2 d-flex flex-column gap-2">
                                    <span class="text-muted small">Quick prompts:</span>
                                    <button class="btn btn-sm btn-outline-secondary text-start" type="button" id="quickPrompt1">Show all chunks with entities</button>
                                    <button class="btn btn-sm btn-outline-secondary text-start" type="button" id="quickPrompt2">Find entities related to Power BI</button>
                                    <button class="btn btn-sm btn-outline-secondary text-start" type="button" id="quickPrompt3">List documents and chunk counts</button>
                                </div>
                                <small class="text-muted" id="assistExplanation"></small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label" for="queryInput">Cypher query</label>
                                <textarea id="queryInput" class="form-control" rows="12"></textarea>
                            </div>
                            <button class="btn btn-success w-100" id="runQueryBtn">Run query</button>
                        </div>
                    </div>
                </div>
                <div class="col-lg-9 query-workbench-main">
                    <div id="queryError" class="text-danger mb-2"></div>
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                        <div id="graphCheckStatus" class="text-muted small flex-grow-1">Graph counts not loaded.</div>
                        <button class="btn btn-sm btn-outline-secondary" id="graphCheckBtn">Refresh counts</button>
                    </div>
                    <details class="query-workbench-details mb-2">
                        <summary>Cypher results</summary>
                        <div class="table-responsive query-results-panel mt-2">
                            <table class="table table-sm table-bordered mb-0" id="resultsTable"></table>
                        </div>
                    </details>
                    <details class="query-workbench-details mb-2" open>
                        <summary>Graph</summary>
                        <div class="graph-workbench mt-2">
                            <aside class="graph-settings-pane" aria-label="Graph visual settings">
                                <div class="graph-settings-header">
                                    <div class="graph-settings-title">Graph settings</div>
                                    <button class="btn btn-sm btn-outline-secondary graph-settings-toggle" type="button" id="graphSettingsToggleBtn" aria-expanded="true" aria-controls="graphSettingsContent">Minimize</button>
                                </div>
                                <div id="graphSettingsContent" class="graph-settings-content">
                                <div class="graph-settings-grid">
                                    <div>
                                        <label class="form-label" for="graphEngineSelect">Engine</label>
                                        <select class="form-select form-select-sm" id="graphEngineSelect" data-graph-setting="engine">
                                            <option value="cytoscape" selected>Cytoscape.js</option>
                                            <option value="vis">vis-network</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphLayoutSelect">Layout</label>
                                        <select class="form-select form-select-sm" id="graphLayoutSelect" data-graph-setting="layout">
                                            <optgroup label="Discrete">
                                                <option value="grid">Grid</option>
                                                <option value="circle">Circle</option>
                                                <option value="concentric">Concentric</option>
                                                <option value="breadthfirst">Breadthfirst</option>
                                                <option value="random">Random</option>
                                            </optgroup>
                                            <optgroup label="Force-directed">
                                                <option value="visDefault">Original vis-network</option>
                                                <option value="physics">Physics simulation</option>
                                                <option value="fcose">fCoSE</option>
                                                <option value="cose" selected>CoSE</option>
                                                <option value="cose-bilkent">CoSE-Bilkent</option>
                                                <option value="cola">Cola</option>
                                            </optgroup>
                                            <optgroup label="Hierarchical">
                                                <option value="dagre">Dagre</option>
                                                <option value="elk">ELK</option>
                                                <option value="cise">CiSE</option>
                                            </optgroup>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphColorModeSelect">Color</label>
                                        <select class="form-select form-select-sm" id="graphColorModeSelect" data-graph-setting="colorMode">
                                            <option value="kind">By kind</option>
                                            <option value="legacyVis" selected>Legacy vis-network</option>
                                            <option value="type">By label</option>
                                            <option value="degree">By degree</option>
                                            <option value="neutral">Neutral</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphNodeScaleRange">Node size</label>
                                        <input class="form-range" type="range" id="graphNodeScaleRange" min="0.7" max="1.8" step="0.1" value="1" data-graph-setting="nodeScale" />
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphEdgeWidthRange">Edge width</label>
                                        <input class="form-range" type="range" id="graphEdgeWidthRange" min="1" max="6" step="1" value="2" data-graph-setting="edgeWidth" />
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphPhysicsStrengthRange">Physics strength</label>
                                        <input class="form-range" type="range" id="graphPhysicsStrengthRange" min="0.5" max="2.5" step="0.1" value="1" data-graph-setting="physicsStrength" />
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphPhysicsSpringRange">Spring length</label>
                                        <input class="form-range" type="range" id="graphPhysicsSpringRange" min="60" max="220" step="10" value="110" data-graph-setting="physicsSpringLength" />
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphPhysicsGravityRange">Gravity</label>
                                        <input class="form-range" type="range" id="graphPhysicsGravityRange" min="0.1" max="1.5" step="0.1" value="0.7" data-graph-setting="physicsGravity" />
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphLayoutQualitySelect">Quality</label>
                                        <select class="form-select form-select-sm" id="graphLayoutQualitySelect" data-graph-setting="layoutQuality">
                                            <option value="draft">Draft</option>
                                            <option value="default">Default</option>
                                            <option value="proof" selected>Proof</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphLayoutDirectionSelect">Direction</label>
                                        <select class="form-select form-select-sm" id="graphLayoutDirectionSelect" data-graph-setting="layoutDirection">
                                            <option value="TB" selected>Top to bottom</option>
                                            <option value="LR">Left to right</option>
                                            <option value="BT">Bottom to top</option>
                                            <option value="RL">Right to left</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphLayoutPaddingRange">Padding</label>
                                        <input class="form-range" type="range" id="graphLayoutPaddingRange" min="10" max="90" step="5" value="35" data-graph-setting="layoutPadding" />
                                    </div>
                                    <div>
                                        <label class="form-label" for="graphLayoutSpacingRange">Spacing</label>
                                        <input class="form-range" type="range" id="graphLayoutSpacingRange" min="0.8" max="2.4" step="0.1" value="1.35" data-graph-setting="layoutSpacing" />
                                    </div>
                                </div>
                                <div class="graph-settings-checks">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="graphAnimateLayoutToggle" checked data-graph-setting="animateLayout" />
                                        <label class="form-check-label" for="graphAnimateLayoutToggle">Animate layout</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="graphAutoFitLayoutToggle" checked data-graph-setting="autoFitLayout" />
                                        <label class="form-check-label" for="graphAutoFitLayoutToggle">Auto fit layout</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="graphNodeLabelsToggle" checked data-graph-setting="showNodeLabels" />
                                        <label class="form-check-label" for="graphNodeLabelsToggle">Node labels</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="graphNodeTextInsideToggle" data-graph-setting="nodeTextInside" />
                                        <label class="form-check-label" for="graphNodeTextInsideToggle">Text inside nodes</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="graphEdgeLabelsToggle" checked data-graph-setting="showEdgeLabels" />
                                        <label class="form-check-label" for="graphEdgeLabelsToggle">Edge labels</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="graphArrowsToggle" checked data-graph-setting="showArrows" />
                                        <label class="form-check-label" for="graphArrowsToggle">Direction arrows</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="graphHighlightToggle" checked data-graph-setting="highlightNeighborhood" />
                                        <label class="form-check-label" for="graphHighlightToggle">Highlight neighborhood</label>
                                    </div>
                                </div>
                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    <button class="btn btn-sm btn-outline-secondary" type="button" id="graphZoomInBtn">Zoom in</button>
                                    <button class="btn btn-sm btn-outline-secondary" type="button" id="graphZoomOutBtn">Zoom out</button>
                                    <button class="btn btn-sm btn-outline-secondary" type="button" id="graphFitBtn">Fit</button>
                                    <button class="btn btn-sm btn-outline-secondary" type="button" id="graphCenterBtn">Center</button>
                                    <button class="btn btn-sm btn-outline-secondary" type="button" id="graphRelayoutBtn">Re-layout</button>
                                    <button class="btn btn-sm btn-outline-secondary" type="button" id="graphSelectionLayoutBtn">Layout selection</button>
                                    <button class="btn btn-sm btn-outline-secondary" type="button" id="graphBackgroundForceBtn">Start force</button>
                                    <button class="btn btn-sm btn-outline-secondary" type="button" id="graphResetStyleBtn">Reset</button>
                                </div>
                                <div id="graphRenderStats" class="graph-render-stats text-muted small mt-2">Run a query to render a graph.</div>
                                </div>
                            </aside>
                            <div id="graphView" class="query-graph-view"></div>
                        </div>
                    </details>
                </div>
            </div>
            <details id="graphSelectionDetails" class="graph-selection-details mt-3">
                <summary id="graphSelectionSummary">Selected graph item details</summary>
                <div id="graphSelectionContent" class="graph-selection-content text-muted small">Click a node or edge in the graph to inspect it.</div>
            </details>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">6) Build Graph Communities (Optional - needed for Global Search in GraphRAG)</div>
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                <div>
                    <div class="fw-semibold">Build Communities</div>
                    <div class="text-muted small">Optional. Needed for Global / Temporal GraphRAG search. Builds community summaries and embeddings from the entity relationship graph.</div>
                </div>
                <button class="btn btn-outline-primary" type="button" id="buildCommunitiesBtn">Build Communities</button>
            </div>
            <details class="community-tuning-panel mb-3" open>
                <summary class="fw-semibold">Community tuning</summary>
                <div class="row g-3 mt-1">
                    <div class="col-md-4 col-xl-3">
                        <label class="form-label d-flex align-items-center gap-2" for="communityResolutionInput">
                            <span>CPM resolution</span>
                            <span class="community-config-info" title="Leiden CPM granularity. Higher values usually create more/smaller communities; lower values create fewer/larger communities.">i</span>
                        </label>
                        <input class="form-control form-control-sm community-config-input" type="number" id="communityResolutionInput" min="0.001" max="2" step="0.01" value="0.25" />
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label class="form-label d-flex align-items-center gap-2" for="communityTypedWeightInput">
                            <span>Typed relationship weight</span>
                            <span class="community-config-info" title="Strength multiplier for explicit extracted relationships between entities. Higher values make typed edges influence clustering more.">i</span>
                        </label>
                        <input class="form-control form-control-sm community-config-input" type="number" id="communityTypedWeightInput" min="0.01" max="20" step="0.1" value="2.0" />
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label class="form-label d-flex align-items-center gap-2" for="communityCoMentionWeightInput">
                            <span>Co-mention weight</span>
                            <span class="community-config-info" title="Strength multiplier for co-mention links inferred from chunk/document co-occurrence. Higher values make co-mentions influence clustering more.">i</span>
                        </label>
                        <input class="form-control form-control-sm community-config-input" type="number" id="communityCoMentionWeightInput" min="0.01" max="20" step="0.1" value="1.0" />
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label class="form-label d-flex align-items-center gap-2" for="communitySeedInput">
                            <span>Seed</span>
                            <span class="community-config-info" title="Random seed used by community detection. Keep fixed for reproducible comparisons across tuning runs.">i</span>
                        </label>
                        <input class="form-control form-control-sm community-config-input" type="number" id="communitySeedInput" min="0" step="1" value="42" />
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label class="form-label d-flex align-items-center gap-2" for="communityMinSizeInput">
                            <span>Min summary size</span>
                            <span class="community-config-info" title="Minimum entity count required for a community to be summarized. Higher values skip smaller communities.">i</span>
                        </label>
                        <input class="form-control form-control-sm community-config-input" type="number" id="communityMinSizeInput" min="1" max="1000" step="1" value="2" />
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label class="form-label d-flex align-items-center gap-2" for="communityMaxSummariesInput">
                            <span>Max summaries</span>
                            <span class="community-config-info" title="Upper bound on how many communities to summarize in one build. Lower values limit cost; higher values increase coverage.">i</span>
                        </label>
                        <input class="form-control form-control-sm community-config-input" type="number" id="communityMaxSummariesInput" min="1" max="500" step="1" value="50" />
                    </div>
                    <div class="col-md-4 col-xl-3 d-flex align-items-end">
                        <div class="form-check form-switch mb-1">
                            <input class="form-check-input community-config-input" type="checkbox" role="switch" id="communityDirectedInput" />
                            <label class="form-check-label d-flex align-items-center gap-2" for="communityDirectedInput">
                                <span>Directed graph</span>
                                <span class="community-config-info" title="When enabled, edge direction is preserved in clustering. Keep off unless direction is semantically important for your relationships.">i</span>
                            </label>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="community-fields-divider" role="separator" aria-hidden="true"></div>
                    </div>
                    <div class="col-12 col-xl-6 community-profile-column">
                        <div class="d-flex justify-content-between align-items-center">
                            <label class="form-label mb-1" for="communityProfileList">Persisted tuning profiles</label>
                            <button class="btn btn-sm btn-outline-secondary" type="button" id="communityLoadProfilesBtn">Reload</button>
                        </div>
                        <div id="communityProfileList" class="community-profile-list" role="listbox" aria-label="Persisted tuning profiles"></div>
                    </div>
                    <div class="col-12 col-xl-6 community-config-column">
                        <div class="form-text community-config-description" id="communityProfileMeta">Loading community profiles...</div>
                        <label class="form-label d-flex align-items-center gap-2" for="communityConfigOutput">
                            <span>Agent config JSON</span>
                            <span class="community-config-info" title="Effective community tuning profile used for build/tune requests. It controls Leiden clustering behavior and summary scope (CPM resolution, relation weights, seed, min size, and max summaries).">i</span>
                        </label>
                        <textarea class="form-control community-config-output" id="communityConfigOutput" rows="8" readonly></textarea>
                    </div>
                </div>
            </details>
            <div id="communityError" class="text-danger mb-2"></div>
            <h6>Process map</h6>
            <div id="communityProcessMap" class="process-map"></div>
            <div id="communityPreBuildGate" class="alert alert-warning py-2 px-3 mt-3 d-none">
                <div class="fw-semibold small">Build paused after Leiden review.</div>
                <div class="small mb-2" id="communityPreBuildMessage">Review detected communities, then choose whether to clear/rebuild the index or tune first.</div>
                <div id="communityPreBuildAssessment" class="small mb-2"></div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-sm btn-success" type="button" id="communityProceedBuildBtn">Proceed to clear index and summarize</button>
                    <button class="btn btn-sm btn-primary" type="button" id="communityTuneBeforeBuildBtn">Tune profile first</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="communityCancelBuildBtn">Cancel</button>
                </div>
            </div>
            <div id="communityPostBuildActions" class="alert alert-secondary py-2 px-3 mt-3 d-none">
                <div class="fw-semibold small">Community optimization finished.</div>
                <div class="small mb-2" id="communityPostBuildMessage">Build the community with the current profile, continue with further tuning, or cancel.</div>
                <div class="small mb-2"><small id="communityStatus" class="text-muted"></small></div>
                <div id="communityQuickAssessment" class="small mb-2"></div>
                <details id="communityFinalProfileDetails" class="mb-2 d-none">
                    <summary class="small fw-semibold">Final profile JSON (analysis output)</summary>
                    <pre id="communityFinalProfileJson" class="mb-0 mt-2"></pre>
                </details>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-sm btn-success" type="button" id="communityContinueBtn">Build Community</button>
                    <span id="communityPostTuneBtnWrapper" title="">
                        <button class="btn btn-sm btn-primary" type="button" id="communityPostTuneBtn">Further Tuning</button>
                    </span>
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="communityRevertProfileBtn">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">7) Hybrid GraphRAG (Graph context → Hybrid retrieval → LLM context)</div>
        <div class="card-body">
            <div class="mb-2">
                <label class="form-label" for="hybridQuestion">Question</label>
                <div class="input-group">
                    <input class="form-control" id="hybridQuestion" value="What did Microsoft do with OpenAI?" />
                    <button class="btn btn-primary" id="runHybridBtn">Run Hybrid Retrieval</button>
                </div>
                <div class="mt-2 d-flex flex-wrap gap-2 align-items-center">
                    <label class="form-label mb-0" for="hybridModeSelect">Mode</label>
                    <button
                        class="btn btn-sm btn-outline-secondary rounded-circle p-0"
                        id="hybridModeInfoBtn"
                        type="button"
                        aria-label="How to choose Hybrid GraphRAG mode"
                        title="Mode guide"
                        style="width:1.4rem;height:1.4rem;line-height:1.2rem;">
                        i
                    </button>
                    <select class="form-select form-select-sm" id="hybridModeSelect" style="max-width: 220px;">
                        <option value="auto" selected>Auto</option>
                        <option value="local">Local / Entity-first</option>
                        <option value="light">Light / Parallel-friendly</option>
                        <option value="path">Path / Multi-hop</option>
                        <option value="global">Global / Temporal</option>
                    </select>
                </div>
                <div class="mt-2 d-flex flex-wrap gap-2">
                    <span class="text-muted small">Quick questions:</span>
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="hybridQuick1">Can F8 support them?</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="hybridQuick2">What is the meeting about?</button>
                    <button class="btn btn-sm btn-outline-secondary" type="button" id="hybridQuick3">What were the key takeaways?</button>
                </div>
                <div class="mt-2"><small id="hybridStatus" class="text-muted"></small></div>
                <div class="mt-2">
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="hybridTraceToggle" checked />
                        <label class="form-check-label" for="hybridTraceToggle">Show retrieval trace</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" id="hybridAnswerToggle" checked />
                        <label class="form-check-label" for="hybridAnswerToggle">Ask LLM for answer</label>
                    </div>
                </div>
            </div>
            <div id="hybridError" class="text-danger mb-2"></div>
            <h6>Process map</h6>
            <div id="hybridProcessMap" class="process-map"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
    <script src="https://unpkg.com/cytoscape/dist/cytoscape.min.js"></script>
