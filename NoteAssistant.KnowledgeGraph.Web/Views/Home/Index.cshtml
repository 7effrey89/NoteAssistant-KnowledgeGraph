        function setQuickPrompt(text) {
            document.getElementById('assistantPrompt').value = text;
        }

        function setHybridQuickQuestion(text) {
            document.getElementById('hybridQuestion').value = text;
        }

        function getMetadataPayload() {
            return {
                documentType: metadataDocumentType.value.trim(),
                documentDate: metadataDocumentDate.value.trim(),
                tags: metadataTags.value.trim()
            };
        }

        function setMetadataForm(metadata) {
            isSettingMetadataForm = true;
            metadataDocumentType.value = metadata?.documentType || '';
            metadataDocumentDate.value = metadata?.documentDate || '';
            metadataTags.value = Array.isArray(metadata?.tags) ? metadata.tags.join(', ') : (metadata?.tags || '');
            isSettingMetadataForm = false;
        }

        function normalizeMetadataDraft(metadata) {
            return {
                documentType: metadata?.documentType || '',
                documentDate: metadata?.documentDate || '',
                tags: Array.isArray(metadata?.tags) ? metadata.tags.join(', ') : (metadata?.tags || '')
            };
        }

        function getMetadataImportAdapter() {
            const customAdapter = window.noteAssistantMetadataImportAdapter;
            if (customAdapter && typeof customAdapter === 'object') {
                return customAdapter;
            }

            return {
                toFieldValues: defaultNoteAssistantMetadataToFields,
                applyToUi: defaultApplyMetadataFieldsToUi
            };
        }

        function defaultNoteAssistantMetadataToFields(files) {
            const parsedDates = files
                .map(file => normalizeNoteAssistantDate(file.folderCreationDate))
                .filter(Boolean);
            const uniqueDates = Array.from(new Set(parsedDates));
            const sortedDates = [...uniqueDates].sort((left, right) => left.localeCompare(right));
            const selectedDate = sortedDates.length > 0 ? sortedDates[sortedDates.length - 1] : '';
            const customers = Array.from(new Set(files.flatMap(file => Array.isArray(file.customers) ? file.customers : []).filter(Boolean)));
            const services = Array.from(new Set(files.flatMap(file => Array.isArray(file.services) ? file.services : []).filter(Boolean)));
            const tags = [];
            customers.forEach(customer => tags.push(`customer:${customer}`));
            services.forEach(service => tags.push(`service:${service}`));

            return {
                documentType: 'meeting_summary',
                documentDate: selectedDate,
                tags: tags.join(', '),
                summary: {
                    fileCount: files.length,
                    customerCount: customers.length,
                    serviceCount: services.length,
                    dateCount: uniqueDates.length
                }
            };
        }

        function defaultApplyMetadataFieldsToUi(fieldValues) {
            setMetadataForm({
                documentType: fieldValues?.documentType || '',
                documentDate: fieldValues?.documentDate || '',
                tags: fieldValues?.tags || ''
            });
            onMetadataFieldChanged();
        }

        function normalizeNoteAssistantDate(value) {
            if (!value) {
                return '';
            }

            const input = String(value).trim();
            const fromIsoMatch = input.match(/^(\d{4})-(\d{2})-(\d{2})/);
            if (fromIsoMatch) {
                return `${fromIsoMatch[1]}-${fromIsoMatch[2]}-${fromIsoMatch[3]}`;
            }

            const fromDashedYearFirst = input.match(/^(\d{4})-(\d{1,2})-(\d{1,2})(?:\s+\d{1,2}[.:]\d{1,2}(?:[.:]\d{1,2})?)?$/);
            if (fromDashedYearFirst) {
                const month = fromDashedYearFirst[2].padStart(2, '0');
                const day = fromDashedYearFirst[3].padStart(2, '0');
                return `${fromDashedYearFirst[1]}-${month}-${day}`;
            }

            const fromDashedDayFirst = input.match(/^(\d{1,2})-(\d{1,2})-(\d{2,4})(?:\s+\d{1,2}[.:]\d{1,2}(?:[.:]\d{1,2})?)?$/);
            if (fromDashedDayFirst) {
                const day = fromDashedDayFirst[1].padStart(2, '0');
                const month = fromDashedDayFirst[2].padStart(2, '0');
                const rawYear = fromDashedDayFirst[3];
                const year = rawYear.length === 2 ? `20${rawYear}` : rawYear;
                return `${year}-${month}-${day}`;
            }

            const fromDotMatch = input.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
            if (fromDotMatch) {
                const day = fromDotMatch[1].padStart(2, '0');
                const month = fromDotMatch[2].padStart(2, '0');
                return `${fromDotMatch[3]}-${month}-${day}`;
            }

            const fromSlashedDayFirst = input.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})(?:\s+\d{1,2}:\d{1,2}(?::\d{1,2})?)?$/);
            if (fromSlashedDayFirst) {
                const day = fromSlashedDayFirst[1].padStart(2, '0');
                const month = fromSlashedDayFirst[2].padStart(2, '0');
                const rawYear = fromSlashedDayFirst[3];
                const year = rawYear.length === 2 ? `20${rawYear}` : rawYear;
                return `${year}-${month}-${day}`;
            }

            const parsed = new Date(input);
            if (!Number.isNaN(parsed.getTime())) {
                const year = parsed.getFullYear();
                const month = String(parsed.getMonth() + 1).padStart(2, '0');
                const day = String(parsed.getDate()).padStart(2, '0');
                return `${year}-${month}-${day}`;
            }

            return '';
        }

        function getJsonStringProperty(obj, keys) {
            if (!obj || typeof obj !== 'object') {
                return '';
            }

            for (const key of keys) {
                const value = obj[key];
                if (typeof value === 'string' && value.trim()) {
                    return value.trim();
                }
            }

            return '';
        }

        function getBaseName(path) {
            return String(path || '')
                .split(/[\\/]/)
                .pop() || '';
        }

        function normalizeMetadataMatchKey(value) {
            if (!value) {
                return '';
            }

            let normalized = String(value).trim().toLowerCase();
            normalized = normalized.replace(/\.(md|json)$/i, '');
            normalized = normalized.replace(/_metadata$/i, '');
            normalized = normalized.replace(/(_summary|_transcript|_mynotes)$/i, '');
            normalized = normalized.replace(/\s+-\s+(summary|transcript|mynotes)$/i, '');
            normalized = normalized.replace(/\s+/g, ' ').trim();
            return normalized;
        }

        function getDocumentMatchKey(plan) {
            if (!plan) {
                return '';
            }

            return normalizeMetadataMatchKey(plan.status?.fileName || plan.title || '');
        }

        function getMetadataFileMatchKeys(file) {
            const keys = new Set();
            const noteSessionKey = normalizeMetadataMatchKey(file?.noteSession || '');
            const fileNameKey = normalizeMetadataMatchKey(getBaseName(file?.fileName || ''));
            if (noteSessionKey) {
                keys.add(noteSessionKey);
            }
            if (fileNameKey) {
                keys.add(fileNameKey);
            }
            return Array.from(keys);
        }

        function selectMetadataFilesForDocument(metadataFiles, plan, options = {}) {
            const allowFallbackAll = Boolean(options.allowFallbackAll);
            const documentKey = getDocumentMatchKey(plan);
            if (!documentKey) {
                return {
                    files: allowFallbackAll ? metadataFiles : [],
                    mode: allowFallbackAll ? 'all-no-document' : 'no-document-key',
                    documentKey,
                    matchedCount: allowFallbackAll ? metadataFiles.length : 0
                };
            }

            const matched = metadataFiles.filter((file) => {
                const keys = getMetadataFileMatchKeys(file);
                return keys.some(key => key === documentKey || key.includes(documentKey) || documentKey.includes(key));
            });

            if (matched.length > 0) {
                return {
                    files: matched,
                    mode: 'matched',
                    documentKey,
                    matchedCount: matched.length
                };
            }

            return {
                files: allowFallbackAll ? metadataFiles : [],
                mode: allowFallbackAll ? 'fallback-all' : 'no-match',
                documentKey,
                matchedCount: 0
            };
        }

        function formatUsedFileNames(files, maxCount = 3) {
            const names = files.map(file => getBaseName(file?.fileName || '')).filter(Boolean);
            if (names.length === 0) {
                return '(none)';
            }

            const preview = names.slice(0, maxCount).join(', ');
            if (names.length <= maxCount) {
                return preview;
            }

            return `${preview} (+${names.length - maxCount} more)`;
        }

        async function onNoteAssistantDbImportClicked() {
            if (!noteAssistantMetadataFolderInput) {
                return;
            }

            noteAssistantMetadataFolderInput.value = '';
            noteAssistantMetadataFolderInput.click();
        }

        async function onNoteAssistantMetadataFolderSelected() {
            const files = Array.from(noteAssistantMetadataFolderInput?.files || []);
            if (files.length === 0) {
                return;
            }

            setMessage('metadataMessage', `Reading ${files.length} selected file(s)...`, 'text-muted');

            const metadataFiles = [];
            for (const file of files) {
                if (!file.name.toLowerCase().endsWith('_metadata.json')) {
                    continue;
                }

                try {
                    const text = await file.text();
                    const json = JSON.parse(text);
                    const folderCreationDate = getJsonStringProperty(json, [
                        'FolderCreationDate',
                        'folderCreationDate',
                        'FolderCreatedDate',
                        'folderCreatedDate',
                        'CreationDate',
                        'creationDate'
                    ]);
                    metadataFiles.push({
                        fileName: file.webkitRelativePath || file.name,
                        noteSession: typeof json.NoteSession === 'string' ? json.NoteSession.trim() : '',
                        folderCreationDate,
                        customers: Array.isArray(json.Customers) ? json.Customers.filter(Boolean) : [],
                        services: Array.isArray(json.Services) ? json.Services.filter(Boolean) : []
                    });
                } catch {
                    // Skip invalid metadata JSON files.
                }
            }

            if (metadataFiles.length === 0) {
                setMessage('metadataMessage', 'No *_metadata.json files were found in the selected folder.', 'text-warning');
                return;
            }

            const adapter = getMetadataImportAdapter();
            const uploadedPlans = Array.from(uploadedDocuments.values());
            if (uploadedPlans.length === 0) {
                // If nothing is uploaded yet, keep legacy behavior: populate the form from all selected metadata files.
                const fieldValues = typeof adapter.toFieldValues === 'function'
                    ? adapter.toFieldValues(metadataFiles)
                    : defaultNoteAssistantMetadataToFields(metadataFiles);

                if (typeof adapter.applyToUi === 'function') {
                    adapter.applyToUi(fieldValues, {
                        setMetadataForm,
                        onMetadataFieldChanged,
                        controls: {
                            metadataDocumentType,
                            metadataDocumentDate,
                            metadataTags
                        }
                    });
                } else {
                    defaultApplyMetadataFieldsToUi(fieldValues);
                }

                const summary = fieldValues?.summary || {};
                const dateNote = Number(summary.dateCount) > 1
                    ? ` Multiple dates detected; using latest FolderCreationDate (${fieldValues?.documentDate || 'n/a'}).`
                    : '';
                setMessage(
                    'metadataMessage',
                    `Imported metadata from ${summary.fileCount || metadataFiles.length} file(s) (customers: ${summary.customerCount || 0}, services: ${summary.serviceCount || 0}).${dateNote} Used file(s): ${formatUsedFileNames(metadataFiles)}.`,
                    'text-success');
                return;
            }

            let applied = 0;
            let failed = 0;
            const unmatched = [];
            const mappingNotes = [];

            for (const plan of uploadedPlans) {
                const selection = selectMetadataFilesForDocument(metadataFiles, plan, { allowFallbackAll: false });
                const metadataFilesForImport = selection.files;
                if (metadataFilesForImport.length === 0) {
                    unmatched.push(plan.status?.fileName || plan.title || `Document ${plan.documentId}`);
                    continue;
                }

                const fieldValues = typeof adapter.toFieldValues === 'function'
                    ? adapter.toFieldValues(metadataFilesForImport)
                    : defaultNoteAssistantMetadataToFields(metadataFilesForImport);
                const metadataPayload = {
                    documentType: fieldValues?.documentType || '',
                    documentDate: fieldValues?.documentDate || '',
                    tags: fieldValues?.tags || ''
                };

                if (!hasMetadataPayload(metadataPayload)) {
                    unmatched.push(plan.status?.fileName || plan.title || `Document ${plan.documentId}`);
                    continue;
                }

                metadataDrafts.set(plan.documentId, metadataPayload);

                let response;
                try {
                    response = await fetch(`${backendBaseUrl}/api/documents/metadata`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ documentIds: [plan.documentId], ...metadataPayload })
                    });
                } catch {
                    failed++;
                    continue;
                }

                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    failed++;
                    continue;
                }

                const updatedPlan = (payload?.updated || [])[0];
                if (updatedPlan) {
                    uploadedDocuments.set(updatedPlan.documentId, updatedPlan);
                    metadataDrafts.set(updatedPlan.documentId, normalizeMetadataDraft(updatedPlan.metadata));
                }

                applied++;
                mappingNotes.push(`${plan.status?.fileName || plan.title || `Document ${plan.documentId}`} <= ${formatUsedFileNames(metadataFilesForImport, 2)}`);
            }

            if (currentDocumentId && uploadedDocuments.has(currentDocumentId)) {
                showDocumentPlan(currentDocumentId, { loadMetadata: false });
            } else {
                renderUploadedDocuments();
            }

            const unmatchedNote = unmatched.length > 0
                ? ` Unmatched documents: ${unmatched.slice(0, 3).join(', ')}${unmatched.length > 3 ? ` (+${unmatched.length - 3} more)` : ''}.`
                : '';
            const mappingPreview = mappingNotes.length > 0
                ? ` Mappings: ${mappingNotes.slice(0, 3).join(' | ')}${mappingNotes.length > 3 ? ` | +${mappingNotes.length - 3} more` : ''}.`
                : '';

            const cssClass = failed > 0
                ? (applied > 0 ? 'text-warning' : 'text-danger')
                : (applied > 0 ? 'text-success' : 'text-warning');
            setMessage(
                'metadataMessage',
                `Imported NoteAssistant metadata applied to ${applied}/${uploadedPlans.length} uploaded documents.${failed > 0 ? ` Failed: ${failed}.` : ''}${unmatchedNote}${mappingPreview}`,
                cssClass);
        }

        function saveCurrentMetadataDraft() {
            if (!currentDocumentId) return;
            metadataDrafts.set(currentDocumentId, getMetadataPayload());
        }

        function onMetadataFieldChanged() {
            if (isSettingMetadataForm) {
                return;
            }

            saveCurrentMetadataDraft();
            queueAutoSaveCurrentMetadata();
        }

        function queueAutoSaveCurrentMetadata() {
            const documentId = currentDocumentId;
            if (!documentId) {
                return;
            }

            const metadata = getMetadataPayload();
            if (!hasMetadataPayload(metadata)) {
                return;
            }

            if (metadataAutoSaveTimer) {
                clearTimeout(metadataAutoSaveTimer);
            }

            metadataAutoSaveTimer = setTimeout(() => {
                metadataAutoSaveTimer = null;
                autoSaveMetadataForDocument(documentId, metadata);
            }, 450);
        }

        async function autoSaveMetadataForDocument(documentId, metadata) {
            const sequence = ++metadataAutoSaveSequence;
            setMessage('metadataMessage', `Saving metadata for document ${documentId}...`, 'text-muted');

            let response;
            try {
                response = await fetch(`${backendBaseUrl}/api/documents/metadata`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ documentIds: [documentId], ...metadata })
                });
            } catch (err) {
                if (sequence !== metadataAutoSaveSequence) {
                    return;
                }
                setMessage('metadataMessage', `Metadata auto-save failed: ${err.message}`, 'text-danger');
                return;
            }

            const payload = await response.json().catch(() => null);
            if (sequence !== metadataAutoSaveSequence) {
                return;
            }

            if (!response.ok) {
                setMessage('metadataMessage', (payload && (payload.error || payload.detail)) || `Metadata auto-save failed (status ${response.status}).`, 'text-danger');
                return;
            }

            const updatedPlan = (payload?.updated || [])[0];
            if (updatedPlan) {
                uploadedDocuments.set(updatedPlan.documentId, updatedPlan);
                metadataDrafts.set(updatedPlan.documentId, normalizeMetadataDraft(updatedPlan.metadata));
                if (currentDocumentId === updatedPlan.documentId) {
                    renderStatus(updatedPlan.status);
                }
                renderUploadedDocuments();
            }

            setMessage('metadataMessage', `Metadata auto-saved for document ${documentId}. Use the blue button only when you want bulk apply.`, 'text-success');
        }

        function hasMetadataPayload(metadata) {
            return Boolean(metadata.documentType || metadata.documentDate || metadata.tags);
        }

        function formatMetadataSummary(metadata) {
            const parts = [];
            if (metadata?.documentType) parts.push(metadata.documentType);
            if (metadata?.documentDate) parts.push(metadata.documentDate);
            if (Array.isArray(metadata?.tags) && metadata.tags.length) parts.push(metadata.tags.join(', '));
            return parts.length ? parts.join(' | ') : 'metadata not set';
        }

        function hasDecompositionData(plan) {
            return Boolean(
                plan
                && Array.isArray(plan.chunks)
                && plan.chunks.length > 0
                && Array.isArray(plan.entities)
                && Array.isArray(plan.mentions)
            );
        }

        function syncDecompositionStateFromUploadedPlans() {
            if (uploadedDocuments.size === 0) {
                decompositionStepCompleted = false;
                return;
            }

            decompositionStepCompleted = Array.from(uploadedDocuments.values()).every(hasDecompositionData);
        }

        function selectAllUploadedDocuments() {
            uploadedDocuments.forEach((_, id) => selectedDocumentIds.add(Number(id)));
            renderUploadedDocuments();
        }

        function clearSelectedDocuments() {
            selectedDocumentIds.clear();
            renderUploadedDocuments();
        }

        function normalizeDocumentPreviewText(value) {
            return String(value || '')
                .replace(/\r\n/g, '\n')
                .replace(/\r/g, '\n');
        }

        function showDocumentPlan(documentId, options = {}) {
            if (currentDocumentId && currentDocumentId !== Number(documentId)) {
                saveCurrentMetadataDraft();
            }

            const plan = uploadedDocuments.get(Number(documentId));
            if (!plan) return;

            syncDecompositionStateFromUploadedPlans();

            currentDocumentId = plan.documentId;
            if (plan.graphName) currentGraphName = plan.graphName;
            document.getElementById('cachedBadge').style.display = plan.cached ? 'inline-block' : 'none';
            const previewText = normalizeDocumentPreviewText(plan.originalContent);
            document.getElementById('originalContent').textContent = previewText || '(no original content returned)';
            if (decompositionStepCompleted) {
                setMessage('ingestMessage', `Ready to ingest document ${plan.documentId} (${plan.chunks.length} chunks, ${plan.entities.length} entities).`, 'text-muted');
                renderDecomposition(plan);
            } else {
                setMessage('ingestMessage', 'Run "Decompose documents" in Section 1 to unlock ingestion in Section 3.', 'text-muted');
            }
            if (decompositionStepCompleted) {
                setMessage('initGraphMessage', 'Ready to build graph for this document.', 'text-muted');
            } else {
                setMessage('initGraphMessage', 'Decomposition is not available for this document yet. Click "Decompose documents" to compute it.', 'text-muted');
            }
            renderStatus(plan.status);
            if (options.loadMetadata !== false) {
                setMetadataForm(metadataDrafts.get(plan.documentId) || normalizeMetadataDraft(plan.metadata));
            }
            renderUploadedDocuments();
            updateDecompositionWorkflowState();
        }

        function updateDecompositionWorkflowState() {
            syncDecompositionStateFromUploadedPlans();
            const hasUploadedDocuments = uploadedDocuments.size > 0;
            const canProceedToIngestion = hasUploadedDocuments && decompositionStepCompleted;

            if (runDecompositionBtn) {
                runDecompositionBtn.disabled = !hasUploadedDocuments;
            }
            if (tabDecompBtn) {
                tabDecompBtn.disabled = !decompositionStepCompleted;
                tabDecompBtn.classList.toggle('disabled', !decompositionStepCompleted);
                tabDecompBtn.classList.toggle('text-muted', !decompositionStepCompleted);
                if (decompositionStepCompleted) {
                    tabDecompBtn.removeAttribute('aria-disabled');
                    tabDecompBtn.title = 'Decomposition completed.';
                } else {
                    tabDecompBtn.setAttribute('aria-disabled', 'true');
                    tabDecompBtn.title = 'Run Decompose documents to enable this tab.';
                }
            }
            if (tabDecompStatusIcon) {
                if (decompositionStepCompleted) {
                    tabDecompStatusIcon.innerHTML = '&#10003;';
                    tabDecompStatusIcon.classList.remove('decomp-tab-status-warning');
                    tabDecompStatusIcon.classList.add('decomp-tab-status-ready');
                } else {
                    tabDecompStatusIcon.innerHTML = '&#9888;';
                    tabDecompStatusIcon.classList.remove('decomp-tab-status-ready');
                    tabDecompStatusIcon.classList.add('decomp-tab-status-warning');
                }
            }
            if (!decompositionStepCompleted && tabOriginalBtn && window.bootstrap?.Tab) {
                window.bootstrap.Tab.getOrCreateInstance(tabOriginalBtn).show();
            }

            ingestBtn.disabled = !canProceedToIngestion;
            ingestSqlBtn.disabled = !canProceedToIngestion;
            ingestLogBtn.disabled = !canProceedToIngestion;
            initGraphBtn.disabled = !canProceedToIngestion;

            if (!hasUploadedDocuments) {
                decompositionStepMessage.textContent = 'Upload documents first, then run decomposition to continue to Section 3.';
            } else if (!decompositionStepCompleted) {
                decompositionStepMessage.textContent = 'Some uploaded documents are missing decomposition data. Click "Decompose documents" to compute it.';
            } else {
                decompositionStepMessage.textContent = 'Decomposition data is available. You can continue to Section 3 (rerun Decompose anytime to refresh).';
            }
        }

        async function onRunDecompositionClicked() {
            if (uploadedDocuments.size === 0) {
                setMessage('uploadMessage', 'Upload one or more documents before running decomposition.', 'text-danger');
                updateDecompositionWorkflowState();
                return;
            }

            saveCurrentMetadataDraft();
            setButtonLoading(runDecompositionBtn, true, 'Decomposing...');
            setMessage('uploadMessage', `Decomposing ${uploadedDocuments.size} document${uploadedDocuments.size === 1 ? '' : 's'} with current metadata...`, 'text-muted');

            const plans = Array.from(uploadedDocuments.values());
            let succeeded = 0;
            let failed = 0;
            let lastError = '';

            for (let index = 0; index < plans.length; index++) {
                const plan = plans[index];
                const metadataDraft = metadataDrafts.get(plan.documentId) || normalizeMetadataDraft(plan.metadata);
                setMessage('uploadMessage', `Decomposing ${index + 1}/${plans.length}: ${plan.status.fileName || plan.title || `Document ${plan.documentId}`}`, 'text-muted');

                let response;
                try {
                    response = await fetch(`${backendBaseUrl}/api/documents/${plan.documentId}/decompose`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(metadataDraft)
                    });
                } catch (err) {
                    failed++;
                    lastError = `Network error for document ${plan.documentId}: ${err.message}`;
                    continue;
                }

                const payload = await response.json().catch(() => null);
                if (!response.ok || !payload) {
                    failed++;
                    lastError = (payload && (payload.error || payload.detail)) || `Decomposition failed for document ${plan.documentId} (status ${response.status}).`;
                    continue;
                }

                succeeded++;
                uploadedDocuments.set(payload.documentId, payload);
                metadataDrafts.set(payload.documentId, normalizeMetadataDraft(payload.metadata));
            }

            decompositionStepCompleted = succeeded > 0;
            const activePlan = currentDocumentId ? uploadedDocuments.get(currentDocumentId) : null;
            const fallbackPlan = activePlan || uploadedDocuments.values().next().value;
            if (fallbackPlan && decompositionStepCompleted) {
                renderDecomposition(fallbackPlan);
                setMessage('ingestMessage', `Ready to ingest document ${fallbackPlan.documentId} (${fallbackPlan.chunks.length} chunks, ${fallbackPlan.entities.length} entities).`, 'text-muted');
            }

            renderUploadedDocuments();
            updateDecompositionWorkflowState();
            if (decompositionStepCompleted && tabDecompBtn && window.bootstrap?.Tab) {
                window.bootstrap.Tab.getOrCreateInstance(tabDecompBtn).show();
            }

            if (failed > 0) {
                const summaryClass = succeeded > 0 ? 'text-warning' : 'text-danger';
                const suffix = lastError ? ` Last error: ${lastError}` : '';
                setMessage('uploadMessage', `Decompose complete: ${succeeded} succeeded, ${failed} failed.${suffix}`, summaryClass);
            } else {
                setMessage('uploadMessage', `Decompose complete: ${succeeded} document${succeeded === 1 ? '' : 's'} updated with current metadata.`, 'text-success');
            }

            setButtonLoading(runDecompositionBtn, false);
        }

        function renderUploadedDocuments() {
            if (uploadedDocuments.size === 0) {
                uploadedDocumentsList.className = 'uploaded-documents-list text-muted small';
                uploadedDocumentsList.innerText = 'Upload one or more files to manage document-specific decomposition and metadata.';
                applyMetadataBtn.disabled = true;
                return;
            }

            uploadedDocumentsList.className = 'uploaded-documents-list';
            uploadedDocumentsList.innerHTML = '';
            const fragment = document.createDocumentFragment();
            uploadedDocuments.forEach((plan) => {
                const fileName = plan.status.fileName || plan.title || `Document ${plan.documentId}`;
                const metadataSummary = formatMetadataSummary(plan.metadata);
                const tooltipText = `${fileName}\nDocument ${plan.documentId}\n${plan.status.state}: ${plan.status.message || ''}\nMetadata: ${metadataSummary}`;
                const item = document.createElement('div');
                item.className = `uploaded-document-item${plan.documentId === currentDocumentId ? ' active' : ''}`;
                item.tabIndex = 0;
                item.role = 'button';
                item.title = tooltipText;
                item.setAttribute('aria-current', plan.documentId === currentDocumentId ? 'true' : 'false');
                item.setAttribute('aria-label', `View ${fileName}`);
                item.addEventListener('click', () => showDocumentPlan(plan.documentId));
                item.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        showDocumentPlan(plan.documentId);
                    }
                });

                const checkbox = document.createElement('input');
                checkbox.className = 'form-check-input';
                checkbox.type = 'checkbox';
                checkbox.checked = selectedDocumentIds.has(plan.documentId);
                checkbox.title = `Select ${fileName}`;
                checkbox.setAttribute('aria-label', `Select ${fileName}`);
                checkbox.addEventListener('click', (event) => event.stopPropagation());
                checkbox.addEventListener('change', () => {
                    if (checkbox.checked) selectedDocumentIds.add(plan.documentId);
                    else selectedDocumentIds.delete(plan.documentId);
                    renderUploadedDocuments();
                });

                const text = document.createElement('div');
                text.className = 'min-w-0';
                const title = document.createElement('div');
                title.className = 'uploaded-document-title';
                title.title = fileName;
                title.innerText = fileName;
                const meta = document.createElement('div');
                meta.className = 'uploaded-document-meta';
                meta.title = tooltipText;
                meta.innerText = `Document ${plan.documentId} | ${plan.status.state} | ${metadataSummary}`;
                text.appendChild(title);
                text.appendChild(meta);

                item.appendChild(checkbox);
                item.appendChild(text);
                fragment.appendChild(item);
            });
            uploadedDocumentsList.appendChild(fragment);
            applyMetadataBtn.disabled = selectedDocumentIds.size === 0;
            document.getElementById('metadataMessage').innerText = selectedDocumentIds.size === 0
                ? 'Select uploaded documents, define metadata, then apply it to that subset.'
                : `${selectedDocumentIds.size} document${selectedDocumentIds.size === 1 ? '' : 's'} selected for metadata update.`;
            document.getElementById('metadataMessage').className = 'text-muted';
        }

        function setBackendStatus(state, text) {
            backendLamp.className = `status-lamp status-lamp-${state}`;
            backendStatusText.innerText = text;
        }

        function resetUploadedDocumentsForNewBatch() {
            currentDocumentId = null;
            uploadedDocuments.clear();
            selectedDocumentIds.clear();
            metadataDrafts.clear();
            decompositionStepCompleted = false;

            document.getElementById('statusOutput').innerText = '';
            document.getElementById('cachedBadge').style.display = 'none';
            document.getElementById('originalContent').textContent = 'Upload a document to see its raw markdown here.';
            document.getElementById('graphMakerSystemPrompt').textContent = 'Decompose a document to see the system prompt used for Graph Maker Agent.';
            document.getElementById('graphMakerInputPrompt').textContent = 'Decompose a document to see the full input prompt sent to Graph Maker Agent.';
            renderList('chunksOutput', []);
            renderList('entitiesOutput', []);
            renderList('mentionsOutput', []);
            renderList('relationshipsOutput', []);
            setMetadataForm(null);
            renderUploadedDocuments();

            setMessage('metadataMessage', 'Select uploaded documents, define metadata, then apply it to that subset.', 'text-muted');
            setMessage('ingestMessage', 'Upload a document first.', 'text-muted');
            setMessage('initGraphMessage', 'Upload a document first.', 'text-muted');
            document.getElementById('ingestSqlOutput').innerText = '';
            document.getElementById('ingestLogOutput').innerText = '';
            ingestBatchResults.innerHTML = '';
