        const initScriptBtn = document.getElementById('initScriptBtn');
        const initScriptOutput = document.getElementById('initScriptOutput');
        const quickPrompt1 = document.getElementById('quickPrompt1');
        const quickPrompt2 = document.getElementById('quickPrompt2');
        const quickPrompt3 = document.getElementById('quickPrompt3');
        const hybridQuick1 = document.getElementById('hybridQuick1');
        const hybridQuick2 = document.getElementById('hybridQuick2');
        const hybridQuick3 = document.getElementById('hybridQuick3');
        const graphZoomInBtn = document.getElementById('graphZoomInBtn');
        const graphZoomOutBtn = document.getElementById('graphZoomOutBtn');
        const graphFitBtn = document.getElementById('graphFitBtn');
        const graphCenterBtn = document.getElementById('graphCenterBtn');
        const graphRelayoutBtn = document.getElementById('graphRelayoutBtn');
        const graphSelectionLayoutBtn = document.getElementById('graphSelectionLayoutBtn');
        const graphBackgroundForceBtn = document.getElementById('graphBackgroundForceBtn');
        const graphResetStyleBtn = document.getElementById('graphResetStyleBtn');
        const graphSettingsToggleBtn = document.getElementById('graphSettingsToggleBtn');
        const querySidebarToggleBtn = document.getElementById('querySidebarToggleBtn');

        uploadBtn.addEventListener('click', () => uploadFile(false));
        uploadCacheBtn.addEventListener('click', () => uploadFile(true));
        selectAllDocsBtn.addEventListener('click', selectAllUploadedDocuments);
        clearSelectedDocsBtn.addEventListener('click', clearSelectedDocuments);
        applyMetadataBtn.addEventListener('click', applyMetadataToSelectedDocuments);
        [metadataDocumentType, metadataDocumentDate, metadataTags].forEach((input) => {
            input.addEventListener('input', onMetadataFieldChanged);
            input.addEventListener('change', onMetadataFieldChanged);
        });
        ingestBtn.addEventListener('click', ingestToDatabase);
        ingestSqlBtn.addEventListener('click', loadIngestSql);
        ingestLogBtn.addEventListener('click', refreshIngestLog);
        initGraphBtn.addEventListener('click', initGraph);
        assistBtn.addEventListener('click', assistQuery);
        runQueryBtn.addEventListener('click', runQuery);
        runHybridBtn.addEventListener('click', runHybridRetrieval);
        buildCommunitiesBtn.addEventListener('click', buildCommunities);
        graphCheckBtn.addEventListener('click', refreshGraphCheck);
        resetDbBtn.addEventListener('click', resetDatabase);
        initScriptBtn.addEventListener('click', runInitScript);
        quickPrompt1.addEventListener('click', () => setQuickPrompt('Show all chunks with entities'));
        quickPrompt2.addEventListener('click', () => setQuickPrompt('Find entities related to Power BI'));
        quickPrompt3.addEventListener('click', () => setQuickPrompt('List documents and chunk counts'));
        hybridQuick1.addEventListener('click', () => setHybridQuickQuestion('Can F8 support them?'));
        hybridQuick2.addEventListener('click', () => setHybridQuickQuestion('What is the meeting about?'));
        hybridQuick3.addEventListener('click', () => setHybridQuickQuestion('What were the key takeaways?'));
        document.querySelectorAll('[data-graph-setting]').forEach((control) => {
            control.addEventListener('input', updateGraphSettingFromControl);
            control.addEventListener('change', updateGraphSettingFromControl);
        });
        graphZoomInBtn.addEventListener('click', () => zoomGraphView(1.2));
        graphZoomOutBtn.addEventListener('click', () => zoomGraphView(0.8));
        graphFitBtn.addEventListener('click', fitGraphView);
        graphCenterBtn.addEventListener('click', centerGraphView);
        graphRelayoutBtn.addEventListener('click', () => runGraphLayout(true));
        graphSelectionLayoutBtn.addEventListener('click', () => applyLayoutToSelectedNeighborhood());
        graphBackgroundForceBtn.addEventListener('click', toggleBackgroundForceLayout);
        graphResetStyleBtn.addEventListener('click', resetGraphSettings);
        graphSettingsToggleBtn.addEventListener('click', toggleGraphSettingsPane);
        querySidebarToggleBtn.addEventListener('click', toggleQuerySidebarPane);
        applyGraphSettingTooltips();
        updateBackgroundForceButton();

        document.getElementById('queryInput').value = `MATCH p=(n)-[r]->(m)\nRETURN n, r, m\nLIMIT 50`;
        window.addEventListener('load', () => {
            checkBackendStatus();
            loadGraphMakerAgentPrompt();
            setInterval(checkBackendStatus, 15000);
            loadGraphOnStartup();
        });

        function setQuickPrompt(text) {
            document.getElementById('assistantPrompt').value = text;
        }

        function setHybridQuickQuestion(text) {
            document.getElementById('hybridQuestion').value = text;
        }

        function getMetadataPayload() {
            return {
                documentType: metadataDocumentType.value.trim(),
                documentDate: metadataDocumentDate.value.trim(),
                tags: metadataTags.value.trim()
            };
        }

        function setMetadataForm(metadata) {
            isSettingMetadataForm = true;
            metadataDocumentType.value = metadata?.documentType || '';
            metadataDocumentDate.value = metadata?.documentDate || '';
            metadataTags.value = Array.isArray(metadata?.tags) ? metadata.tags.join(', ') : (metadata?.tags || '');
            isSettingMetadataForm = false;
        }

        function normalizeMetadataDraft(metadata) {
            return {
                documentType: metadata?.documentType || '',
                documentDate: metadata?.documentDate || '',
                tags: Array.isArray(metadata?.tags) ? metadata.tags.join(', ') : (metadata?.tags || '')
            };
        }

        function saveCurrentMetadataDraft() {
            if (!currentDocumentId) return;
            metadataDrafts.set(currentDocumentId, getMetadataPayload());
        }

        function onMetadataFieldChanged() {
            if (isSettingMetadataForm) {
                return;
            }

            saveCurrentMetadataDraft();
            queueAutoSaveCurrentMetadata();
        }

        function queueAutoSaveCurrentMetadata() {
            const documentId = currentDocumentId;
            if (!documentId) {
                return;
            }

            const metadata = getMetadataPayload();
            if (!hasMetadataPayload(metadata)) {
                return;
            }

            if (metadataAutoSaveTimer) {
                clearTimeout(metadataAutoSaveTimer);
            }

            metadataAutoSaveTimer = setTimeout(() => {
                metadataAutoSaveTimer = null;
                autoSaveMetadataForDocument(documentId, metadata);
            }, 450);
        }

        async function autoSaveMetadataForDocument(documentId, metadata) {
            const sequence = ++metadataAutoSaveSequence;
            setMessage('metadataMessage', `Saving metadata for document ${documentId}...`, 'text-muted');

            let response;
            try {
                response = await fetch(`${backendBaseUrl}/api/documents/metadata`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ documentIds: [documentId], ...metadata })
                });
            } catch (err) {
                if (sequence !== metadataAutoSaveSequence) {
                    return;
                }
                setMessage('metadataMessage', `Metadata auto-save failed: ${err.message}`, 'text-danger');
                return;
            }

            const payload = await response.json().catch(() => null);
            if (sequence !== metadataAutoSaveSequence) {
                return;
            }

            if (!response.ok) {
                setMessage('metadataMessage', (payload && (payload.error || payload.detail)) || `Metadata auto-save failed (status ${response.status}).`, 'text-danger');
                return;
            }

            const updatedPlan = (payload?.updated || [])[0];
            if (updatedPlan) {
                uploadedDocuments.set(updatedPlan.documentId, updatedPlan);
                metadataDrafts.set(updatedPlan.documentId, normalizeMetadataDraft(updatedPlan.metadata));
                if (currentDocumentId === updatedPlan.documentId) {
                    renderStatus(updatedPlan.status);
                }
                renderUploadedDocuments();
            }

            setMessage('metadataMessage', `Metadata auto-saved for document ${documentId}. Use the blue button only when you want bulk apply.`, 'text-success');
        }

        function hasMetadataPayload(metadata) {
            return Boolean(metadata.documentType || metadata.documentDate || metadata.tags);
        }

        function formatMetadataSummary(metadata) {
            const parts = [];
            if (metadata?.documentType) parts.push(metadata.documentType);
            if (metadata?.documentDate) parts.push(metadata.documentDate);
            if (Array.isArray(metadata?.tags) && metadata.tags.length) parts.push(metadata.tags.join(', '));
            return parts.length ? parts.join(' | ') : 'metadata not set';
        }

        function selectAllUploadedDocuments() {
            uploadedDocuments.forEach((_, id) => selectedDocumentIds.add(Number(id)));
            renderUploadedDocuments();
        }

        function clearSelectedDocuments() {
            selectedDocumentIds.clear();
            renderUploadedDocuments();
        }

        function showDocumentPlan(documentId, options = {}) {
            if (currentDocumentId && currentDocumentId !== Number(documentId)) {
                saveCurrentMetadataDraft();
            }

            const plan = uploadedDocuments.get(Number(documentId));
            if (!plan) return;

            currentDocumentId = plan.documentId;
            if (plan.graphName) currentGraphName = plan.graphName;
            document.getElementById('cachedBadge').style.display = plan.cached ? 'inline-block' : 'none';
            ingestBtn.disabled = false;
            ingestSqlBtn.disabled = false;
            ingestLogBtn.disabled = false;
            initGraphBtn.disabled = false;
            setMessage('ingestMessage', `Ready to ingest document ${plan.documentId} (${plan.chunks.length} chunks, ${plan.entities.length} entities).`, 'text-muted');
            setMessage('initGraphMessage', 'Ready to build graph for this document.', 'text-muted');
            renderDecomposition(plan);
            renderStatus(plan.status);
            if (options.loadMetadata !== false) {
                setMetadataForm(metadataDrafts.get(plan.documentId) || normalizeMetadataDraft(plan.metadata));
            }
            renderUploadedDocuments();
        }

        function renderUploadedDocuments() {
            if (uploadedDocuments.size === 0) {
                uploadedDocumentsList.className = 'uploaded-documents-list text-muted small';
                uploadedDocumentsList.innerText = 'Upload one or more files to manage document-specific decomposition and metadata.';
                applyMetadataBtn.disabled = true;
                return;
            }

            uploadedDocumentsList.className = 'uploaded-documents-list';
            uploadedDocumentsList.innerHTML = '';
            const fragment = document.createDocumentFragment();
            uploadedDocuments.forEach((plan) => {
                const fileName = plan.status.fileName || plan.title || `Document ${plan.documentId}`;
                const metadataSummary = formatMetadataSummary(plan.metadata);
                const tooltipText = `${fileName}\nDocument ${plan.documentId}\n${plan.status.state}: ${plan.status.message || ''}\nMetadata: ${metadataSummary}`;
                const item = document.createElement('div');
                item.className = `uploaded-document-item${plan.documentId === currentDocumentId ? ' active' : ''}`;
                item.tabIndex = 0;
                item.role = 'button';
                item.title = tooltipText;
                item.setAttribute('aria-current', plan.documentId === currentDocumentId ? 'true' : 'false');
                item.setAttribute('aria-label', `View ${fileName}`);
                item.addEventListener('click', () => showDocumentPlan(plan.documentId));
                item.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        showDocumentPlan(plan.documentId);
                    }
                });

                const checkbox = document.createElement('input');
                checkbox.className = 'form-check-input';
                checkbox.type = 'checkbox';
                checkbox.checked = selectedDocumentIds.has(plan.documentId);
                checkbox.title = `Select ${fileName}`;
                checkbox.setAttribute('aria-label', `Select ${fileName}`);
                checkbox.addEventListener('click', (event) => event.stopPropagation());
                checkbox.addEventListener('change', () => {
                    if (checkbox.checked) selectedDocumentIds.add(plan.documentId);
                    else selectedDocumentIds.delete(plan.documentId);
                    renderUploadedDocuments();
                });

                const text = document.createElement('div');
                text.className = 'min-w-0';
                const title = document.createElement('div');
                title.className = 'uploaded-document-title';
                title.title = fileName;
                title.innerText = fileName;
                const meta = document.createElement('div');
                meta.className = 'uploaded-document-meta';
                meta.title = tooltipText;
                meta.innerText = `Document ${plan.documentId} | ${plan.status.state} | ${metadataSummary}`;
                text.appendChild(title);
                text.appendChild(meta);

                item.appendChild(checkbox);
                item.appendChild(text);
                fragment.appendChild(item);
            });
            uploadedDocumentsList.appendChild(fragment);
            applyMetadataBtn.disabled = selectedDocumentIds.size === 0;
            document.getElementById('metadataMessage').innerText = selectedDocumentIds.size === 0
                ? 'Select uploaded documents, define metadata, then apply it to that subset.'
                : `${selectedDocumentIds.size} document${selectedDocumentIds.size === 1 ? '' : 's'} selected for metadata update.`;
            document.getElementById('metadataMessage').className = 'text-muted';
        }

        function setBackendStatus(state, text) {
            backendLamp.className = `status-lamp status-lamp-${state}`;
            backendStatusText.innerText = text;
        }

        function resetUploadedDocumentsForNewBatch() {
            currentDocumentId = null;
            uploadedDocuments.clear();
            selectedDocumentIds.clear();
            metadataDrafts.clear();

            document.getElementById('statusOutput').innerText = '';
            document.getElementById('cachedBadge').style.display = 'none';
            document.getElementById('originalContent').textContent = 'Upload a document to see its raw markdown here.';
            document.getElementById('decompositionSystemPrompt').textContent = 'Upload a document to see the prompt used for entity extraction.';
            renderList('chunksOutput', []);
            renderList('entitiesOutput', []);
            renderList('mentionsOutput', []);
            renderList('relationshipsOutput', []);
            setMetadataForm(null);
            renderUploadedDocuments();

            ingestBtn.disabled = true;
            ingestSqlBtn.disabled = true;
            ingestLogBtn.disabled = true;
            initGraphBtn.disabled = true;
            setMessage('metadataMessage', 'Select uploaded documents, define metadata, then apply it to that subset.', 'text-muted');
            setMessage('ingestMessage', 'Upload a document first.', 'text-muted');
            setMessage('initGraphMessage', 'Upload a document first.', 'text-muted');
            document.getElementById('ingestSqlOutput').innerText = '';
            document.getElementById('ingestLogOutput').innerText = '';
            ingestBatchResults.innerHTML = '';
        }

        async function checkBackendStatus() {
            setBackendStatus('warning', 'Checking backend...');
            try {
                const response = await fetch(`${backendBaseUrl}/api/health`);
                if (response.ok) {
                    setBackendStatus('online', 'Backend online');
                    return;
                }

                const payload = await response.json().catch(() => null);
                const detail = payload?.detail || payload?.error;
                setBackendStatus('warning', detail ? `Backend online: ${detail}` : `Backend online (status ${response.status}).`);
            } catch (err) {
                setBackendStatus('offline', `Backend offline: ${err.message}`);
            }
        }

        async function loadGraphMakerAgentPrompt() {
            const promptElement = document.getElementById('graphMakerAgentPrompt');
            promptElement.textContent = 'Loading Graph Maker Agent system prompt...';
            try {
                const response = await fetch(`${backendBaseUrl}/api/graph-maker-agent`);
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    promptElement.textContent = (payload && (payload.error || payload.detail)) || `Graph Maker Agent prompt unavailable (status ${response.status}).`;
                    return;
                }

                promptElement.textContent = payload?.systemPrompt || '(no system prompt returned)';
            } catch (err) {
                promptElement.textContent = `Graph Maker Agent prompt unavailable: ${err.message}`;
            }
        }

        async function uploadFile(cacheMode) {
            const fileInput = document.getElementById(cacheMode ? 'cacheFile' : 'markdownFile');
            const activeUploadButton = cacheMode ? uploadCacheBtn : uploadBtn;
            const files = Array.from(fileInput.files || []);
            const resultsList = document.getElementById('uploadBatchResults');
            resultsList.innerHTML = '';

            if (files.length === 0) {
                setMessage('uploadMessage', `Please select at least one ${cacheMode ? 'cache analysis .json' : '.md'} file first.`, 'text-danger');
                return;
            }

            const expectedExtension = cacheMode ? '.json' : '.md';
            const invalidFiles = files.filter(file => !file.name.toLowerCase().endsWith(expectedExtension));
            if (invalidFiles.length > 0) {
                setMessage('uploadMessage', `Only ${expectedExtension} files are supported in this mode. Remove: ${invalidFiles.map(file => file.name).join(', ')}.`, 'text-danger');
                return;
            }

            activeUploadButton.disabled = true;
            resetUploadedDocumentsForNewBatch();
            setMessage('uploadMessage', cacheMode
                ? `Uploading ${files.length} cache file${files.length === 1 ? '' : 's'} without LLM processing...`
                : `Uploading and analyzing ${files.length} file${files.length === 1 ? '' : 's'}...`, 'text-muted');

            let succeeded = 0;
            let failed = 0;
            for (let index = 0; index < files.length; index++) {
                const file = files[index];
                const resultItem = appendUploadBatchResult(file.name, 'Uploading...', 'text-muted');
                setMessage('uploadMessage', `${cacheMode ? 'Loading cache' : 'Analyzing'} ${index + 1}/${files.length}: ${file.name}`, 'text-muted');

                const result = await uploadSingleFile(file, cacheMode);
                if (result.ok) {
                    succeeded++;
                    handleUploadSuccess(result.payload);
                    const statusMessage = result.payload.cached
                        ? `Document ${result.payload.documentId} loaded from cache (${result.payload.status.state}). Analysis step skipped by duplicate/content-hash handling.`
                        : `Document ${result.payload.documentId} analyzed (${result.payload.status.state}).`;
                    updateUploadBatchResult(resultItem, statusMessage, result.payload.cached ? 'text-warning' : 'text-success');
                } else {
                    failed++;
                    updateUploadBatchResult(resultItem, result.error, 'text-danger');
                }
            }

            activeUploadButton.disabled = false;
            const summaryClass = failed > 0 ? (succeeded > 0 ? 'text-warning' : 'text-danger') : 'text-success';
            setMessage('uploadMessage', `Batch complete: ${succeeded} succeeded, ${failed} failed. See detailed file results above.`, summaryClass);
        }

        async function uploadSingleFile(file, cacheMode) {
            const formData = new FormData();
            formData.append('file', file);
            const metadata = getMetadataPayload();
            formData.append('documentType', metadata.documentType || '');
            formData.append('documentDate', metadata.documentDate || '');
            formData.append('tags', metadata.tags || '');

            let response;
            try {
                response = await fetch(`${backendBaseUrl}${cacheMode ? '/api/documents/upload-cache' : '/api/documents/upload'}`, {
                    method: 'POST',
                    body: formData
                });
            } catch (err) {
                console.error('Upload network error', err);
                return { ok: false, error: `Network error calling ${backendBaseUrl}: ${err.message}. Check the backend is running and CORS allows ${window.location.origin}.` };
            }

            let payload;
            try {
                payload = await response.json();
            } catch (err) {
                console.error('Upload parse error', err, response.status);
                return { ok: false, error: `Backend returned non-JSON (status ${response.status}).` };
            }

            if (!response.ok) {
                return { ok: false, error: payload.error || `Upload failed with status ${response.status}.` };
            }

            return { ok: true, payload };
        }

        function handleUploadSuccess(payload) {
            uploadedDocuments.set(payload.documentId, payload);
            selectedDocumentIds.add(payload.documentId);
            showDocumentPlan(payload.documentId);
        }

        function appendUploadBatchResult(fileName, message, cssClass) {
            return appendBatchResult(document.getElementById('uploadBatchResults'), fileName, message, cssClass);
        }

        function appendBatchResult(list, fileName, message, cssClass) {
            const item = document.createElement('li');
            const name = document.createElement('strong');
            const status = document.createElement('span');
            name.innerText = fileName;
            status.className = cssClass;
            status.innerText = message;
            item.appendChild(name);
            item.appendChild(document.createTextNode(': '));
            item.appendChild(status);
            list.appendChild(item);
            return item;
        }

        function updateUploadBatchResult(item, message, cssClass) {
            const status = item.querySelector('span');
            status.className = cssClass;
            status.innerText = message;
        }

        async function applyMetadataToSelectedDocuments() {
            saveCurrentMetadataDraft();
            const documentIds = Array.from(selectedDocumentIds);
            if (documentIds.length === 0) {
                setMessage('metadataMessage', 'Select one or more uploaded documents first.', 'text-danger');
                return;
            }

            const metadata = getMetadataPayload();
            if (!hasMetadataPayload(metadata)) {
                setMessage('metadataMessage', 'Define at least one metadata field before applying.', 'text-danger');
                return;
            }

            applyMetadataBtn.disabled = true;
            setMessage('metadataMessage', `Applying metadata to ${documentIds.length} document${documentIds.length === 1 ? '' : 's'}...`, 'text-muted');
            let response;
            try {
                response = await fetch(`${backendBaseUrl}/api/documents/metadata`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ documentIds, ...metadata })
                });
            } catch (err) {
                setMessage('metadataMessage', `Metadata update failed: ${err.message}`, 'text-danger');
                applyMetadataBtn.disabled = false;
                renderUploadedDocuments();
                return;
            }

            const payload = await response.json().catch(() => null);
            if (!response.ok) {
                setMessage('metadataMessage', (payload && (payload.error || payload.detail)) || `Metadata update failed (status ${response.status}).`, 'text-danger');
                applyMetadataBtn.disabled = false;
                renderUploadedDocuments();
                return;
            }

            (payload.updated || []).forEach((plan) => {
                uploadedDocuments.set(plan.documentId, plan);
                metadataDrafts.set(plan.documentId, normalizeMetadataDraft(plan.metadata));
            });
            if (currentDocumentId && uploadedDocuments.has(currentDocumentId)) {
                showDocumentPlan(currentDocumentId, { loadMetadata: false });
            } else {
                renderUploadedDocuments();
            }

            const missing = payload.missing || [];
            const suffix = missing.length ? ` (${missing.length} missing: ${missing.join(', ')})` : '';
            setMessage('metadataMessage', `Metadata applied to ${(payload.updated || []).length} document${(payload.updated || []).length === 1 ? '' : 's'}.${suffix}`, missing.length ? 'text-warning' : 'text-success');
            applyMetadataBtn.disabled = selectedDocumentIds.size === 0;
        }

        async function ingestToDatabase() {
            const plans = Array.from(uploadedDocuments.values());
            if (plans.length === 0) {
                setMessage('ingestMessage', 'Upload one or more documents first.', 'text-danger');
                return;
            }

            ingestBatchResults.innerHTML = '';
            ingestBtn.disabled = true;
            let succeeded = 0;
            let failed = 0;
            let skipped = 0;

            for (let index = 0; index < plans.length; index++) {
                const plan = plans[index];
                const label = plan.status.fileName || plan.title || `Document ${plan.documentId}`;
                setMessage('ingestMessage', `Ingesting ${index + 1} of ${plans.length}: ${label}`, 'text-muted');
                const resultItem = appendBatchResult(ingestBatchResults, label, 'Ingesting...', 'text-muted');
                let response;
                try {
                    response = await fetch(`${backendBaseUrl}/api/documents/${plan.documentId}/ingest`, { method: 'POST' });
                } catch (err) {
                    failed++;
                    updateUploadBatchResult(resultItem, `Failed: ${err.message}`, 'text-danger');
                    continue;
                }

                let payload;
                try { payload = await response.json(); } catch { payload = null; }
                if (!response.ok) {
                    failed++;
                    updateUploadBatchResult(resultItem, `Failed: ${(payload && (payload.error || payload.detail)) || `status ${response.status}`}`, 'text-danger');
                    continue;
                }

                if (payload?.graphName) {
                    currentGraphName = payload.graphName;
                }
                if (payload?.documentId) {
                    uploadedDocuments.set(payload.documentId, payload);
                    if (payload.documentId === currentDocumentId) {
                        renderStatus(payload.status);
                    }
                }

                if ((payload?.status?.state || '').toLowerCase() === 'skipped') {
                    skipped += 1;
                    updateUploadBatchResult(resultItem, `Skipped: ${payload?.status?.message || 'No changes were applied.'}`, 'text-warning');
                } else {
                    succeeded += 1;
                    updateUploadBatchResult(resultItem, `Succeeded: ${payload?.status?.message || 'Ingest completed.'}`, 'text-success');
                }
            }

            renderUploadedDocuments();
            if (currentDocumentId && uploadedDocuments.has(currentDocumentId)) {
                showDocumentPlan(currentDocumentId, { loadMetadata: false });
            }

            const hasIssues = failed > 0;
            const messageClass = hasIssues ? ((succeeded + skipped) > 0 ? 'text-warning' : 'text-danger') : 'text-success';
            setMessage('ingestMessage', `Ingest batch complete: ${succeeded} succeeded, ${skipped} skipped, ${failed} failed.`, messageClass);
            ingestBtn.disabled = false;
            await refreshIngestLog();
        }

        async function loadIngestSql() {
            if (!currentDocumentId) {
                return;
            }

            const output = document.getElementById('ingestSqlOutput');
            output.innerText = 'Loading SQL…';
            try {
                const response = await fetch(`${backendBaseUrl}/api/documents/${currentDocumentId}/ingest/preview`);
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    output.innerText = (payload && (payload.error || payload.detail)) || `Failed to load SQL (status ${response.status}).`;
                    return;
                }

                const relational = payload.relationalStatements || [];
                const graph = payload.graphStatements || [];
                const lines = [];
                lines.push('-- Relational statements');
                relational.forEach((stmt, idx) => lines.push(`-- ${idx + 1}\n${stmt}`));
                lines.push('');
                lines.push('-- Graph statements');
                graph.forEach((stmt, idx) => lines.push(`-- ${idx + 1}\n${stmt}`));
                output.innerText = lines.join('\n');
            } catch (err) {
                output.innerText = `Failed to load SQL: ${err.message}`;
            }
        }

        async function refreshIngestLog() {
            if (!currentDocumentId) {
                return;
            }

            const output = document.getElementById('ingestLogOutput');
            output.innerText = 'Loading log…';
            try {
                const response = await fetch(`${backendBaseUrl}/api/documents/${currentDocumentId}/ingest/log`);
                const payload = await response.json().catch(() => null);
                if (!response.ok) {
                    output.innerText = (payload && (payload.error || payload.detail)) || `Failed to load log (status ${response.status}).`;
                    return;
                }

                const lines = [];
                lines.push(`Started: ${payload.startedAt}`);
                lines.push(`Completed: ${payload.completedAt || 'n/a'}`);
                lines.push(`Statements: ${payload.succeededStatements}/${payload.totalStatements} succeeded, ${payload.failedStatements} failed`);
                (payload.steps || []).forEach((step) => {
                    const status = step.success ? 'ok' : 'fail';
                    lines.push(`[${status}] #${step.index} ${step.statementType} (${step.durationMs}ms)`);
                    if (step.error) {
                        lines.push(`  error: ${step.error}`);
                    }
                    lines.push(`  ${step.statement}`);
                });
                output.innerText = lines.join('\n');
            } catch (err) {
                output.innerText = `Failed to load log: ${err.message}`;
            }
        }

