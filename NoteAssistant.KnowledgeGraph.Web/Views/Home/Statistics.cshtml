@{
    ViewData["Title"] = "Token Statistics";
    var backendBaseUrl = (string)(ViewData["BackendBaseUrl"] ?? "http://localhost:5070");
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Token Statistics</h1>
        <div class="text-muted">LLM input/output token usage by timestamp, agent, and operation.</div>
    </div>
    <div class="d-flex align-items-center gap-2">
        <label class="form-label mb-0" for="daysSelect">Range</label>
        <select class="form-select form-select-sm" id="daysSelect" style="width: 120px;">
            <option value="1">1 day</option>
            <option value="7">7 days</option>
            <option value="30" selected>30 days</option>
            <option value="90">90 days</option>
            <option value="365">365 days</option>
        </select>
        <button class="btn btn-sm btn-primary" id="refreshBtn" type="button">Refresh</button>
    </div>
</div>

<div id="statsError" class="text-danger mb-2"></div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">Calls</div><div class="h4 mb-0" id="callsTotal">-</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">Input Tokens</div><div class="h4 mb-0" id="promptTotal">-</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">Output Tokens</div><div class="h4 mb-0" id="completionTotal">-</div></div></div>
    </div>
    <div class="col-md-3">
        <div class="card h-100"><div class="card-body"><div class="text-muted small">Total Tokens</div><div class="h4 mb-0" id="tokensTotal">-</div></div></div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
        <span>Model Pricing (User Local)</span>
        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-sm btn-outline-secondary" id="addPricingRowBtn" type="button">Add Row</button>
            <button class="btn btn-sm btn-primary" id="savePricingBtn" type="button">Save Pricing</button>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end mb-3">
            <div class="col-md-5">
                <label class="form-label" for="activePricingSelect">Active model pricing row for estimate</label>
                <select class="form-select form-select-sm" id="activePricingSelect"></select>
            </div>
            <div class="col-md-7">
                <div class="alert alert-info mb-0 py-2 px-3">
                    <div class="small">Estimated range cost</div>
                    <div class="fw-semibold" id="estimatedCostTotal">-</div>
                    <div class="small text-muted" id="estimatedCostBreakdown"></div>
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead>
                    <tr>
                        <th>Region</th>
                        <th>Model</th>
                        <th>Currency</th>
                        <th class="text-end">Input / 1M</th>
                        <th class="text-end">Cached Input / 1M</th>
                        <th class="text-end">Output / 1M</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody id="pricingRows"><tr><td colspan="7" class="text-muted">Loading pricing...</td></tr></tbody>
            </table>
        </div>
        <div class="form-text mt-2">Pricing is stored in your local user app data folder. Cached input pricing is stored but not applied in the estimate because cached token counts are not currently tracked in usage logs.</div>
        <div class="small text-muted mt-1" id="pricingSaveStatus"></div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Usage By Agent</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead><tr><th>Agent</th><th>Operation</th><th class="text-end">Calls</th><th class="text-end">Input</th><th class="text-end">Output</th><th class="text-end">Total</th><th>Last Seen</th></tr></thead>
                <tbody id="agentRows"><tr><td colspan="7" class="text-muted">Loading...</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Daily Usage</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead><tr><th>Day</th><th class="text-end">Calls</th><th class="text-end">Input Tokens</th><th class="text-end">Output Tokens</th><th class="text-end">Total Tokens</th><th class="text-end">Estimated Cost</th></tr></thead>
                <tbody id="dailyRows"><tr><td colspan="6" class="text-muted">Loading...</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">Recent Calls</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead><tr><th>Timestamp</th><th>Agent</th><th>Operation</th><th>Model</th><th class="text-end">Input</th><th class="text-end">Output</th><th class="text-end">Total</th></tr></thead>
                <tbody id="recentRows"><tr><td colspan="7" class="text-muted">Loading...</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const backendBaseUrl = '@backendBaseUrl';
    const fmt = new Intl.NumberFormat();
    const decimalFmt = new Intl.NumberFormat(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    let pricingRows = [];
    let summaryStats = { promptTokens: 0, completionTokens: 0, totalTokens: 0 };
    let dailyStats = [];
    let activePricingId = '';

    document.getElementById('refreshBtn').addEventListener('click', loadStats);
    document.getElementById('daysSelect').addEventListener('change', loadStats);
    document.getElementById('addPricingRowBtn').addEventListener('click', addPricingRow);
    document.getElementById('savePricingBtn').addEventListener('click', savePricingRows);
    document.getElementById('activePricingSelect').addEventListener('change', event => {
        activePricingId = event.target.value;
        renderCostEstimate();
        renderDailyRows(dailyStats);
    });
    document.getElementById('pricingRows').addEventListener('input', onPricingTableInput);
    document.getElementById('pricingRows').addEventListener('click', onPricingTableClick);
    initialize();

    async function initialize() {
        await loadPricingRows();
        await loadStats();
    }

    async function loadStats() {
        const days = document.getElementById('daysSelect').value;
        const error = document.getElementById('statsError');
        error.textContent = '';
        try {
            const response = await fetch(`${backendBaseUrl}/api/tokens/stats?days=${encodeURIComponent(days)}`);
            const payload = await response.json();
            if (!response.ok) {
                throw new Error(payload.detail || payload.error || 'Failed to load token statistics.');
            }

            document.getElementById('callsTotal').textContent = fmt.format(payload.summary.calls || 0);
            document.getElementById('promptTotal').textContent = fmt.format(payload.summary.promptTokens || 0);
            document.getElementById('completionTotal').textContent = fmt.format(payload.summary.completionTokens || 0);
            document.getElementById('tokensTotal').textContent = fmt.format(payload.summary.totalTokens || 0);
            summaryStats = {
                promptTokens: payload.summary.promptTokens || 0,
                completionTokens: payload.summary.completionTokens || 0,
                totalTokens: payload.summary.totalTokens || 0
            };
            dailyStats = payload.daily || [];
            renderAgentRows(payload.byAgent || []);
            renderDailyRows(dailyStats);
            renderRecentRows(payload.recent || []);
            renderCostEstimate();
        } catch (err) {
            error.textContent = err.message;
        }
    }

    async function loadPricingRows() {
        const status = document.getElementById('pricingSaveStatus');
        try {
            const response = await fetch(`${backendBaseUrl}/api/tokens/pricing`);
            const payload = await response.json();
            if (!response.ok) {
                throw new Error(payload.detail || payload.error || 'Failed to load token pricing.');
            }

            pricingRows = Array.isArray(payload.rows) ? payload.rows : [];
            if (!pricingRows.length) {
                addPricingRow();
            }

            if (!pricingRows.some(row => row.id === activePricingId)) {
                activePricingId = pricingRows[0]?.id || '';
            }

            renderPricingRows();
            renderPricingSelector();
            renderCostEstimate();
            renderDailyRows(dailyStats);
            status.textContent = '';
        } catch (err) {
            status.textContent = err.message;
        }
    }

    async function savePricingRows() {
        const status = document.getElementById('pricingSaveStatus');
        status.textContent = '';

        try {
            const response = await fetch(`${backendBaseUrl}/api/tokens/pricing`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ rows: pricingRows })
            });
            const payload = await response.json();
            if (!response.ok) {
                throw new Error(payload.detail || payload.error || 'Failed to save token pricing.');
            }

            pricingRows = Array.isArray(payload.rows) ? payload.rows : [];
            if (!pricingRows.some(row => row.id === activePricingId)) {
                activePricingId = pricingRows[0]?.id || '';
            }
            renderPricingRows();
            renderPricingSelector();
            renderCostEstimate();
            renderDailyRows(dailyStats);
            status.textContent = 'Pricing saved.';
        } catch (err) {
            status.textContent = err.message;
        }
    }

    function renderPricingRows() {
        const body = document.getElementById('pricingRows');
        if (!pricingRows.length) {
            body.innerHTML = '<tr><td colspan="7" class="text-muted">No pricing rows. Add one.</td></tr>';
            return;
        }

        body.innerHTML = pricingRows.map((row, index) => `
            <tr>
                <td><input class="form-control form-control-sm" data-index="${index}" data-field="region" value="${esc(row.region || '')}" /></td>
                <td><input class="form-control form-control-sm" data-index="${index}" data-field="model" value="${esc(row.model || '')}" /></td>
                <td><input class="form-control form-control-sm" data-index="${index}" data-field="currency" value="${esc(row.currency || '')}" /></td>
                <td><input class="form-control form-control-sm text-end" type="number" step="0.01" min="0" data-index="${index}" data-field="inputPerMillion" value="${row.inputPerMillion ?? 0}" /></td>
                <td><input class="form-control form-control-sm text-end" type="number" step="0.01" min="0" data-index="${index}" data-field="cachedInputPerMillion" value="${row.cachedInputPerMillion ?? 0}" /></td>
                <td><input class="form-control form-control-sm text-end" type="number" step="0.01" min="0" data-index="${index}" data-field="outputPerMillion" value="${row.outputPerMillion ?? 0}" /></td>
                <td class="text-end"><button class="btn btn-sm btn-outline-danger" type="button" data-action="delete-pricing-row" data-index="${index}">Delete</button></td>
            </tr>
        `).join('');
    }

    function renderPricingSelector() {
        const select = document.getElementById('activePricingSelect');
        if (!pricingRows.length) {
            select.innerHTML = '<option value="">No rows</option>';
            return;
        }

        select.innerHTML = pricingRows
            .map(row => `<option value="${esc(row.id)}">${esc(row.region || '')} | ${esc(row.model || '')} (${esc(row.currency || '')})</option>`)
            .join('');

        select.value = activePricingId;
        if (select.value !== activePricingId) {
            activePricingId = pricingRows[0].id;
            select.value = activePricingId;
        }
    }

    function onPricingTableInput(event) {
        const target = event.target;
        if (!target || !target.dataset) {
            return;
        }

        const index = Number.parseInt(target.dataset.index, 10);
        const field = target.dataset.field;
        if (!Number.isInteger(index) || index < 0 || index >= pricingRows.length || !field) {
            return;
        }

        const row = pricingRows[index];
        if (!row) {
            return;
        }

        if (field === 'inputPerMillion' || field === 'cachedInputPerMillion' || field === 'outputPerMillion') {
            const parsed = Number.parseFloat(target.value);
            row[field] = Number.isFinite(parsed) && parsed >= 0 ? parsed : 0;
        } else {
            row[field] = target.value;
        }

        renderPricingSelector();
        renderCostEstimate();
        renderDailyRows(dailyStats);
    }

    function onPricingTableClick(event) {
        const button = event.target?.closest('button[data-action="delete-pricing-row"]');
        if (!button) {
            return;
        }

        const index = Number.parseInt(button.dataset.index, 10);
        if (!Number.isInteger(index) || index < 0 || index >= pricingRows.length) {
            return;
        }

        const removed = pricingRows[index];
        pricingRows.splice(index, 1);
        if (!pricingRows.length) {
            addPricingRow();
        }
        if (removed?.id === activePricingId) {
            activePricingId = pricingRows[0]?.id || '';
        }
        renderPricingRows();
        renderPricingSelector();
        renderCostEstimate();
        renderDailyRows(dailyStats);
    }

    function addPricingRow() {
        const newId = `row-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
        pricingRows.push({
            id: newId,
            region: '',
            model: '',
            currency: 'DKK',
            inputPerMillion: 0,
            cachedInputPerMillion: 0,
            outputPerMillion: 0
        });

        activePricingId = newId;
        renderPricingRows();
        renderPricingSelector();
        renderCostEstimate();
        renderDailyRows(dailyStats);
    }

    function renderCostEstimate() {
        const totalEl = document.getElementById('estimatedCostTotal');
        const breakdownEl = document.getElementById('estimatedCostBreakdown');
        const activeRow = pricingRows.find(row => row.id === activePricingId);
        if (!activeRow) {
            totalEl.textContent = '-';
            breakdownEl.textContent = 'Select a pricing row to estimate cost.';
            return;
        }

        const inputCost = (summaryStats.promptTokens / 1_000_000) * (Number(activeRow.inputPerMillion) || 0);
        const outputCost = (summaryStats.completionTokens / 1_000_000) * (Number(activeRow.outputPerMillion) || 0);
        const totalCost = inputCost + outputCost;
        const currency = (activeRow.currency || '').trim().toUpperCase() || 'DKK';

        totalEl.textContent = formatCurrency(totalCost, currency);
        breakdownEl.textContent = `Input ${formatCurrency(inputCost, currency)} + Output ${formatCurrency(outputCost, currency)} (Prompt ${fmt.format(summaryStats.promptTokens || 0)} tokens, Completion ${fmt.format(summaryStats.completionTokens || 0)} tokens)`;
    }

    function formatCurrency(value, currency) {
        try {
            return new Intl.NumberFormat(undefined, { style: 'currency', currency, maximumFractionDigits: 2 }).format(value || 0);
        } catch {
            return `${currency} ${decimalFmt.format(value || 0)}`;
        }
    }

    function renderAgentRows(rows) {
        const body = document.getElementById('agentRows');
        body.innerHTML = rows.length ? rows.map(row => `<tr><td>${esc(row.agent)}</td><td>${esc(row.operation)}</td><td class="text-end">${fmt.format(row.calls || 0)}</td><td class="text-end">${fmt.format(row.promptTokens || 0)}</td><td class="text-end">${fmt.format(row.completionTokens || 0)}</td><td class="text-end">${fmt.format(row.totalTokens || 0)}</td><td>${formatDateTime(row.lastSeen)}</td></tr>`).join('') : '<tr><td colspan="7" class="text-muted">No token usage recorded for this range.</td></tr>';
    }

    function renderDailyRows(rows) {
        const body = document.getElementById('dailyRows');
        const activeRow = pricingRows.find(row => row.id === activePricingId);
        const currency = (activeRow?.currency || '').trim().toUpperCase() || 'DKK';
        body.innerHTML = rows.length
            ? rows.map(row => {
                const promptTokens = row.promptTokens || 0;
                const completionTokens = row.completionTokens || 0;
                const dailyCost = activeRow
                    ? ((promptTokens / 1_000_000) * (Number(activeRow.inputPerMillion) || 0)) + ((completionTokens / 1_000_000) * (Number(activeRow.outputPerMillion) || 0))
                    : null;
                return `<tr><td>${formatDate(row.day)}</td><td class="text-end">${fmt.format(row.calls || 0)}</td><td class="text-end">${fmt.format(promptTokens)}</td><td class="text-end">${fmt.format(completionTokens)}</td><td class="text-end">${fmt.format(row.totalTokens || 0)}</td><td class="text-end">${dailyCost === null ? '-' : formatCurrency(dailyCost, currency)}</td></tr>`;
            }).join('')
            : '<tr><td colspan="6" class="text-muted">No daily usage recorded for this range.</td></tr>';
    }

    function renderRecentRows(rows) {
        const body = document.getElementById('recentRows');
        body.innerHTML = rows.length ? rows.map(row => `<tr><td>${formatDateTime(row.occurredAt)}</td><td>${esc(row.agent)}</td><td>${esc(row.operation)}</td><td>${esc(row.modelDeployment || '')}</td><td class="text-end">${fmt.format(row.promptTokens || 0)}</td><td class="text-end">${fmt.format(row.completionTokens || 0)}</td><td class="text-end">${fmt.format(row.totalTokens || 0)}</td></tr>`).join('') : '<tr><td colspan="7" class="text-muted">No recent calls recorded for this range.</td></tr>';
    }

    function formatDateTime(value) {
        return value ? new Date(value).toLocaleString() : '';
    }

    function formatDate(value) {
        return value ? new Date(value).toLocaleDateString() : '';
    }

    function esc(value) {
        return String(value ?? '').replace(/[&<>'"]/g, ch => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[ch]));
    }
</script>
}
