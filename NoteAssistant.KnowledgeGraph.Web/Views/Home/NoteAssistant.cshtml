@using System.Text.Json
@{
    ViewData["Title"] = "NoteAssistant";
    var backendBaseUrl = (string?)ViewData["BackendBaseUrl"] ?? "http://localhost:5070";
    var encodedBackendBaseUrl = JsonSerializer.Serialize(backendBaseUrl.TrimEnd('/'));
}

<div class="container-fluid py-4 noteassistant-page">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <h1 class="mb-1">NoteAssistant</h1>
            <p class="text-muted mb-0">Import NoteAssistant metadata files and fill null values in <code>kg_data.documents</code> for <code>document_type</code>, <code>document_date</code>, and <code>tags</code>.</p>
        </div>
        <div class="text-muted small">
            Matching rule: metadata <code>NoteSession</code> or file name matches <code>documents.title</code> after stripping the trailing <code>_suffix</code> from the title.
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xxl-3">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Folder Input</h2>
                    <p class="text-muted small">Pick the folder that contains your <code>*_metadata.json</code> files. The browser reads the files locally and sends the parsed metadata to the backend.</p>

                    <div class="mb-3">
                        <label class="form-label" for="naFolderInput">Metadata folder</label>
                        <input class="form-control" id="naFolderInput" type="file" webkitdirectory directory multiple accept=".json,application/json" />
                    </div>

                    <div class="small text-muted mb-3" id="naFolderHint">No folder selected.</div>

                    <div class="border rounded p-3 bg-light small mb-3">
                        <div><strong>Document type:</strong> <code>meeting_summary</code></div>
                        <div><strong>Document date source:</strong> <code>FolderCreationDate</code> reduced to <code>yyyy-MM-dd</code></div>
                        <div><strong>Tags JSON:</strong> <code>{ "Customers": [...], "Services": [...] }</code></div>
                        <div><strong>Null-only updates:</strong> existing non-null values are preserved</div>
                    </div>

                    <div class="d-grid gap-2 d-sm-flex">
                        <button class="btn btn-primary" id="naImportBtn" type="button" disabled>Import metadata</button>
                        <button class="btn btn-outline-secondary" id="naClearBtn" type="button">Clear</button>
                    </div>

                    <div class="mt-3 small" id="naMessage"></div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xxl-9">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <h2 class="h5 mb-0">Metadata Files & Import Results</h2>
                            <span class="badge text-bg-secondary" id="naSelectedCount">0 files</span>
                        </div>
                        <div class="small text-muted" id="naResultSummary">Select a folder to preview metadata files.</div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle na-results-table">
                            <thead>
                                <tr>
                                    <th><button type="button" class="btn btn-link btn-sm p-0 na-sort" data-sort="updated">Updated</button></th>
                                    <th><button type="button" class="btn btn-link btn-sm p-0 na-sort" data-sort="fileName">File</button></th>
                                    <th><button type="button" class="btn btn-link btn-sm p-0 na-sort" data-sort="noteSession">NoteSession</button></th>
                                    <th><button type="button" class="btn btn-link btn-sm p-0 na-sort" data-sort="documentDate">Date</button></th>
                                    <th><button type="button" class="btn btn-link btn-sm p-0 na-sort" data-sort="customers">Customers</button></th>
                                    <th><button type="button" class="btn btn-link btn-sm p-0 na-sort" data-sort="services">Services</button></th>
                                    <th><button type="button" class="btn btn-link btn-sm p-0 na-sort" data-sort="matchKey">Match key</button></th>
                                    <th><button type="button" class="btn btn-link btn-sm p-0 na-sort" data-sort="matchedCount">Matched</button></th>
                                </tr>
                                <tr class="na-filter-row">
                                    <th><input class="form-control form-control-sm na-filter" data-filter="updated" placeholder="updated" /></th>
                                    <th><input class="form-control form-control-sm na-filter" data-filter="fileName" placeholder="file" /></th>
                                    <th><input class="form-control form-control-sm na-filter" data-filter="noteSession" placeholder="session" /></th>
                                    <th><input class="form-control form-control-sm na-filter" data-filter="documentDate" placeholder="date" /></th>
                                    <th><input class="form-control form-control-sm na-filter" data-filter="customers" placeholder="customers" /></th>
                                    <th><input class="form-control form-control-sm na-filter" data-filter="services" placeholder="services" /></th>
                                    <th><input class="form-control form-control-sm na-filter" data-filter="matchKey" placeholder="match" /></th>
                                    <th><input class="form-control form-control-sm na-filter" data-filter="matchedCount" placeholder="matched" /></th>
                                </tr>
                            </thead>
                            <tbody id="naConsolidatedBody">
                                <tr>
                                    <td colspan="8" class="text-muted">Select a folder to preview metadata files.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const backendBaseUrl = @Html.Raw(encodedBackendBaseUrl);
    const folderInput = document.getElementById('naFolderInput');
    const importBtn = document.getElementById('naImportBtn');
    const clearBtn = document.getElementById('naClearBtn');
    const folderHint = document.getElementById('naFolderHint');
    const message = document.getElementById('naMessage');
    const selectedCount = document.getElementById('naSelectedCount');
    const consolidatedBody = document.getElementById('naConsolidatedBody');
    const resultSummary = document.getElementById('naResultSummary');
    const sortButtons = Array.from(document.querySelectorAll('.na-sort'));
    const filterInputs = Array.from(document.querySelectorAll('.na-filter'));

    let metadataFiles = [];
    let importResults = new Map();
    let sortState = { key: 'updated', direction: 'desc' };
    let filters = {};

    folderInput.addEventListener('change', onFolderSelected);
    importBtn.addEventListener('click', importMetadata);
    clearBtn.addEventListener('click', resetPage);
    sortButtons.forEach(button => button.addEventListener('click', () => setSort(button.dataset.sort)));
    filterInputs.forEach(input => input.addEventListener('input', () => {
        filters[input.dataset.filter] = input.value.trim().toLowerCase();
        renderConsolidatedTable();
    }));
    updateSortIndicators();

    async function onFolderSelected() {
        const files = Array.from(folderInput.files || []);
        if (files.length === 0) {
            resetPage();
            return;
        }

        setMessage(`Reading ${files.length} file${files.length === 1 ? '' : 's'}...`, 'text-muted');
        const parsed = [];
        const invalid = [];

        for (const file of files) {
            if (!file.name.toLowerCase().endsWith('_metadata.json')) {
                continue;
            }

            try {
                const text = await file.text();
                const json = JSON.parse(text);
                parsed.push({
                    fileName: file.webkitRelativePath || file.name,
                    noteSession: typeof json.NoteSession === 'string' ? json.NoteSession.trim() : '',
                    folderCreationDate: typeof json.FolderCreationDate === 'string' ? json.FolderCreationDate : '',
                    customers: Array.isArray(json.Customers) ? json.Customers.filter(Boolean) : [],
                    services: Array.isArray(json.Services) ? json.Services.filter(Boolean) : []
                });
            } catch (error) {
                invalid.push(`${file.name}: ${error.message}`);
            }
        }

        metadataFiles = parsed;
        selectedCount.textContent = `${metadataFiles.length} file${metadataFiles.length === 1 ? '' : 's'}`;
        folderHint.textContent = files[0]?.webkitRelativePath
            ? `Selected folder: ${files[0].webkitRelativePath.split('/')[0]}`
            : `${files.length} file${files.length === 1 ? '' : 's'} selected`;
        importBtn.disabled = metadataFiles.length === 0;
        importResults = new Map();
        renderConsolidatedTable();

        if (invalid.length > 0) {
            setMessage(`Loaded ${metadataFiles.length} metadata file(s). Skipped ${invalid.length} invalid file(s).`, 'text-warning');
        } else if (metadataFiles.length > 0) {
            setMessage(`Loaded ${metadataFiles.length} metadata file(s). Ready to import.`, 'text-success');
        } else {
            setMessage('No *_metadata.json files were found in the selected folder.', 'text-warning');
        }
    }

    async function importMetadata() {
        if (metadataFiles.length === 0) {
            setMessage('Select a folder with metadata files first.', 'text-danger');
            return;
        }

        importBtn.disabled = true;
        setMessage(`Importing ${metadataFiles.length} metadata file(s)...`, 'text-muted');

        let response;
        try {
            response = await fetch(`${backendBaseUrl}/api/noteassistant/import-metadata`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ files: metadataFiles })
            });
        } catch (error) {
            importBtn.disabled = false;
            setMessage(`Import failed: ${error.message}`, 'text-danger');
            return;
        }

        let payload = null;
        try {
            payload = await response.json();
        } catch {
        }

        importBtn.disabled = false;

        if (!response.ok) {
            setMessage((payload && (payload.error || payload.detail)) || `Import failed with status ${response.status}.`, 'text-danger');
            return;
        }

        importResults = new Map((payload.results || []).map(result => [result.fileName || '', result]));
        sortState = { key: 'updated', direction: 'desc' };
        renderConsolidatedTable();
        resultSummary.textContent = `${payload.processed || 0} processed | ${payload.updated || 0} updated | ${payload.notFound || 0} not found`;
        setMessage('Import completed.', 'text-success');
    }

    function renderConsolidatedTable() {
        updateSortIndicators();

        if (metadataFiles.length === 0) {
            consolidatedBody.innerHTML = '<tr><td colspan="8" class="text-muted">Select a folder to preview metadata files.</td></tr>';
            resultSummary.textContent = 'Select a folder to preview metadata files.';
            return;
        }

        const rows = metadataFiles.map(file => buildConsolidatedRow(file, importResults.get(file.fileName)));
        const filtered = rows.filter(row => Object.entries(filters).every(([key, value]) => !value || getFilterText(row, key).includes(value)));
        filtered.sort(compareRows);

        if (filtered.length === 0) {
            consolidatedBody.innerHTML = '<tr><td colspan="8" class="text-muted">No rows match the active filters.</td></tr>';
            resultSummary.textContent = `${metadataFiles.length} selected | 0 shown after filters`;
            return;
        }

        consolidatedBody.innerHTML = filtered.map(row => {
            const statusClass = row.status === 'updated'
                ? 'text-bg-success'
                : row.status === 'already-populated'
                    ? 'text-bg-secondary'
                    : row.status === 'not-found'
                        ? 'text-bg-warning'
                        : 'text-bg-light text-dark';
            const customers = row.customers ? escapeHtml(row.customers) : '<span class="text-muted">none</span>';
            const services = row.services ? escapeHtml(row.services) : '<span class="text-muted">none</span>';
            return `
                <tr>
                    <td><span class="badge ${statusClass}">${escapeHtml(row.updatedLabel)}</span></td>
                    <td>${escapeHtml(row.fileName)}</td>
                    <td>${escapeHtml(row.noteSession || '(missing)')}</td>
                    <td>${escapeHtml(row.documentDate || '(missing)')}</td>
                    <td>${customers}</td>
                    <td>${services}</td>
                    <td>${escapeHtml(row.matchKey || '')}</td>
                    <td>${escapeHtml(String(row.matchedCount))}</td>
                </tr>`;
        }).join('');

        const updated = rows.filter(row => row.status === 'updated').length;
        const notFound = rows.filter(row => row.status === 'not-found').length;
        const imported = rows.filter(row => row.status).length;
        resultSummary.textContent = `${metadataFiles.length} selected | ${filtered.length} shown | ${imported} imported | ${updated} updated | ${notFound} not found`;
    }

    function buildConsolidatedRow(file, result) {
        const documentDate = result?.documentDate || normalizeDate(file.folderCreationDate);
        const status = result?.status || '';
        const updatedCount = Number(result?.updatedCount ?? 0);
        return {
            fileName: file.fileName,
            noteSession: file.noteSession,
            documentDate,
            customers: file.customers.join(', '),
            services: file.services.join(', '),
            matchKey: result?.matchKey || deriveMatchKey(file),
            matchedCount: Number(result?.matchedCount ?? 0),
            updatedCount,
            updated: status === 'updated' ? 2 : status ? (updatedCount > 0 ? 2 : 1) : 0,
            updatedLabel: status ? `${updatedCount} ${status}` : 'pending',
            status
        };
    }

    function deriveMatchKey(file) {
        const noteSession = (file.noteSession || '').trim();
        if (noteSession) {
            return noteSession.replace(/_metadata$/i, '').replace(/\.md$/i, '').trim();
        }

        return (file.fileName || '')
            .split(/[\\/]/).pop()
            ?.replace(/_metadata\.json$/i, '')
            .replace(/_summary$/i, '') || '';
    }

    function setSort(key) {
        if (sortState.key === key) {
            sortState.direction = sortState.direction === 'asc' ? 'desc' : 'asc';
        } else {
            sortState = { key, direction: key === 'updated' ? 'desc' : 'asc' };
        }
        renderConsolidatedTable();
    }

    function getFilterText(row, key) {
        if (key === 'updated') {
            return `${row.updatedLabel} ${row.status}`.toLowerCase();
        }

        return String(row[key] ?? '').toLowerCase();
    }

    function compareRows(left, right) {
        const direction = sortState.direction === 'asc' ? 1 : -1;
        const key = sortState.key;
        const leftValue = left[key];
        const rightValue = right[key];
        if (typeof leftValue === 'number' || typeof rightValue === 'number') {
            return ((Number(leftValue) || 0) - (Number(rightValue) || 0)) * direction || left.fileName.localeCompare(right.fileName);
        }
        return String(leftValue || '').localeCompare(String(rightValue || ''), undefined, { numeric: true, sensitivity: 'base' }) * direction;
    }

    function updateSortIndicators() {
        sortButtons.forEach(button => {
            const active = button.dataset.sort === sortState.key;
            button.classList.toggle('fw-semibold', active);
            const label = button.textContent.replace(/\s+[▲▼]$/, '');
            button.textContent = active ? `${label} ${sortState.direction === 'asc' ? '▲' : '▼'}` : label;
        });
    }

    function normalizeDate(value) {
        if (!value) {
            return '';
        }

        const date = new Date(value);
        if (Number.isNaN(date.getTime())) {
            return '';
        }

        return date.toISOString().slice(0, 10);
    }

    function resetPage() {
        metadataFiles = [];
        importResults = new Map();
        filters = {};
        filterInputs.forEach(input => input.value = '');
        sortState = { key: 'updated', direction: 'desc' };
        folderInput.value = '';
        selectedCount.textContent = '0 files';
        folderHint.textContent = 'No folder selected.';
        consolidatedBody.innerHTML = '<tr><td colspan="8" class="text-muted">Select a folder to preview metadata files.</td></tr>';
        resultSummary.textContent = 'Select a folder to preview metadata files.';
        importBtn.disabled = true;
        setMessage('', 'text-muted');
        updateSortIndicators();
    }

    function setMessage(text, className) {
        message.className = `mt-3 small ${className || 'text-muted'}`;
        message.textContent = text;
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }
})();
</script>
}