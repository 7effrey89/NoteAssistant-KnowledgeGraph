@using System.Text.Json
@{
    ViewData["Title"] = "NoteAssistant";
    var backendBaseUrl = (string?)ViewData["BackendBaseUrl"] ?? "http://localhost:5070";
    var encodedBackendBaseUrl = JsonSerializer.Serialize(backendBaseUrl.TrimEnd('/'));
}

<div class="container-fluid py-4 noteassistant-page">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <h1 class="mb-1">NoteAssistant</h1>
            <p class="text-muted mb-0">Generate stakeholder-ready meeting summaries from NoteAssistant transcript text files.</p>
        </div>
        <div class="text-muted small">Output is written by the local backend to the folder path you provide.</div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Transcript Input</h2>
                    <p class="text-muted small">Select the original transcript folder when possible, or choose one or more <code>transcript.txt</code> / <code>transcript.md</code> files. The original folder name is used for the summary filename.</p>

                    <div class="mb-3">
                        <label class="form-label" for="naTranscriptFolder">Transcript folder</label>
                        <input class="form-control" id="naTranscriptFolder" type="file" webkitdirectory directory multiple accept=".txt,.md,text/plain,text/markdown" />
                        <div class="small text-muted mt-2">Recommended. This lets the app infer the original folder name automatically.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="naTranscriptFiles">Transcript files</label>
                        <input class="form-control" id="naTranscriptFiles" type="file" multiple accept=".txt,.md,text/plain,text/markdown" />
                        <div class="small text-muted mt-2">Use this if you cannot select a folder. Then fill the original transcript folder path/name below.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="naOriginalFolderPath">Original transcript folder path or name <span class="text-danger">*</span></label>
                        <input class="form-control" id="naOriginalFolderPath" type="text" placeholder="C:\Users\you\Documents\NoteAssistant\ISS - Insight - 27-05-26 13.02.16" />
                        <div class="small text-muted mt-2">Required. Names the saved file: &lt;original folder name&gt;_summary_v2.md. Auto-filled when using the folder picker above.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="naOutputFolderPath">Output folder path</label>
                        <input class="form-control" id="naOutputFolderPath" type="text" placeholder="C:\Users\you\Documents\NoteAssistant\Meeting Folder" />
                        <div class="d-grid gap-2 d-sm-flex">
                            <button class="btn btn-outline-secondary" id="naClearBtn" type="button">Clear</button>
                        </div>
                        <div class="small text-muted mt-2" id="naOutputFolderHint">The summary is saved as &lt;folder name&gt;_summary_v2.md.</div>
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-primary" id="naSummarizeBtn" type="button" disabled>Generate meeting summary</button>
                    </div>

                    <div class="mt-3 small" id="naMessage"></div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <h2 class="h5 mb-0">Summary Output</h2>
                            <span class="badge text-bg-secondary" id="naSelectedCount">0 files</span>
                        </div>
                        <div class="small text-muted" id="naResultSummary">Select transcript files and an output folder.</div>
                    </div>

                    <div class="na-file-list border rounded bg-light p-3 mb-3" id="naFileList">No transcript files selected.</div>

                    <textarea class="form-control na-summary-preview" id="naSummaryPreview" rows="22" readonly placeholder="Generated meeting summary will appear here after processing."></textarea>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <button class="btn btn-outline-primary btn-sm" id="naCopyBtn" type="button" disabled>Copy summary</button>
                        <button class="btn btn-outline-secondary btn-sm" id="naDownloadBtn" type="button" disabled>Download summary</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const backendBaseUrl = @Html.Raw(encodedBackendBaseUrl);
    const folderInput = document.getElementById('naTranscriptFolder');
    const fileInput = document.getElementById('naTranscriptFiles');
    const originalFolderPathInput = document.getElementById('naOriginalFolderPath');
    const outputFolderPathInput = document.getElementById('naOutputFolderPath');
    const clearBtn = document.getElementById('naClearBtn');
    const summarizeBtn = document.getElementById('naSummarizeBtn');
    const outputFolderHint = document.getElementById('naOutputFolderHint');
    const selectedCount = document.getElementById('naSelectedCount');
    const resultSummary = document.getElementById('naResultSummary');
    const fileList = document.getElementById('naFileList');
    const summaryPreview = document.getElementById('naSummaryPreview');
    const copyBtn = document.getElementById('naCopyBtn');
    const downloadBtn = document.getElementById('naDownloadBtn');
    const message = document.getElementById('naMessage');

    let latestSummary = '';
    let latestFileName = 'meeting-summary.md';

    folderInput.addEventListener('change', renderSelectedFiles);
    fileInput.addEventListener('change', renderSelectedFiles);
    originalFolderPathInput.addEventListener('input', updateSummarizeButton);
    outputFolderPathInput.addEventListener('input', updateSummarizeButton);
    clearBtn.addEventListener('click', resetPage);
    summarizeBtn.addEventListener('click', summarizeTranscripts);
    copyBtn.addEventListener('click', copySummary);
    downloadBtn.addEventListener('click', downloadSummary);

    renderSelectedFiles();

    function renderSelectedFiles() {
        const files = getTranscriptFiles();
        selectedCount.textContent = `${files.length} file${files.length === 1 ? '' : 's'}`;
        if (files.length === 0) {
            fileList.textContent = 'No transcript files selected.';
            resultSummary.textContent = 'Select transcript files and an output folder.';
        } else {
            fileList.innerHTML = files.map(file => `<div><strong>${escapeHtml(file.webkitRelativePath || file.name)}</strong> <span class="text-muted">${formatBytes(file.size)}</span></div>`).join('');
            resultSummary.textContent = `${files.length} transcript file${files.length === 1 ? '' : 's'} ready.`;
            const relativeRoot = getRelativeRoot(files);
            if (relativeRoot && !originalFolderPathInput.value.trim()) {
                originalFolderPathInput.value = relativeRoot;
            }
        }
        updateSummarizeButton();
    }

    function updateSummarizeButton() {
        summarizeBtn.disabled = getTranscriptFiles().length === 0
            || !outputFolderPathInput.value.trim()
            || !originalFolderPathInput.value.trim();
    }

    async function summarizeTranscripts() {
        const files = getTranscriptFiles();
        if (files.length === 0) {
            setMessage('Select one or more transcript text files first.', 'text-danger');
            return;
        }
        const outputFolderPath = outputFolderPathInput.value.trim();
        const originalFolderPath = originalFolderPathInput.value.trim();
        if (!outputFolderPath) {
            setMessage('Enter an output folder path first.', 'text-danger');
            return;
        }
        if (!originalFolderPath) {
            setMessage('Enter the original transcript folder path or name so the summary can be named correctly.', 'text-danger');
            return;
        }

        const originalButtonHtml = summarizeBtn.innerHTML;
        summarizeBtn.disabled = true;
        summarizeBtn.innerHTML = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span><span class="ms-2">Summarizing...</span>';
        setMessage(`Summarizing ${files.length} file${files.length === 1 ? '' : 's'}...`, 'text-muted');

        try {
            const formData = new FormData();
            files.forEach(file => formData.append('files', file, file.name));
            formData.append('outputFolderPath', outputFolderPath);
            formData.append('originalFolderPath', originalFolderPath);
            const response = await fetch(`${backendBaseUrl}/api/noteassistant/summarize-transcript`, {
                method: 'POST',
                body: formData
            });
            const payload = await response.json().catch(() => null);
            if (!response.ok || payload?.success === false) {
                setMessage(payload?.error || `Summary failed with status ${response.status}.`, 'text-danger');
                return;
            }

            latestSummary = payload.summaryMarkdown || '';
            latestFileName = sanitizeFileName(payload.suggestedFileName || getDefaultSummaryFileName(originalFolderPath, outputFolderPath));
            summaryPreview.value = latestSummary;
            copyBtn.disabled = !latestSummary;
            downloadBtn.disabled = !latestSummary;
            resultSummary.textContent = `${payload.fileCount} file${payload.fileCount === 1 ? '' : 's'} summarized | ${payload.characterCount} characters processed`;
            setMessage(`Summary written to ${payload.outputPath || latestFileName}.`, 'text-success');
        } catch (error) {
            setMessage(`Summary failed: ${error.message}`, 'text-danger');
        } finally {
            summarizeBtn.innerHTML = originalButtonHtml;
            updateSummarizeButton();
        }
    }

    async function copySummary() {
        if (!latestSummary) return;
        await navigator.clipboard.writeText(latestSummary);
        setMessage('Summary copied to clipboard.', 'text-success');
    }

    function downloadSummary() {
        if (!latestSummary) return;
        const blob = new Blob([latestSummary], { type: 'text/markdown;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const anchor = document.createElement('a');
        anchor.href = url;
        anchor.download = latestFileName;
        anchor.click();
        URL.revokeObjectURL(url);
    }

    function resetPage() {
        folderInput.value = '';
        fileInput.value = '';
        originalFolderPathInput.value = '';
        outputFolderPathInput.value = '';
        latestSummary = '';
        latestFileName = 'meeting-summary.md';
        summaryPreview.value = '';
        copyBtn.disabled = true;
        downloadBtn.disabled = true;
        outputFolderHint.textContent = 'The summary is saved as <folder name>_summary_v2.md.';
        setMessage('', '');
        renderSelectedFiles();
    }

    function setMessage(text, className) {
        message.className = className || '';
        message.textContent = text;
    }

    function formatBytes(bytes) {
        if (!Number.isFinite(bytes) || bytes <= 0) return '0 B';
        const units = ['B', 'KB', 'MB'];
        let value = bytes;
        let unit = 0;
        while (value >= 1024 && unit < units.length - 1) {
            value /= 1024;
            unit++;
        }
        return `${value.toFixed(unit === 0 ? 0 : 1)} ${units[unit]}`;
    }

    function sanitizeFileName(value) {
        const cleaned = String(value || 'meeting-summary.md').replace(/[\\/:*?"<>|]+/g, '-').trim();
        return cleaned.toLowerCase().endsWith('.md') ? cleaned : `${cleaned}.md`;
    }

    function getDefaultSummaryFileName(originalFolderPath, outputFolderPath) {
        const sourcePath = originalFolderPath || outputFolderPath;
        const normalized = String(sourcePath || '').replace(/[\\/]+$/g, '');
        const folderName = normalized.split(/[\\/]/).filter(Boolean).pop() || 'meeting';
        const safeFolderName = sanitizeFileName(folderName).replace(/\.md$/i, '') || 'meeting';
        return `${safeFolderName}_summary_v2.md`;
    }

    function getRelativeRoot(files) {
        const relativePaths = files.map(file => file.webkitRelativePath).filter(Boolean);
        if (relativePaths.length === 0) return '';
        const parts = relativePaths.map(path => path.split('/').filter(Boolean));
        if (parts.every(pathParts => pathParts.length >= 2)) {
            const first = parts[0][0];
            const second = parts[0][1];
            if (parts.every(pathParts => pathParts[0] === first && pathParts[1] === second)) {
                return second;
            }
        }
        return parts[0][0] || '';
    }

    function getTranscriptFiles() {
        const acceptedExtensions = ['.txt', '.md'];
        const files = [...Array.from(folderInput.files || []), ...Array.from(fileInput.files || [])];
        const unique = new Map();
        for (const file of files) {
            const lowerName = file.name.toLowerCase();
            if (!acceptedExtensions.some(extension => lowerName.endsWith(extension))) continue;
            unique.set(file.webkitRelativePath || file.name, file);
        }
        return [...unique.values()];
    }

    function escapeHtml(value) {
        return String(value ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
})();
</script>
}